    }
    .wa-float:hover .wa-tooltip { opacity: 1; }
    .wa-tooltip::after {
      content: '';
      position: absolute; left: 100%; top: 50%;
      transform: translateY(-50%);
      border: 5px solid transparent;
      border-left-color: #0f172a;
    }
  </style>
</head>
