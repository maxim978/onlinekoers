---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

let formSuccess = false;
let formError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const companyName = String(formData.get('company_name') || '').trim();
  const industry    = String(formData.get('industry')    || '').trim();
  const email       = String(formData.get('email')       || '').trim();
  const phone       = String(formData.get('phone')       || '').trim();

  if (!companyName || !email) {
    formError = 'Vul minimaal uw bedrijfsnaam en e-mailadres in.';
  } else {
    const slug = companyName.toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim();

    const { error: insertError } = await supabase.from('leads').insert({
      company_name: companyName,
      slug: `${slug}-${Date.now()}`,
      industry: industry || null,
      status: 'Concept',
      style_instructions: `Contactgegevens: ${email}${phone ? ', ' + phone : ''}`,
    });

    formError   = insertError ? 'Er is een fout opgetreden. Probeer het opnieuw.' : '';
    formSuccess = !insertError;
  }
}
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="OnlineKoers – Uw vakmanschap verdient een digitale koers die staat. Wij bouwen eerst, u beslist later."/>
  <title>OnlineKoers – Digitale koers voor vakmannen</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html  { scroll-behavior: smooth; }
    body  {
      font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
      background: #fff;
      color: #0f172a;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }
    img { display: block; max-width: 100%; }

    /* ── ANIMATIONS ─────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @keyframes fadeLeft {
      from { opacity: 0; transform: translateX(-40px); }
      to   { opacity: 1; transform: translateX(0);     }
    }
    @keyframes float {
      0%,100% { transform: translateY(0)    rotate(0deg);  }
      33%     { transform: translateY(-14px) rotate(2deg);  }
      66%     { transform: translateY(-7px)  rotate(-1deg); }
    }
    @keyframes pulseDot {
      0%,100% { opacity: 1; transform: scale(1); }
      50%     { opacity: 0.4; transform: scale(1.5); }
    }
    @keyframes blobFloat {
      0%,100% { transform: translate(0,0) scale(1); }
      25%     { transform: translate(40px,-60px) scale(1.08); }
      50%     { transform: translate(-25px,-80px) scale(0.92); }
      75%     { transform: translate(-55px, 30px) scale(1.05); }
    }
    @keyframes marqueeScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes scrollLine {
      0%   { transform: scaleY(0) translateY(0); transform-origin: top; opacity: 1; }
      45%  { transform: scaleY(1) translateY(0); transform-origin: top; opacity: 1; }
      55%  { transform: scaleY(1) translateY(0); transform-origin: bottom; opacity: 1; }
      100% { transform: scaleY(0) translateY(0); transform-origin: bottom; opacity: 0; }
    }
    @keyframes waPulse {
      0%,100% { box-shadow: 0 4px 24px rgba(37,211,102,.4); }
      50%     { box-shadow: 0 4px 40px rgba(37,211,102,.7), 0 0 0 10px rgba(37,211,102,.1); }
    }
    @keyframes iconBounce {
      0%,100% { transform: translateY(0); }
      50%     { transform: translateY(-5px); }
    }
    @keyframes spinSlow {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    @keyframes shimmer {
      0%   { transform: translateX(-100%); }
      100% { transform: translateX(200%); }
    }

    .reveal {
      opacity: 0; transform: translateY(40px);
      transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1);
    }
    .reveal.in { opacity: 1; transform: translateY(0); }
    .reveal-l {
      opacity: 0; transform: translateX(-40px);
      transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1);
    }
    .reveal-l.in { opacity: 1; transform: translateX(0); }

    /* ── HELPERS ──────────────────────────────── */
    .container  { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    .section    { padding: 7rem 1.5rem; }
    .section-sm { padding: 5rem 1.5rem; }

    .section-label {
      display: inline-flex; align-items: center; gap: .625rem;
      font-size: .72rem; font-weight: 700; letter-spacing: .14em;
      text-transform: uppercase; color: #f97316; margin-bottom: .875rem;
    }
    .section-label::before { content:''; width:20px; height:2px; background:#f97316; }

    .section-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900; letter-spacing: -.03em; line-height: 1.1;
      color: #0f172a; margin-bottom: 1.125rem;
    }
    .section-title.white  { color: #fff; }
    .section-sub {
      font-size: 1.05rem; color: #64748b; line-height: 1.75;
      max-width: 520px;
    }
    .section-sub.white { color: rgba(255,255,255,.65); }

    .accent-orange { color: #f97316; }

    /* ── BUTTONS ──────────────────────────────── */
    .btn-orange {
      display: inline-flex; align-items: center; gap: .5rem;
      background: #f97316; color: #fff;
      padding: .875rem 1.875rem;
      border-radius: .625rem; font-size: .95rem; font-weight: 700;
      border: none; cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 4px 24px rgba(249,115,22,.3);
      letter-spacing: -.01em;
    }
    .btn-orange:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(249,115,22,.45); }

    .btn-outline {
      display: inline-flex; align-items: center; gap: .5rem;
      background: transparent; color: #0f172a;
      padding: .875rem 1.875rem;
      border-radius: .625rem; font-size: .95rem; font-weight: 600;
      border: 1.5px solid #e2e8f0; cursor: pointer;
      transition: border-color .2s, background .2s, color .2s;
    }
    .btn-outline:hover { border-color: #f97316; color: #f97316; background: #fff7ed; }

    .btn-white {
      display: inline-flex; align-items: center; gap: .5rem;
      background: #fff; color: #f97316;
      padding: .875rem 1.875rem;
      border-radius: .625rem; font-size: .95rem; font-weight: 700;
      border: none; cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 4px 20px rgba(0,0,0,.15);
    }
    .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,.2); }

    .btn-whatsapp {
      display: inline-flex; align-items: center; gap: .75rem;
      background: #25d366; color: #fff;
      padding: .875rem 1.875rem;
      border-radius: .625rem; font-size: .95rem; font-weight: 700;
      border: none; cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 4px 20px rgba(37,211,102,.3);
      width: 100%; justify-content: center;
    }
    .btn-whatsapp:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(37,211,102,.45); }

    /* ── NAV ──────────────────────────────────── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 68px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem;
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid #f1f5f9;
      transition: box-shadow .3s;
    }
    .nav.scrolled { box-shadow: 0 1px 20px rgba(0,0,0,.08); }
    .nav-logo img { height: 34px; width: auto; }
    .nav-links { display: flex; align-items: center; gap: 2rem; }
    .nav-links a {
      font-size: .875rem; font-weight: 500; color: #64748b;
      transition: color .2s;
    }
    .nav-links a:hover { color: #0f172a; }
    .nav-cta {
      background: #f97316; color: #fff;
      padding: .5rem 1.25rem; border-radius: .5rem;
      font-size: .875rem; font-weight: 700;
      transition: transform .15s, box-shadow .15s;
      box-shadow: 0 2px 12px rgba(249,115,22,.3);
    }
    .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(249,115,22,.4); color: #fff !important; }

    /* ── HERO ─────────────────────────────────── */
    .hero {
      padding: 9rem 1.5rem 6rem;
      background: #fff;
      position: relative; overflow: hidden;
      min-height: 100vh; display: flex; align-items: center;
    }

    /* Animated blobs */
    .hero-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }
    .hero-blob-1 {
      width: 550px; height: 550px;
      background: rgba(249,115,22,.1);
      top: -150px; right: -120px;
      animation: blobFloat 20s ease-in-out infinite;
    }
    .hero-blob-2 {
      width: 400px; height: 400px;
      background: rgba(251,191,36,.07);
      bottom: -80px; left: 5%;
      animation: blobFloat 16s ease-in-out infinite reverse;
    }
    .hero-blob-3 {
      width: 280px; height: 280px;
      background: rgba(15,23,42,.04);
      top: 45%; left: 45%;
      animation: blobFloat 24s ease-in-out infinite 5s;
    }

    /* Decorative spinning ring */
    .hero-ring {
      position: absolute; top: 10%; right: 8%;
      width: 180px; height: 180px;
      border: 1.5px dashed rgba(249,115,22,.18);
      border-radius: 50%;
      animation: spinSlow 40s linear infinite;
      pointer-events: none;
    }
    .hero-ring-inner {
      position: absolute; top: 20%; right: 13%;
      width: 100px; height: 100px;
      border: 1px dashed rgba(249,115,22,.12);
      border-radius: 50%;
      animation: spinSlow 28s linear infinite reverse;
      pointer-events: none;
    }

    .hero-inner {
      max-width: 1200px; margin: 0 auto; width: 100%;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4rem; align-items: center;
      position: relative; z-index: 1;
    }
    @media (max-width: 860px) {
      .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .hero-visual { display: none; }
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: #fff7ed; border: 1px solid #fed7aa;
      border-radius: 9999px; padding: .375rem 1rem;
      font-size: .78rem; font-weight: 700;
      color: #c2410c; margin-bottom: 1.5rem;
      animation: fadeUp .5s .05s both;
    }
    .hero-badge-dot {
      width: 7px; height: 7px; background: #f97316;
      border-radius: 50%; animation: pulseDot 2s ease-in-out infinite;
    }

    .hero-title {
      font-size: clamp(2.6rem, 5vw, 4.25rem);
      font-weight: 900; letter-spacing: -.04em; line-height: 1.06;
      color: #0f172a; margin-bottom: 1.5rem;
      animation: fadeUp .6s .1s both;
    }
    .hero-title .accent-orange { font-style: normal; }

    .hero-sub {
      font-size: 1.1rem; color: #64748b; line-height: 1.75;
      margin-bottom: 2.5rem; max-width: 480px;
      animation: fadeUp .6s .18s both;
    }
    .hero-sub strong { color: #0f172a; font-weight: 600; }

    .hero-cta {
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
      animation: fadeUp .6s .25s both;
    }

    .hero-stats {
      display: flex; gap: 2.5rem; margin-top: 3rem;
      padding-top: 2rem; border-top: 1px solid #f1f5f9;
      animation: fadeUp .6s .35s both;
    }
    .hstat-val {
      font-size: 1.85rem; font-weight: 900; color: #0f172a;
      letter-spacing: -.05em; line-height: 1;
    }
    .hstat-lbl { font-size: .75rem; color: #94a3b8; font-weight: 500; margin-top: .25rem; }

    /* Scroll cue */
    .scroll-cue {
      position: absolute; bottom: 2.5rem; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      opacity: .4;
    }
    .scroll-cue-text { font-size: .65rem; letter-spacing: .12em; text-transform: uppercase; color: #94a3b8; }
    .scroll-cue-line {
      width: 1.5px; height: 44px;
      background: linear-gradient(to bottom, #f97316, transparent);
      animation: scrollLine 2.2s ease-in-out infinite;
    }

    /* Hero visual */
    .hero-visual {
      position: relative; animation: fadeUp .8s .3s both;
    }
    .browser-window {
      background: #fff;
      border-radius: 1rem;
      box-shadow: 0 20px 80px rgba(15,23,42,.12), 0 0 0 1px rgba(15,23,42,.06);
      overflow: hidden;
    }
    .browser-bar {
      background: #f8fafc; padding: .75rem 1rem;
      display: flex; align-items: center; gap: .5rem;
      border-bottom: 1px solid #f1f5f9;
    }
    .browser-dot { width: 10px; height: 10px; border-radius: 50%; }
    .browser-url {
      flex: 1; background: #fff; border: 1px solid #e2e8f0;
      border-radius: .375rem; padding: .25rem .75rem;
      font-size: .72rem; color: #94a3b8; margin: 0 .5rem;
    }
    .browser-content {
      padding: 1.5rem;
      background: linear-gradient(135deg, #fff7ed 0%, #fff 60%);
      min-height: 240px;
    }
    .mock-btn  {
      display: inline-block; margin-top: 1rem;
      padding: .5rem 1.25rem; background: #f97316;
      border-radius: .375rem; height: 32px; width: 120px;
      position: relative; overflow: hidden;
    }
    .mock-btn::after {
      content: '';
      position: absolute; top: 0; left: 0;
      width: 40%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.3), transparent);
      animation: shimmer 2.5s ease-in-out infinite 1s;
    }

    /* Floating badges */
    .float-badge {
      position: absolute; right: -24px; bottom: 36px;
      background: #fff; border-radius: .75rem;
      box-shadow: 0 8px 30px rgba(15,23,42,.12);
      padding: .875rem 1rem;
      display: flex; align-items: center; gap: .75rem;
      animation: float 5s ease-in-out infinite;
    }
    .float-badge-icon {
      width: 36px; height: 36px; background: #fff7ed;
      border-radius: .5rem; display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; flex-shrink: 0;
    }
    .float-badge-text { font-size: .78rem; font-weight: 700; color: #0f172a; white-space: nowrap; }
    .float-badge-sub  { font-size: .7rem; color: #94a3b8; white-space: nowrap; }

    .float-badge-2 {
      position: absolute; left: -30px; top: 40px;
      background: #fff; border-radius: .75rem;
      box-shadow: 0 8px 30px rgba(15,23,42,.1);
      padding: .75rem .875rem;
      display: flex; align-items: center; gap: .625rem;
      animation: float 7s ease-in-out infinite 2s;
    }
    .badge2-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; flex-shrink: 0; animation: pulseDot 1.8s infinite; }

    /* ── MARQUEE BAND ─────────────────────────── */
    .marquee-band {
      background: #0f172a;
      padding: .875rem 0;
      overflow: hidden;
    }
    .marquee-track {
      display: flex; align-items: center; gap: 0;
      animation: marqueeScroll 28s linear infinite;
      width: max-content;
    }
    .marquee-band:hover .marquee-track { animation-play-state: paused; }
    .marquee-item {
      display: flex; align-items: center; gap: 1.5rem;
      padding: 0 2rem;
      font-size: .8rem; font-weight: 600; color: rgba(255,255,255,.45);
      letter-spacing: .08em; text-transform: uppercase; white-space: nowrap;
    }
    .marquee-dot { width: 4px; height: 4px; border-radius: 50%; background: #f97316; flex-shrink: 0; }
    .marquee-item .highlight { color: rgba(255,255,255,.85); }

    /* ── INDUSTRY PILLS BAND ─────────────────── */
    .pills-band {
      background: #f8fafc;
      border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9;
      padding: 2rem 1.5rem;
    }
    .pills-inner {
      max-width: 900px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; gap: 2rem;
      flex-wrap: wrap;
    }
    .pills-inner p { font-size: .8rem; color: #94a3b8; font-weight: 500; white-space: nowrap; }
    .stat-pills { display: flex; gap: 1rem; flex-wrap: wrap; }
    .stat-pill {
      background: #fff; border: 1px solid #e2e8f0; border-radius: 9999px;
      padding: .5rem 1.125rem;
      font-size: .8rem; font-weight: 700; color: #0f172a;
      transition: border-color .2s, box-shadow .2s;
    }
    .stat-pill:hover { border-color: #fed7aa; box-shadow: 0 2px 12px rgba(249,115,22,.1); }
    .stat-pill span { color: #f97316; margin-right: .3rem; }

    /* ── AANPAK – WHITE ───────────────────────── */
    .aanpak-bg { background: #fff; }
    .steps {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem; margin-top: 3.5rem;
    }
    @media (max-width: 640px) { .steps { grid-template-columns: 1fr; } }

    .step-card {
      background: #fff;
      border: 1.5px solid #f1f5f9;
      border-radius: 1.25rem; padding: 2.25rem;
      position: relative; overflow: hidden;
      transition: border-color .3s, box-shadow .3s;
      transform-style: preserve-3d;
      will-change: transform;
    }
    .step-card::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(249,115,22,.06) 0%, transparent 60%);
      opacity: 0;
      transition: opacity .3s;
    }
    .step-card:hover::before { opacity: 1; }
    .step-card:hover {
      border-color: #fed7aa;
      box-shadow: 0 16px 48px rgba(249,115,22,.12);
    }
    .step-num {
      font-size: 4.5rem; font-weight: 900; line-height: 1;
      color: #f1f5f9; margin-bottom: 1.25rem;
      transition: color .3s;
    }
    .step-card:hover .step-num { color: #fed7aa; }
    .step-icon {
      width: 44px; height: 44px; background: #fff7ed;
      border-radius: .75rem; display: flex; align-items: center; justify-content: center;
      color: #f97316; margin-bottom: 1.25rem;
      transition: transform .3s;
    }
    .step-card:hover .step-icon { transform: scale(1.1) rotate(-5deg); }
    .step-title { font-size: 1.1rem; font-weight: 700; color: #0f172a; margin-bottom: .625rem; }
    .step-desc  { color: #64748b; line-height: 1.7; font-size: .875rem; }

    /* ── ORANGE BLOCK ─────────────────────────── */
    .orange-block {
      background: #f97316;
      padding: 5rem 1.5rem;
      position: relative; overflow: hidden;
    }
    .orange-block::before {
      content: '';
      position: absolute; top: -80px; right: -80px;
      width: 300px; height: 300px;
      background: rgba(255,255,255,.06);
      border-radius: 50%;
    }
    .orange-block::after {
      content: '';
      position: absolute; bottom: -60px; left: -60px;
      width: 200px; height: 200px;
      background: rgba(255,255,255,.04);
      border-radius: 50%;
    }
    .orange-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center;
      position: relative; z-index: 1;
    }
    @media (max-width: 700px) { .orange-inner { grid-template-columns: 1fr; } }
    .orange-block-title {
      font-size: clamp(1.5rem, 3vw, 2.5rem);
      font-weight: 900; color: #fff; letter-spacing: -.03em;
      line-height: 1.2; margin-bottom: .75rem;
    }
    .orange-block-sub { color: rgba(255,255,255,.75); font-size: 1rem; line-height: 1.65; }

    /* ── SERVICES – OOK KUNNEN WIJ ────────────── */
    .services-bg { background: #f8fafc; }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem; margin-top: 3rem;
    }
    @media (max-width: 640px) { .services-grid { grid-template-columns: 1fr; } }

    .service-card {
      background: #fff;
      border: 1.5px solid #f1f5f9;
      border-radius: 1.25rem; padding: 2rem;
      transition: border-color .3s, box-shadow .3s;
      transform-style: preserve-3d;
      will-change: transform;
      position: relative; overflow: hidden;
    }
    .service-card::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(249,115,22,.05) 0%, transparent 60%);
      opacity: 0;
      transition: opacity .3s;
    }
    .service-card:hover::after { opacity: 1; }
    .service-card:hover {
      border-color: #fed7aa;
      box-shadow: 0 12px 40px rgba(249,115,22,.1);
    }
    .service-emoji {
      font-size: 2.25rem; margin-bottom: 1.25rem;
      display: block;
      animation: iconBounce 3s ease-in-out infinite;
    }
    .service-card:nth-child(2) .service-emoji { animation-delay: .5s; }
    .service-card:nth-child(3) .service-emoji { animation-delay: 1s; }
    .service-card:nth-child(4) .service-emoji { animation-delay: 1.5s; }
    .service-title {
      font-size: 1.05rem; font-weight: 800; color: #0f172a; margin-bottom: .5rem;
    }
    .service-desc { color: #64748b; font-size: .875rem; line-height: 1.7; }

    /* ── DARK BLOCK ───────────────────────────── */
    .dark-block { background: #0f172a; padding: 7rem 1.5rem; position: relative; overflow: hidden; }
    .dark-block::before {
      content: '';
      position: absolute; top: -200px; right: -200px;
      width: 500px; height: 500px;
