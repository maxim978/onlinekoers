      box-shadow: 0 4px 20px rgba(249,115,22,.3);
      letter-spacing: -.01em;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(249,115,22,.4); }

    .form-note { text-align: center; font-size: .72rem; color: #cbd5e1; margin-top: .875rem; }

    .error-box {
      background: #fef2f2; border: 1px solid #fecaca;
      border-radius: .5rem; padding: .75rem 1rem;
      color: #dc2626; font-size: .85rem; margin-bottom: 1rem;
    }
    .success-box {
      background: #f0fdf4; border: 1.5px solid #bbf7d0;
      border-radius: 1.25rem; padding: 3rem; text-align: center;
    }
    .success-emoji { font-size: 2.5rem; margin-bottom: 1rem; }
    .success-title { font-size: 1.2rem; font-weight: 800; color: #0f172a; margin-bottom: .5rem; }
    .success-sub   { color: #64748b; }

    /* ── FOOTER ───────────────────────────────── */
    footer {
      background: #0f172a;
      border-top: 1px solid rgba(255,255,255,.06);
      padding: 2.5rem 1.5rem;
    }
    .footer-inner {
      max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap;
    }
