      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1.1fr; gap: 5rem; align-items: start;
    }
    @media (max-width: 860px) { .contact-grid { grid-template-columns: 1fr; gap: 3rem; } }

    .contact-info-sub { color: #64748b; line-height: 1.75; margin-bottom: 2rem; }
