    @media (max-width: 860px) { .dark-inner { grid-template-columns: 1fr; gap: 3rem; } }

    .check-list { list-style: none; margin-top: 2rem; display: flex; flex-direction: column; gap: .875rem; }
    .check-item {
      display: flex; align-items: flex-start; gap: .875rem;
      color: rgba(255,255,255,.6); font-size: .9rem; line-height: 1.6;
    }
    .check-icon {
      flex-shrink: 0; margin-top: 1px;
      width: 20px; height: 20px; border-radius: 50%;
      background: rgba(249,115,22,.15);
      display: flex; align-items: center; justify-content: center;
      transition: background .3s;
    }
    .check-item:hover .check-icon { background: rgba(249,115,22,.3); }

    .branch-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .branch-card {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 1rem; padding: 1.5rem;
      transition: border-color .25s, background .25s, transform .25s;
    }
    .branch-card:hover {
      border-color: rgba(249,115,22,.3);
      background: rgba(249,115,22,.06);
      transform: translateY(-3px);
    }
    .branch-icon { font-size: 1.5rem; margin-bottom: .625rem; }
    .branch-name { font-weight: 700; color: #fff; font-size: .875rem; margin-bottom: .25rem; }
    .branch-desc { color: rgba(255,255,255,.35); font-size: .78rem; line-height: 1.5; }

    /* ── QUOTE ────────────────────────────────── */
    .quote-section {
      padding: 6rem 1.5rem;
      background: #fff;
      text-align: center;
      border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9;
    }
    .quote-mark { font-size: 4rem; line-height: 1; color: #fed7aa; margin-bottom: .5rem; }
    .quote-text {
      font-size: clamp(1.25rem, 2.5vw, 1.875rem);
      font-weight: 800; color: #0f172a; letter-spacing: -.03em;
      max-width: 680px; margin: 0 auto 1rem; line-height: 1.35;
