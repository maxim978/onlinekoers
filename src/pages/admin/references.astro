---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { requireAdmin } from '@/lib/auth';
import { supabaseAdmin } from '@/lib/supabase';

const isAdmin = await requireAdmin(Astro.cookies);
if (!isAdmin) return Astro.redirect('/admin/login');

let error: string | null = null;
let success = false;

// Handle add / delete
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'delete') {
    const id = form.get('id')?.toString();
    if (id) await supabaseAdmin.from('reference_sites').delete().eq('id', id);
    success = true;
  } else {
    const tags = form.get('style_tags')?.toString()
      .split(',').map(t => t.trim().toLowerCase()).filter(Boolean) ?? [];

    const { error: e } = await supabaseAdmin.from('reference_sites').insert({
      name: form.get('name')?.toString() ?? '',
      url: form.get('url')?.toString() ?? '',
      style_tags: tags,
      notes: form.get('notes')?.toString() || null,
    });
    if (e) error = e.message;
    else success = true;
  }
}

// Fetch all references
const { data: refs } = await supabaseAdmin
  .from('reference_sites')
  .select('*')
  .order('created_at', { ascending: false });

// All unique tags for filter
const allTags = [...new Set(refs?.flatMap(r => r.style_tags ?? []) ?? [])].sort();

// Filter by tag
const url = new URL(Astro.request.url);
const activeTag = url.searchParams.get('tag') ?? '';
const filtered = activeTag ? refs?.filter(r => r.style_tags?.includes(activeTag)) : refs;
---

<AdminLayout title="Voorbeeld websites">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-1">Voorbeeld websites</h1>
      <p class="text-gray-500 text-sm">{refs?.length ?? 0} opgeslagen · gebruik als stijl-inspiratie bij nieuwe leads</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Left: add form -->
    <div class="lg:col-span-1">
      <div class="bg-white border border-gray-200 rounded-xl p-5 sticky top-6">
        <h2 class="font-semibold text-gray-900 mb-4">Nieuwe toevoegen</h2>

        {error && <div class="mb-3 px-3 py-2 bg-red-50 text-red-700 text-sm rounded-lg">{error}</div>}
        {success && <div class="mb-3 px-3 py-2 bg-green-50 text-green-700 text-sm rounded-lg">Opgeslagen!</div>}

        <form method="POST" class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Naam *</label>
            <input
              name="name"
              type="text"
              required
              placeholder="Apple, Patagonia, Gimmie..."
              class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black"
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">URL *</label>
            <input
              name="url"
              type="url"
              required
              placeholder="https://..."
              class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black"
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Stijl-tags</label>
            <input
              name="style_tags"
              type="text"
              placeholder="luxe, minimalistisch, groen"
              class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black"
            />
            <p class="text-xs text-gray-400 mt-1">Komma-gescheiden</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Notitie</label>
            <textarea
              name="notes"
              rows="2"
              placeholder="Wat maakt deze site goed?"
              class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-black text-white rounded-lg py-2 text-sm font-semibold hover:bg-gray-800 transition-colors"
          >
            Toevoegen
          </button>
        </form>
      </div>
    </div>

    <!-- Right: reference cards -->
    <div class="lg:col-span-2">

      <!-- Tag filters -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          <a
            href="/admin/references"
            class={`px-3 py-1 rounded-full text-xs font-medium transition-colors ${!activeTag ? 'bg-black text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
          >
            Alles
          </a>
          {allTags.map(tag => (
            <a
              href={`/admin/references?tag=${tag}`}
              class={`px-3 py-1 rounded-full text-xs font-medium transition-colors ${activeTag === tag ? 'bg-black text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <!-- Grid -->
      {!filtered || filtered.length === 0 ? (
        <div class="bg-white border border-gray-200 rounded-xl p-12 text-center text-gray-400">
          Nog geen voorbeelden opgeslagen.
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {filtered.map(ref => {
            const domain = (() => { try { return new URL(ref.url).hostname.replace('www.', ''); } catch { return ref.url; } })();
            const faviconUrl = `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
            const screenshotUrl = `https://api.microlink.io/?url=${encodeURIComponent(ref.url)}&screenshot=true&meta=false&embed=screenshot.url`;

            return (
              <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-md transition-shadow group">
                <!-- Screenshot preview -->
                <a href={ref.url} target="_blank" rel="noopener" class="block">
                  <div class="relative h-36 bg-gray-100 overflow-hidden">
                    <img
                      src={screenshotUrl}
                      alt={ref.name}
                      class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                    />
                    <!-- Fallback als screenshot niet laadt -->
                    <div class="absolute inset-0 hidden items-center justify-center bg-gradient-to-br from-gray-50 to-gray-200">
                      <span class="text-gray-400 text-sm font-mono">{domain}</span>
                    </div>
                    <!-- Hover overlay -->
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center">
                      <span class="opacity-0 group-hover:opacity-100 transition-opacity bg-white text-black text-xs font-semibold px-3 py-1.5 rounded-full shadow">
                        Openen ↗
                      </span>
                    </div>
                  </div>
                </a>

                <div class="p-4">
                  <div class="flex items-start justify-between gap-2 mb-2">
                    <div class="flex items-center gap-2 min-w-0">
                      <img src={faviconUrl} alt="" class="w-4 h-4 flex-shrink-0" />
                      <span class="font-semibold text-gray-900 text-sm truncate">{ref.name}</span>
                    </div>
                    <!-- Delete -->
                    <form method="POST">
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={ref.id} />
                      <button
                        type="submit"
                        class="text-gray-300 hover:text-red-400 transition-colors text-lg leading-none flex-shrink-0"
                        title="Verwijderen"
                        onclick="return confirm('Verwijderen?')"
                      >
                        ×
                      </button>
                    </form>
                  </div>

                  <p class="text-xs text-gray-400 mb-2 truncate">{domain}</p>

                  {ref.notes && (
                    <p class="text-xs text-gray-600 mb-3 leading-relaxed">{ref.notes}</p>
                  )}

                  {ref.style_tags?.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {ref.style_tags.map((tag: string) => (
                        <a
                          href={`/admin/references?tag=${tag}`}
                          class="px-2 py-0.5 bg-gray-100 text-gray-500 rounded text-xs hover:bg-gray-200 transition-colors"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </div>
</AdminLayout>
