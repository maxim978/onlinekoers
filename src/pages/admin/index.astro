---
import { supabase } from '../../lib/supabase';

// Auth check
const authCookie = Astro.cookies.get('admin_auth');
if (authCookie?.value !== 'true') {
  return Astro.redirect('/admin/login');
}

// Handle POST actions
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (form.get('_action') === 'logout') {
    Astro.cookies.delete('admin_auth', { path: '/' });
    return Astro.redirect('/admin/login');
  }
  if (form.get('_action') === 'update_status') {
    await supabase
      .from('leads')
      .update({ status: String(form.get('status')) })
      .eq('id', String(form.get('lead_id')));
  }
}

// Filters
const url = new URL(Astro.request.url);
const filterStatus   = url.searchParams.get('status')   ?? '';
const filterIndustry = url.searchParams.get('industry') ?? '';
const filterDate     = url.searchParams.get('date')     ?? '';

// Fetch leads with optional filters
let q: any = supabase.from('leads').select('*').order('created_at', { ascending: false });
if (filterStatus)   q = q.eq('status', filterStatus);
if (filterIndustry) q = q.eq('industry', filterIndustry);
if (filterDate)     q = q.gte('created_at', filterDate + 'T00:00:00Z');
const { data: leadsData } = await q;
const allLeads: any[] = leadsData ?? [];

// Analytics per lead
const { data: analyticsRaw } = await supabase
  .from('analytics')
  .select('lead_id, duration_seconds');

const analyticsMap: any = {};
for (const row of analyticsRaw ?? []) {
  if (!analyticsMap[row.lead_id]) {
    analyticsMap[row.lead_id] = { views: 0, totalDuration: 0 };
  }
  analyticsMap[row.lead_id].views += 1;
  analyticsMap[row.lead_id].totalDuration += (row.duration_seconds ?? 0);
}

// Stats
const totalLeads   = allLeads.length;
const liveLeads    = allLeads.filter((l) => l.status === 'Live').length;
const bezekenLeads = allLeads.filter((l) => l.status === 'Bekeken').length;
const totalViews   = (Object.values(analyticsMap) as any[]).reduce((s, a) => s + a.views, 0);

function formatDuration(sec: number) {
  if (sec < 60) return sec + 's';
  return Math.floor(sec / 60) + 'm ' + (sec % 60) + 's';
}

const statusBadge: Record<string, string> = {
  Concept: 'badge-concept',
  Live:    'badge-live',
  Bekeken: 'badge-bekeken',
};
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Admin Dashboard | OnlineKoers</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; background: #0f172a; color: #f8fafc; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }

      .sidebar {
        position: fixed; top: 0; left: 0; bottom: 0; width: 240px;
        background: #1e293b; border-right: 1px solid #334155;
        display: flex; flex-direction: column; padding: 1.5rem; z-index: 40;
      }
      .main { margin-left: 240px; min-height: 100vh; padding: 2rem 2.5rem; }
      .logo { font-size: 1.25rem; font-weight: 900; margin-bottom: 2rem; color: #f8fafc; }
      .logo span { color: #f97316; }

      .nav-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.625rem 0.875rem; border-radius: 0.5rem;
        font-size: 0.875rem; font-weight: 500; color: #94a3b8;
        transition: background 0.15s, color 0.15s; margin-bottom: 0.25rem;
      }
      .nav-item:hover, .nav-item.active { background: rgba(249,115,22,0.1); color: #f97316; }

      .stat-card { background: #1e293b; border: 1px solid #334155; border-radius: 1rem; padding: 1.5rem; }
      .stat-value { font-size: 2rem; font-weight: 800; color: #f8fafc; }
      .stat-label { font-size: 0.8rem; color: #64748b; margin-top: 0.25rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }

      .badge { display: inline-flex; align-items: center; padding: 0.25rem 0.625rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
      .badge-concept { background: rgba(100,116,139,0.2); color: #94a3b8; }
      .badge-live    { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
      .badge-bekeken { background: rgba(96,165,250,0.15); color: #93c5fd; border: 1px solid rgba(96,165,250,0.3); }

      .table-container { background: #1e293b; border: 1px solid #334155; border-radius: 1rem; overflow: hidden; }
      table { width: 100%; border-collapse: collapse; }
      th {
        padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.05em; color: #64748b;
        background: #0f172a; border-bottom: 1px solid #334155;
      }
      td { padding: 1rem 1.25rem; font-size: 0.875rem; border-bottom: 1px solid #1e293b; color: #cbd5e1; vertical-align: middle; }
      tr:last-child td { border-bottom: none; }
      tr:hover td { background: rgba(255,255,255,0.02); }

      select, input[type="date"] {
        background: #0f172a; border: 1px solid #475569; border-radius: 0.5rem;
        padding: 0.5rem 0.875rem; color: #f8fafc; font-size: 0.875rem;
        font-family: 'Inter', sans-serif; outline: none; transition: border-color 0.15s;
      }
      select:focus, input:focus { border-color: #f97316; }

      .btn {
        background: #f97316; color: #fff; font-weight: 600; font-size: 0.875rem;
        padding: 0.5rem 1.25rem; border: none; border-radius: 0.5rem; cursor: pointer;
        transition: opacity 0.15s; font-family: 'Inter', sans-serif;
      }
      .btn:hover { opacity: 0.9; }
      .btn-ghost {
        background: transparent; color: #94a3b8; border: 1px solid #475569;
        font-weight: 500; font-size: 0.875rem; padding: 0.5rem 1.25rem;
        border-radius: 0.5rem; cursor: pointer; transition: color 0.15s, border-color 0.15s;
        font-family: 'Inter', sans-serif;
      }
      .btn-ghost:hover { color: #f8fafc; border-color: #64748b; }

      @media (max-width: 1024px) {
        .sidebar { display: none; }
        .main { margin-left: 0; padding: 1.5rem; }
      }
    </style>
  </head>
  <body>

    <aside class="sidebar">
      <div class="logo"><span>Online</span>Koers</div>
      <nav style="flex:1">
        <a href="/admin" class="nav-item active">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"/>
          </svg>
          Dashboard
        </a>
        <a href="/" class="nav-item" target="_blank">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Website
        </a>
      </nav>
      <form method="POST" style="margin-top:auto">
        <input type="hidden" name="_action" value="logout" />
        <button type="submit" class="btn-ghost" style="width:100%">Uitloggen</button>
      </form>
    </aside>

    <main class="main">

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem">
        <div>
          <h1 style="font-size:1.75rem;font-weight:800;color:#f8fafc">Dashboard</h1>
          <p style="color:#64748b;font-size:0.875rem;margin-top:0.25rem">
            {new Date().toLocaleDateString('nl-NL', { weekday:'long', year:'numeric', month:'long', day:'numeric' })}
          </p>
        </div>
        <a href="/" target="_blank" class="btn" style="text-decoration:none">+ Nieuwe lead</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:2rem">
        <div class="stat-card">
          <div class="stat-value">{totalLeads}</div>
          <div class="stat-label">Totaal leads</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#22c55e">{liveLeads}</div>
          <div class="stat-label">Live previews</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#60a5fa">{bezekenLeads}</div>
          <div class="stat-label">Bekeken</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#f97316">{totalViews}</div>
          <div class="stat-label">Totaal views</div>
        </div>
      </div>

      <form method="GET" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:flex-end;margin-bottom:1.5rem">
        <div>
          <label style="display:block;font-size:0.75rem;font-weight:600;color:#64748b;margin-bottom:0.375rem;text-transform:uppercase;letter-spacing:0.05em">Status</label>
          <select name="status">
            <option value=""        selected={filterStatus === ''}>Alle</option>
            <option value="Concept" selected={filterStatus === 'Concept'}>Concept</option>
            <option value="Live"    selected={filterStatus === 'Live'}>Live</option>
            <option value="Bekeken" selected={filterStatus === 'Bekeken'}>Bekeken</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:0.75rem;font-weight:600;color:#64748b;margin-bottom:0.375rem;text-transform:uppercase;letter-spacing:0.05em">Branche</label>
          <select name="industry">
            <option value=""          selected={filterIndustry === ''}>Alle</option>
            <option value="bouw"      selected={filterIndustry === 'bouw'}>Bouw</option>
            <option value="interieur" selected={filterIndustry === 'interieur'}>Interieur</option>
            <option value="techniek"  selected={filterIndustry === 'techniek'}>Techniek</option>
            <option value="vastgoed"  selected={filterIndustry === 'vastgoed'}>Vastgoed</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:0.75rem;font-weight:600;color:#64748b;margin-bottom:0.375rem;text-transform:uppercase;letter-spacing:0.05em">Vanaf datum</label>
          <input type="date" name="date" value={filterDate} />
        </div>
        <button type="submit" class="btn">Filteren</button>
        {(filterStatus || filterIndustry || filterDate) && (
          <a href="/admin" class="btn-ghost">Reset</a>
        )}
      </form>

      <div class="table-container">
        <div style="padding:1.25rem 1.5rem;border-bottom:1px solid #334155">
          <h2 style="font-size:1rem;font-weight:700;color:#f8fafc">
            Leads <span style="font-size:0.8rem;font-weight:500;color:#64748b;margin-left:0.5rem">({allLeads.length})</span>
          </h2>
        </div>

        {allLeads.length === 0 ? (
          <div style="padding:3rem;text-align:center;color:#475569">
            <p>Geen leads gevonden voor de geselecteerde filters.</p>
          </div>
        ) : (
          <div style="overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>Bedrijf</th>
                  <th>Branche</th>
                  <th>Status</th>
                  <th>Views</th>
                  <th>Gem. kijktijd</th>
                  <th>Aangemaakt</th>
                  <th>Preview</th>
                  <th>Actie</th>
                </tr>
              </thead>
              <tbody>
                {allLeads.map((lead) => {
                  const stats = analyticsMap[lead.id] ?? { views: 0, totalDuration: 0 };
                  const avg   = stats.views > 0 ? Math.round(stats.totalDuration / stats.views) : 0;
                  const badge = statusBadge[lead.status] ?? 'badge-concept';
                  return (
                    <tr>
                      <td>
                        <div style="display:flex;align-items:center;gap:0.75rem">
                          <div style={`width:32px;height:32px;border-radius:8px;background:${lead.primary_color ?? '#475569'};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.875rem;color:#fff;flex-shrink:0`}>
                            {lead.company_name.charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <div style="font-weight:600;color:#f8fafc;font-size:0.875rem">{lead.company_name}</div>
                            <div style="font-size:0.75rem;color:#64748b">{lead.slug}</div>
                          </div>
                        </div>
                      </td>
                      <td>
                        {lead.industry
                          ? <span style="font-size:0.8rem;color:#94a3b8;text-transform:capitalize">{lead.industry}</span>
                          : <span style="color:#475569">-</span>
                        }
                      </td>
                      <td><span class={`badge ${badge}`}>{lead.status}</span></td>
                      <td><span style="font-weight:600;color:#f8fafc">{stats.views}</span></td>
                      <td>
                        <span style={`color:${avg > 60 ? '#22c55e' : avg > 0 ? '#fbbf24' : '#475569'}`}>
                          {avg > 0 ? formatDuration(avg) : '-'}
                        </span>
                      </td>
                      <td>
                        <span style="font-size:0.8rem;color:#64748b">
                          {new Date(lead.created_at).toLocaleDateString('nl-NL', { day:'2-digit', month:'2-digit', year:'2-digit' })}
                        </span>
                      </td>
                      <td>
                        {lead.status !== 'Concept' ? (
                          <a href={`/preview/${lead.slug}`} target="_blank"
                             style="color:#f97316;font-size:0.8rem;font-weight:500;display:inline-flex;align-items:center;gap:0.25rem">
                            Bekijk
                            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                          </a>
                        ) : (
                          <span style="color:#475569;font-size:0.8rem">Concept</span>
                        )}
                      </td>
                      <td>
                        <form method="POST" style="display:inline">
                          <input type="hidden" name="_action" value="update_status" />
                          <input type="hidden" name="lead_id" value={lead.id} />
                          <select name="status" onchange="this.form.submit()"
                                  style="background:#0f172a;border:1px solid #475569;border-radius:0.375rem;padding:0.25rem 0.5rem;color:#f8fafc;font-size:0.8rem;font-family:'Inter',sans-serif;cursor:pointer">
                            <option value="Concept" selected={lead.status === 'Concept'}>Concept</option>
                            <option value="Live"    selected={lead.status === 'Live'}>Live</option>
                            <option value="Bekeken" selected={lead.status === 'Bekeken'}>Bekeken</option>
                          </select>
                        </form>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <div style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid #1e293b;text-align:center;color:#475569;font-size:0.8rem">
        OnlineKoers Admin {new Date().getFullYear()}
      </div>
    </main>
  </body>
</html>
