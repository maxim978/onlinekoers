---
import LayoutBarten from '../../../layouts/LayoutBarten.astro';
---

<LayoutBarten title="Winkelwagen" activePage="winkelwagen">
  <section style="padding: 12rem 0 6rem; background: var(--primary); color: white;">
    <div class="container">
      <div style="max-width: 800px;">
        <span class="reveal" style="display: inline-block; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 1.5rem; color: var(--accent);">Uw Selectie</span>
        <h1 class="reveal" style="font-size: clamp(3rem, 6vw, 5rem); line-height: 1; margin-bottom: 2rem;">Winkelwagen</h1>
        <p class="reveal" style="font-size: 1.1rem; opacity: 0.7; max-width: 500px; line-height: 1.6;">Controleer uw bestelling en vul uw gegevens in om de bestelling af te ronden.</p>
      </div>
    </div>
  </section>

  <section style="padding: 6rem 0; background: var(--secondary);">
    <div class="container">
      <div id="cart-content" style="display: grid; grid-template-columns: 1fr 400px; gap: 4rem; align-items: start;">
        
        <!-- LEFT: Cart Items -->
        <div class="reveal">
          <div id="cart-list" style="background: white; border-radius: 2rem; padding: 3rem; box-shadow: 0 20px 60px rgba(0,0,0,0.05);">
            <!-- Items injected here -->
            <div id="empty-cart" style="text-align: center; padding: 4rem 0; display: none;">
              <div style="font-size: 4rem; margin-bottom: 2rem;">🧺</div>
              <h2 style="margin-bottom: 1rem;">Uw winkelwagen is leeg</h2>
              <p style="opacity: 0.5; margin-bottom: 2.5rem;">Voeg producten toe op onze bestelpagina.</p>
              <a href="/preview/vleesboerderij-barten/bestellen" class="btn-premium">Direct Bestellen</a>
            </div>
            
            <div id="items-container"></div>
          </div>
        </div>

        <!-- RIGHT: Checkout Form -->
        <div class="reveal" id="checkout-panel">
          <div style="background: white; border-radius: 2rem; padding: 3rem; box-shadow: 0 20px 60px rgba(0,0,0,0.05); position: sticky; top: 120px;">
            <h3 class="serif" style="font-size: 1.8rem; margin-bottom: 2rem;">Afronden</h3>
            
            <div id="cart-summary" style="margin-bottom: 2rem;">
              <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 0.9rem; opacity: 0.6;">
                <span>Subtotaal</span>
                <span id="subtotal">€0,00</span>
              </div>
              <div style="display: flex; justify-content: space-between; padding-top: 1.5rem; border-top: 1px solid #f0ede8; font-weight: 800; font-size: 1.4rem;">
                <span>Totaal</span>
                <span id="total-amount">€0,00</span>
              </div>
            </div>

            <form id="cart-final-form">
              <div style="display: grid; gap: 1.5rem;">
                <div style="display: grid; gap: 0.5rem;">
                  <label style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(27,42,30,0.4);">Uw Naam</label>
                  <input type="text" name="name" required style="width: 100%; padding: 1rem 1.25rem; border-radius: 1rem; border: 1px solid rgba(27,42,30,0.1); outline: none;" />
                </div>
                <div style="display: grid; gap: 0.5rem;">
                  <label style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(27,42,30,0.4);">E-mailadres</label>
                  <input type="email" name="email" required style="width: 100%; padding: 1rem 1.25rem; border-radius: 1rem; border: 1px solid rgba(27,42,30,0.1); outline: none;" />
                </div>
                <div style="display: grid; gap: 0.5rem;">
                  <label style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(27,42,30,0.4);">Telefoonnummer</label>
                  <input type="tel" name="phone" required style="width: 100%; padding: 1rem 1.25rem; border-radius: 1rem; border: 1px solid rgba(27,42,30,0.1); outline: none;" />
                </div>
                <div style="display: grid; gap: 0.5rem;">
                  <label style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(27,42,30,0.4);">Gewenste afhaaldatum</label>
                  <select name="pickup_date" required style="width: 100%; padding: 1rem 1.25rem; border-radius: 1rem; border: 1px solid rgba(27,42,30,0.1); outline: none; background: white;">
                    <option value="">Kies een datum...</option>
                    <option>Vrijdag (eerstvolgende)</option>
                    <option>Zaterdag (eerstvolgende)</option>
                    <option>Vrijdag (week erna)</option>
                    <option>Zaterdag (week erna)</option>
                  </select>
                </div>
                <div style="display: grid; gap: 0.5rem;">
                  <label style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(27,42,30,0.4);">Opmerkingen (optioneel)</label>
                  <textarea name="comments" placeholder="Bijv. specifieke snijwensen..." style="width: 100%; padding: 1rem 1.25rem; border-radius: 1rem; border: 1px solid rgba(27,42,30,0.1); outline: none; min-height: 80px; resize: vertical;"></textarea>
                </div>
                <button type="submit" class="btn-premium btn-cta" style="width: 100%; justify-content: center; padding: 1.25rem;">Bestelling Plaatsen</button>
              </div>
            </form>

            <div id="success-msg" style="display: none; text-align: center; padding: 2rem 0;">
              <div style="width: 48px; height: 48px; border-radius: 50%; background: #e8f5e9; color: #388e3c; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">✓</div>
              <h4 style="margin-bottom: 0.5rem;">Bestelling verzonden!</h4>
              <p style="font-size: 0.85rem; opacity: 0.6;">We nemen snel contact met u op.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script is:inline>
    let cart = [];
    
    function loadCart() {
      try {
        cart = JSON.parse(localStorage.getItem('barten_cart') || '[]');
      } catch(e) { cart = []; }
      renderCart();
    }

    function saveCart() {
      localStorage.setItem('barten_cart', JSON.stringify(cart));
      window.dispatchEvent(new CustomEvent('cartUpdated'));
      renderCart();
    }

    function fmt(n) {
      return '€' + n.toFixed(2).replace('.', ',');
    }

    function renderCart() {
      const active = cart.filter(i => i.qty > 0);
      const container = document.getElementById('items-container');
      const empty = document.getElementById('empty-cart');
      const panel = document.getElementById('checkout-panel');
      const list = document.getElementById('cart-list');

      if (active.length === 0) {
        if (container) container.style.display = 'none';
        if (empty) empty.style.display = 'block';
        if (panel) panel.style.display = 'none';
        const content = document.getElementById('cart-content');
        if (content) content.style.gridTemplateColumns = '1fr';
        return;
      }

      if (container) container.style.display = 'block';
      if (empty) empty.style.display = 'none';
      if (panel) panel.style.display = 'block';
      const content = document.getElementById('cart-content');
      if (content) content.style.gridTemplateColumns = '1fr 400px';

      if (container) {
        container.innerHTML = active.map(item => `
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 2rem 0; border-bottom: 1px solid #f0ede8;">
            <div style="display: flex; align-items: center; gap: 2rem;">
              <div style="width: 80px; height: 80px; background: #f4f2ec; border-radius: 1rem; overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 2rem;">🥩</div>
              <div>
                <h4 style="font-size: 1.2rem; margin-bottom: 0.25rem;">${item.name}</h4>
                <p style="font-size: 0.8rem; opacity: 0.4;">Gewicht: ${item.weightLabel} · ${fmt(item.price)}</p>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 2.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem; background: #f4f2ec; padding: 0.5rem; border-radius: 1rem;">
                <button class="qty-btn" onclick="window.updateQty('${item.cartId}', -1)" style="width: 32px; height: 32px; border-radius: 0.75rem; border: none; background: white; cursor: pointer; font-weight: 900;">−</button>
                <span style="font-weight: 800; min-width: 20px; text-align: center;">${item.qty}</span>
                <button class="qty-btn" onclick="window.updateQty('${item.cartId}', 1)" style="width: 32px; height: 32px; border-radius: 0.75rem; border: none; background: white; cursor: pointer; font-weight: 900;">+</button>
              </div>
              <div style="font-weight: 800; font-size: 1.1rem; width: 80px; text-align: right;">${fmt(item.price * item.qty)}</div>
            </div>
          </div>
        `).join('');
      }

      const total = active.reduce((s, i) => s + i.price * i.qty, 0);
      const subtotalEl = document.getElementById('subtotal');
      const totalAmountEl = document.getElementById('total-amount');
      if (subtotalEl) subtotalEl.textContent = fmt(total);
      if (totalAmountEl) totalAmountEl.textContent = fmt(total);
    }

    window.updateQty = (cartId, delta) => {
      const item = cart.find(i => i.cartId === cartId);
      if (item) {
        item.qty = Math.max(0, item.qty + delta);
        saveCart();
      }
    };

    const form = document.getElementById('cart-final-form');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = e.target.querySelector('button');
        btn.textContent = 'Versturen...';
        btn.disabled = true;
        
        await new Promise(r => setTimeout(r, 1000));
        
        e.target.style.display = 'none';
        const summary = document.getElementById('cart-summary');
        const success = document.getElementById('success-msg');
        if (summary) summary.style.opacity = '0.5';
        if (success) success.style.display = 'block';
        
        cart = [];
        localStorage.setItem('barten_cart', JSON.stringify(cart));
        window.dispatchEvent(new CustomEvent('cartUpdated'));
      });
    }

    loadCart();
  </script>
</LayoutBarten>
