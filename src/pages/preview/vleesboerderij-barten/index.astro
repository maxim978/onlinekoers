---
import LayoutBarten from '../../../layouts/LayoutBarten.astro';
---

<LayoutBarten title="Home" activePage="home">
  <!-- HERO -->
  <section class="hero-section" style="height: 100vh; position: relative; display: flex; align-items: center; overflow: hidden;">
    <div style="position: absolute; inset: 0; background: url('/images/barten/hero.png') center/cover no-repeat; filter: brightness(0.6);"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <div style="max-width: 800px;">
        <span class="reveal" style="display: inline-block; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 1.5rem; color: var(--accent);">Ambachtelijk & Eerlijk</span>
        <h1 class="reveal" style="font-size: clamp(3.5rem, 8vw, 6.5rem); line-height: 0.95; margin-bottom: 2rem;">Vakmanschap <br/><span style="color: var(--accent); font-style: italic; font-weight: 400;">op uw bord.</span></h1>
        <p class="reveal" style="font-size: 1.25rem; opacity: 0.8; margin-bottom: 3rem; max-width: 500px; line-height: 1.6;">Direct van onze boerderij in Meerkerk naar uw keuken. Puur vlees van runderen die de ruimte krijgen.</p>
        <div class="reveal" style="display: flex; gap: 1.5rem;">
          <a href="/preview/vleesboerderij-barten/bestellen" class="btn-premium">Direct Bestellen</a>
          <a href="/preview/vleesboerderij-barten/assortiment" class="btn-premium" style="background: transparent; border: 1px solid rgba(255,255,255,0.3);">Bekijk Assortiment</a>
        </div>
      </div>
    </div>
    
    <div style="position: absolute; bottom: 3rem; left: 50%; transform: translateX(-50%); text-align: center; opacity: 0.5;">
      <span style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.2em; display: block; margin-bottom: 0.5rem;">Scroll</span>
      <div style="width: 1px; height: 50px; background: white; margin: 0 auto;"></div>
    </div>
  </section>

  <!-- USP STRIP -->
  <section style="background: var(--accent); padding: 0;">
    <div class="container" style="display: flex; align-items: center; gap: 2.5rem; padding-top: 1rem; padding-bottom: 1rem; flex-wrap: wrap; justify-content: center;">
      {[
        ['✓', 'Direct van de boer'],
        ['✓', 'Minimaal 3 weken gerijpt'],
        ['✓', 'Kampioenswinnaar'],
        ['✓', 'Afhalen in Meerkerk'],
      ].map(([icon, txt]) => (
        <div style="display:flex;align-items:center;gap:.5rem;font-size:.78rem;font-weight:700;color:rgba(27,42,30,.85);">
          <span style="width:20px;height:20px;background:rgba(27,42,30,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.65rem;">{icon}</span>
          {txt}
        </div>
      ))}
    </div>
  </section>

  <!-- USPs -->
  <section style="padding: 8rem 0; background: white;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem;">
        {[
          { num:'01', icon:'🌿', title:'Eigen Keten', desc:'Van het kalfje dat bij ons wordt geboren tot het stukje vlees op uw bord. Wij beheren het volledige proces.' },
          { num:'02', icon:'🌾', title:'Vrije Uitloop', desc:'Onze runderen grazen het grootste deel van het jaar in de weidse polders van de Alblasserwaard.' },
          { num:'03', icon:'⏱️', title:'3 Weken Rijping', desc:'Voor optimale smaak en malsheid laten wij ons rundvlees minimaal drie weken ambachtelijk rijpen.' },
        ].map((u, i) => (
          <div class="reveal" style={`transition-delay:${i*0.15}s`}>
            <div style="width:56px;height:56px;border-radius:1rem;background:#f4f2ec;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1.5rem;">{u.icon}</div>
            <div style="font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.2em;color:var(--accent);margin-bottom:.6rem;">{u.num}</div>
            <h3 style="font-size:1.5rem;margin-bottom:.75rem;">{u.title}</h3>
            <p style="color:var(--text-dark);opacity:.6;line-height:1.75;font-size:.95rem;">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED STORY -->
  <section style="padding-bottom: 10rem;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8rem; align-items: center;">
        <div class="reveal">
          <div style="position: relative;">
            <img src="/images/barten/farm.png" alt="Boerderij" style="width: 100%; border-radius: 2rem; box-shadow: 0 40px 100px rgba(0,0,0,0.1);" />
            <div style="position: absolute; -bottom: 3rem; -right: 3rem; background: var(--primary); color: white; padding: 3rem; border-radius: 2rem; max-width: 300px;">
              <h4 class="serif" style="font-size: 1.5rem; margin-bottom: 1rem;">Sinds generaties</h4>
              <p style="font-size: 0.9rem; opacity: 0.7; line-height: 1.6;">Al jarenlang een begrip in Meerkerk voor kwaliteitsvlees van eigen bodem.</p>
            </div>
          </div>
        </div>
        <div class="reveal">
          <span class="section-tag" style="display: block; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent); margin-bottom: 1.5rem;">Onze Filosofie</span>
          <h2 style="font-size: clamp(2.5rem, 4vw, 4rem); line-height: 1.1; margin-bottom: 2rem;">Liefde voor het <span style="color: var(--accent);">dier</span> en het vak.</h2>
          <p style="font-size: 1.1rem; line-height: 1.8; opacity: 0.6; margin-bottom: 2.5rem;">
            Bij Vleesboerderij Barten geloven we dat een goed stuk vlees begint bij een goed leven. Onze "Verbeterd Roodbont" runderen krijgen de rust en ruimte die ze verdienen. 
            Dit vertaalt zich direct in de kwaliteit en smaak die u bij ons in de winkel vindt.
          </p>
          <a href="/preview/vleesboerderij-barten/over-ons" class="btn-premium">Ontdek ons verhaal</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORY GRID -->
  <section style="padding: 10rem 0; background: var(--primary); color: white;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 6rem;">
        <h2 style="font-size: 3.5rem; margin-bottom: 1rem;">Ons Assortiment</h2>
        <p style="opacity: 0.6; max-width: 600px; margin: 0 auto;">Ontdek onze ambachtelijke producten, van malse biefstuk tot complete BBQ-pakketten.</p>
      </div>
      
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem;">
        {[
          { emoji:'🥩', title:'Rundvlees',     sub:'Mals & gerijpt',           delay:'0s'    },
          { emoji:'🥓', title:'Varkensvlees',  sub:'Smaakvol & puur',          delay:'.1s'   },
          { emoji:'🍗', title:'Kip & Kalkoen', sub:'Vers & eerlijk',            delay:'.2s'   },
          { emoji:'🔥', title:'BBQ Specials',  sub:'Ambachtelijk gemarineerd',  delay:'.3s'   },
        ].map(c => (
          <a href="/preview/vleesboerderij-barten/bestellen"
             class="reveal"
             style={`transition-delay:${c.delay};display:flex;flex-direction:column;align-items:center;text-align:center;padding:2.5rem 1.5rem;border-radius:1.75rem;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);text-decoration:none;color:white;transition:background .3s,transform .3s;`}
             onmouseover="this.style.background='rgba(255,255,255,.13)';this.style.transform='translateY(-4px)'"
             onmouseout="this.style.background='rgba(255,255,255,.07)';this.style.transform=''">
            <div style="width:64px;height:64px;border-radius:1.25rem;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:1.75rem;margin-bottom:1.25rem;">{c.emoji}</div>
            <h4 style="font-size:1.15rem;margin-bottom:.4rem;">{c.title}</h4>
            <p style="font-size:.75rem;opacity:.45;">{c.sub}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</LayoutBarten>
