---
import Tracker from '../../components/Tracker.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'nick-van-der-heijden')
  .maybeSingle();
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nick van der Heijden | Artiest</title>
  <meta name="description" content="Nick van der Heijden — artiest en singer-songwriter. Eigentijdse muziek. Luister op Spotify." />
  <meta name="robots" content="noindex" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: hidden; }

    :root {
      --bg:       #FAFAFA;
      --s1:       #FFFFFF;
      --s2:       #F3F4F6;
      --text:     #111827;
      --white:    #FFFFFF;
      --muted:    #6B7280;
      --faint:    rgba(197, 160, 89, 0.05);
      --accent:   #C5A059;
      --accent-l: #D4B376;
      --glow:     rgba(197, 160, 89, 0.2);
      --green:    #1DB954;
      --green-d:  #158a40;
      --border:   #E5E7EB;
      --hero-bg:  #000000;
      --radius:   2rem;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }

    /* ══ REVEAL (Disabled) ══ */
    .r { opacity: 1 !important; transform: none !important; transition: none !important; }
    .r.on { opacity: 1 !important; transform: none !important; transition: none !important; }
    .d1 { transition-delay: .1s; } .d2 { transition-delay: .22s; }
    .d3 { transition-delay: .34s; } .d4 { transition-delay: .46s; }

    /* ══ KEYFRAMES ══ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(32px); }
      to   { opacity: 1; transform: none; }
    }
    @keyframes pulse  { 0%,100% { opacity:.25; } 50% { opacity:.75; } }
    @keyframes orb    { 0%,100% { transform: translate(0,0) scale(1); } 40% { transform: translate(24px,-18px) scale(1.05); } 70% { transform: translate(-14px,22px) scale(.97); } }
    @keyframes marq   { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @keyframes wave   { 0%,100% { scaleY: 1; } 50% { scaleY: 0.3; } }
    @keyframes barPulse {
      0%,100% { transform: scaleY(0.3); }
      50%     { transform: scaleY(1); }
    }

    /* ══ NAV ══ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1rem 0;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      transition: box-shadow .3s;
    }
    .nav.s {
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .nav-row { display: flex; align-items: center; justify-content: space-between; }
    .nav-logo {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.15rem;
      color: var(--text); text-decoration: none; letter-spacing: .01em;
    }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; align-items: center; gap: 2.25rem; }
    .nav-link {
      font-size: .78rem; font-weight: 500; letter-spacing: .04em;
      color: var(--muted); text-decoration: none; transition: color .2s;
    }
    .nav-link:hover { color: var(--white); }
    .nav-cta {
      font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      color: #fff; background: var(--accent);
      padding: .85rem 1.8rem; border-radius: 3rem;
      text-decoration: none; transition: all .3s;
      box-shadow: 0 4px 12px var(--glow);
    }
    .nav-cta:hover { background: var(--accent-l); transform: translateY(-2px); box-shadow: 0 8px 20px var(--glow); }

    /* mobile nav */
    .nav-toggle {
      display: none; background: none; border: 1px solid var(--border);
      color: var(--white); cursor: pointer;
      width: 40px; height: 40px; border-radius: 4px;
      align-items: center; justify-content: center;
      transition: border-color .2s;
    }
    .nav-toggle:hover { border-color: var(--accent-l); }
    .nav-overlay {
      position: fixed; inset: 0; background: var(--bg); z-index: 200;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 2.5rem;
      transform: translateX(100%);
      transition: transform .5s cubic-bezier(.22,1,.36,1);
    }
    .nav-overlay.on { transform: translateX(0); }
    .nav-overlay .nav-link {
      font-size: 1.5rem; font-family: 'Syne', sans-serif; font-weight: 600; color: var(--muted);
    }
    .nav-overlay .nav-link:hover { color: var(--accent); }
    .nav-overlay-close {
      position: absolute; top: 1.25rem; right: 1.25rem;
      background: none; border: 1px solid var(--border); color: var(--white);
      cursor: pointer; width: 44px; height: 44px; border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      transition: all .2s;
    }
    .nav-overlay-close:hover { background: var(--white); color: var(--bg); border-color: var(--white); }

    /* ══ HERO ══ */
    .hero {
      min-height: 100vh; min-height: 100svh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: left; position: relative; overflow: hidden;
      padding: 6rem clamp(1.5rem, 5vw, 4rem);
      background: #000;
      color: #fff;
    }

    .hero-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: 80% 15%;
      z-index: 1;
    }
    .hero::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(90deg, rgba(0,0,0,1) 0%, rgba(0,0,0,0.85) 30%, transparent 80%);
      z-index: 2;
    }
    .hero-bg-text {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(10rem, 35vw, 40rem);
      color: rgba(255, 255, 255, 0.03);
      white-space: nowrap; z-index: 1; pointer-events: none;
      letter-spacing: -.05em;
    }

    /* Background glow orbs */
    .orb {
      position: absolute; border-radius: 50%; pointer-events: none;
      animation: orb 14s ease-in-out infinite;
    }
    .orb-1 {
      width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(124,92,244,.18) 0%, transparent 68%);
      top: -180px; left: 50%; transform: translateX(-50%);
      animation-delay: 0s;
    }
    .orb-2 {
      width: 420px; height: 420px;
      background: radial-gradient(circle, rgba(167,139,250,.1) 0%, transparent 70%);
      bottom: 20px; left: -80px;
      animation-delay: -5s;
    }
    .orb-3 {
      width: 360px; height: 360px;
      background: radial-gradient(circle, rgba(124,92,244,.1) 0%, transparent 70%);
      bottom: 60px; right: -60px;
      animation-delay: -9s;
    }

    /* Grain texture overlay */
    .hero-grain {
      position: absolute; inset: 0; pointer-events: none; opacity: .048; z-index: 1;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    .hero-content { position: relative; z-index: 10; transition: none !important; }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: .65rem;
      font-size: .63rem; font-weight: 600; letter-spacing: .3em; text-transform: uppercase;
      color: var(--accent-l); margin-bottom: 2.25rem;
      transition: none !important;
    }
    .eyebrow-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--accent-l);
      animation: pulse 2.2s ease-in-out infinite;
      flex-shrink: 0;
    }

    .hero-name {
      font-family: 'Syne', sans-serif; font-weight: 800;
      line-height: .85; letter-spacing: -.04em; margin-bottom: 2rem;
      text-shadow: 0 4px 30px rgba(0,0,0,0.5);
    }
    .hero-name-1 {
      display: block;
      font-size: clamp(4rem, 15vw, 12rem);
      color: #FFFFFF;
    }
    .hero-name-2 {
      display: block;
      font-size: clamp(1rem, 3.5vw, 3rem);
      font-weight: 400; letter-spacing: .4em; text-transform: uppercase;
      color: #FFFFFF; margin-top: 1rem;
    }

    /* Animated waveform bars */
    .hero-wave {
      display: flex; align-items: center; justify-content: center; gap: 3px;
      height: 32px; margin: 0 auto 1.75rem;
    }
    .hero-wave-bar {
      width: 3px; border-radius: 2px; background: var(--accent);
      transform-origin: bottom;
      animation: barPulse ease-in-out infinite;
    }

    .hero-sub {
      font-size: .98rem; color: #fff; line-height: 1.75; max-width: 420px;
      margin: 0 auto 2.75rem;
    }

    .hero-btns {
      display: flex; gap: .85rem; justify-content: center; flex-wrap: wrap;
    }

    /* ══ BUTTONS ══ */
    .btn {
      display: inline-flex; align-items: center; gap: .55rem;
      font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      padding: 1.1rem 2.5rem; border-radius: 4rem;
      text-decoration: none; border: none; cursor: pointer;
      transition: all .4s cubic-bezier(.22,1,.36,1);
    }
    .btn-spotify {
      background: var(--green); color: #fff;
    }
    .btn-spotify:hover { background: #1ed760; transform: translateY(-4px); box-shadow: 0 12px 30px rgba(29,185,84,0.3); }
    .btn-ghost {
      border: 1px solid rgba(255,255,255,0.3); color: #fff; background: transparent;
    }
    .btn-ghost:hover { border-color: #fff; background: #fff; color: var(--text); }
    .btn-accent {
      background: var(--accent); color: #fff;
    }
    .btn-accent:hover { background: var(--accent-l); transform: translateY(-4px); box-shadow: 0 12px 30px var(--glow); }

    /* ══ VIDEOS ══ */
    .video-sec { background: var(--s1); padding: 10rem 0; border-top: 1px solid var(--border); }
    .video-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; margin-top: 5rem; }
    .video-card {
      aspect-ratio: 16/9; border-radius: var(--radius); overflow: hidden;
      background: var(--text); border: 4px solid var(--white);
      transition: all .6s cubic-bezier(.22,1,.36,1);
      position: relative;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .video-card::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.4) 100%);
      pointer-events: none; z-index: 1;
    }
    .video-card:hover { transform: translateY(-12px) rotate(1deg); box-shadow: 0 30px 60px rgba(99,102,241,0.2); }
    .video-card iframe { width: 100%; height: 100%; border: none; position: relative; z-index: 2; }

    /* ══ MARQUEE ══ */
    .marquee-wrap {
      background: var(--white); overflow: hidden;
      padding: 1.1rem 0;
    }
    .marquee-track {
      display: flex; width: max-content;
      animation: marq 26s linear infinite;
      white-space: nowrap;
    }
    .marquee-item {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: .68rem;
      letter-spacing: .22em; text-transform: uppercase;
      color: var(--text); padding: 0 2.25rem;
      display: flex; align-items: center; gap: 2.25rem;
    }
    .marquee-item::after {
      content: '';
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0;
    }

    /* ══ ABOUT ══ */
    .about {
      background: var(--s1); padding: 9rem 0;
      position: relative; overflow: hidden;
    }
    .about-bg-name {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(10rem, 28vw, 24rem);
      color: rgba(124,92,244,.035);
      white-space: nowrap; pointer-events: none; user-select: none;
      letter-spacing: -.05em; line-height: 1;
    }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; align-items: center;
      position: relative; z-index: 1;
    }

    .section-tag {
      display: inline-flex; align-items: center; gap: .55rem;
      font-size: .6rem; font-weight: 600; letter-spacing: .26em; text-transform: uppercase;
      color: var(--accent-l); margin-bottom: 1.5rem;
    }
    .section-tag::before { content: '—'; opacity: .6; }

    .section-h2 {
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: clamp(2.2rem, 4.5vw, 3.8rem); line-height: 1.05; letter-spacing: -.025em;
      color: var(--text); margin-bottom: 2rem;
    }
    .section-h2 em { font-style: italic; font-weight: 400; color: var(--accent); }

    .about-p { font-size: .95rem; line-height: 1.88; color: var(--muted); margin-bottom: 1.1rem; }

    .about-links { display: flex; gap: .85rem; flex-wrap: wrap; margin-top: 2.25rem; }
    .about-link {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .73rem; font-weight: 500; color: var(--text);
      border: 1px solid var(--border); padding: .75rem 1.75rem; border-radius: 3rem;
      text-decoration: none; transition: all .2s;
    }
    .about-link:hover { color: #fff; border-color: var(--accent); background: var(--accent); transform: translateY(-2px); }

    /* Photo frame */
    .about-photo-wrap { position: relative; }
    .about-photo {
      aspect-ratio: 4/5; border-radius: var(--radius); overflow: hidden;
      background: var(--s2); position: relative;
      box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }
    .about-photo img {
      width: 100%; height: 100%; object-fit: cover; object-position: center;
      display: block; transition: transform .8s;
    }
    .about-photo:hover img { transform: scale(1.05); }
    .about-photo::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(99,102,241,0.2) 0%, transparent 60%);
    }
    .about-photo-fallback {
      width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
      background: var(--s2);
    }
    .about-photo-fallback span {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 7rem;
      color: rgba(0,0,0,.05); letter-spacing: -.05em; user-select: none;
    }
    /* Decorative line */
    .about-photo-accent {
      position: absolute; bottom: -1rem; right: -1rem;
      width: 100px; height: 100px; background: var(--accent);
      border-radius: 50%; opacity: 0.1; filter: blur(30px);
    }

    /* ══ SPOTIFY / MUZIEK ══ */
    .music-sec {
      background: var(--bg); padding: 9rem 0;
      position: relative; overflow: hidden;
    }
    /* Subtle background glow */
    .music-sec::before {
      content: '';
      position: absolute; width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(29,185,84,.06) 0%, transparent 70%);
      top: 50%; left: 60%; transform: translate(-50%,-50%);
      pointer-events: none;
    }
    .music-inner {
      display: grid; grid-template-columns: 5fr 6fr; gap: 6.5rem; align-items: center;
      position: relative; z-index: 1;
    }

    .spotify-tag { color: var(--green) !important; }
    .spotify-tag::before { color: var(--green-d) !important; }

    .music-p { font-size: .95rem; line-height: 1.88; color: var(--muted); margin-bottom: 2.25rem; }

    /* Waveform decoration */
    .music-wave {
      display: flex; align-items: center; gap: 4px; margin-bottom: 1.75rem;
    }
    .mw-bar {
      width: 3px; border-radius: 3px; background: var(--green); opacity: .5;
    }

    .spotify-embed {
      border-radius: 12px; overflow: hidden;
      box-shadow: 0 0 60px rgba(29,185,84,.1), 0 24px 60px rgba(0,0,0,.45);
    }

    /* ══ LIVE ══ */
    .live-sec {
      background: var(--s1); padding: 9rem 0;
    }
    .live-head {
      display: flex; align-items: flex-end; justify-content: space-between;
      flex-wrap: wrap; gap: 2rem; margin-bottom: 4rem;
    }
    .live-h2 {
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(2.5rem, 5.5vw, 4.5rem); line-height: .95; letter-spacing: -.04em;
      color: var(--white);
    }
    .live-h2 small {
      display: block; font-size: .38em; font-weight: 400;
      letter-spacing: .22em; text-transform: uppercase;
      color: var(--accent-l); margin-bottom: .6rem;
    }

    .event-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
    .event-card {
      background: var(--white); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 3rem 2.5rem; position: relative; overflow: hidden;
      transition: all .3s cubic-bezier(.22,1,.36,1);
      cursor: default;
    }
    .event-card:hover { border-color: var(--accent); transform: translateY(-5px); box-shadow: 0 15px 35px var(--glow); }
    .event-date {
      font-size: .6rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.5rem;
    }
    .event-venue {
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: 1.5rem; color: var(--text); line-height: 1.1; margin-bottom: .5rem;
    }
    .event-location { font-size: .85rem; color: var(--muted); margin-bottom: 2rem; }
    .event-badge {
      display: inline-block;
      font-size: .55rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
      color: #fff;
      background: var(--accent); padding: .4rem 1.2rem; border-radius: 2rem;
    }

    /* ══ CONTACT ══ */
    .contact-sec { background: var(--bg); padding: 9rem 0; }
    .contact-grid { display: grid; grid-template-columns: 5fr 6fr; gap: 7rem; align-items: start; }
    .contact-p { font-size: .95rem; line-height: 1.88; color: var(--muted); margin-bottom: 2.25rem; }
    .c-info { display: flex; flex-direction: column; gap: .9rem; }
    .c-item { display: flex; align-items: center; gap: .75rem; font-size: .87rem; color: var(--muted); }
    .c-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent-l); flex-shrink: 0; }
    .c-item a { color: inherit; text-decoration: none; transition: color .2s; }
    .c-item a:hover { color: var(--accent-l); }

    /* Form */
    .form { display: flex; flex-direction: column; gap: 1rem; }
    .frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; width: 100%; max-width: 100%; }
    .field { display: flex; flex-direction: column; gap: .35rem; }
    .field label {
      font-size: .58rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
      color: var(--muted);
    }
    .field input, .field select, .field textarea {
      background: var(--white); border: 1px solid var(--border); border-radius: 2rem;
      padding: 1rem 1.25rem; width: 100%; max-width: 100%; min-width: 0;
      box-sizing: border-box !important;
      font-family: 'Outfit', sans-serif; font-size: .9rem; color: var(--text);
      outline: none; transition: all .2s;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--accent); box-shadow: 0 0 0 3px var(--glow);
    }
    .field input::placeholder, .field textarea::placeholder { color: rgba(245,244,255,.2); }
    .field textarea { resize: vertical; min-height: 110px; }
    .field select { appearance: none; cursor: pointer; }

    .form-submit {
      padding: 1.1rem; background: var(--accent); color: #fff;
      font-family: 'Outfit', sans-serif; font-size: .73rem; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      border: none; border-radius: 3rem; cursor: pointer;
      box-shadow: 0 8px 20px var(--glow);
      transition: all .3s; margin-top: .5rem;
    }
    .form-submit:hover { background: var(--accent-l); transform: translateY(-3px); box-shadow: 0 12px 30px var(--glow); }
    .form-submit:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .form-success {
      display: none; text-align: center; padding: 3rem 2rem;
      border: 1px solid rgba(124,92,244,.2); border-radius: 6px;
      background: var(--s1);
    }
    .form-success.on { display: block; }
    .form-success-icon {
      width: 52px; height: 52px; border-radius: 50%;
      background: rgba(124,92,244,.12); border: 1px solid rgba(124,92,244,.28);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem; color: var(--accent-l); font-size: 1.25rem;
    }
    .form-success h3 {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.5rem;
      color: var(--white); margin-bottom: .6rem;
    }
    .form-success p { font-size: .88rem; color: var(--muted); line-height: 1.7; }

    /* ══ FOOTER ══ */
    .footer {
      background: var(--s1); border-top: 1px solid var(--border);
      padding: 3.5rem 0 2.5rem;
    }
    .footer-row {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 1.5rem; margin-bottom: 2.5rem;
      padding-bottom: 2.5rem; border-bottom: 1px solid var(--border);
    }
    .footer-logo {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem;
      color: var(--white); text-decoration: none;
    }
