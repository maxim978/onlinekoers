---
import Layout from '../../layouts/Layout.astro';
import Tracker from '../../components/Tracker.astro';
import { supabase } from '../../lib/supabase';
import { resolveStylePreset, cn } from '../../lib/styleEngine';

// Dit is de 'wrapper' voor de specifieke URL met een 's'
const slug = 'hoveniersbedrijf-az';

const { data: lead, error } = await supabase
  .from('leads')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (error || !lead) {
  return Astro.redirect('/404');
}

const style = resolveStylePreset(lead.style_instructions);
const images: string[] = Array.isArray(lead.photos) ? lead.photos : (Array.isArray(lead.images) ? lead.images : []);
const services = Array.isArray(lead.services) ? lead.services : [];

const industryLabel: Record<string, string> = {
  hovenier: 'Hovenier & Tuinontwerp',
};

const svgIcons: Record<string, string> = {
  leaf: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
  home: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12 12 2.25l9.75 9.75M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
  grid: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" /></svg>`,
  fence: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  droplet: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /></svg>`,
  tree: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
};
---

<Layout
  title={lead.company_name}
  description={lead.description || `Bekijk de website preview van ${lead.company_name}`}
  primaryColor={lead.primary_color}
  secondaryColor={lead.secondary_color}
>
  <style define:vars={{ accentColor: lead.accent_color }}>
    .badge-pulse { animation: pulse-ring 2.5s ease infinite; }
    @keyframes pulse-ring { 
      0%, 100% { box-shadow: 0 0 0 0 rgba(var(--accentColor), 0.4) } 
      50% { box-shadow: 0 0 0 8px rgba(var(--accentColor), 0) } 
    }
  </style>

  <!-- Banner -->
  <div class="fixed top-0 left-0 right-0 z-50 bg-slate-900/95 backdrop-blur border-b border-slate-700">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 bg-orange-500/20 border border-orange-500/40 rounded-full px-3 py-1 text-orange-400 text-xs font-semibold">
          <span class="w-1.5 h-1.5 bg-orange-500 rounded-full animate-pulse"></span>
          PREVIEW
        </span>
        <span class="text-slate-300 text-sm hidden sm:block">
          Exclusief ontwerp voor <strong class="text-white">{lead.company_name}</strong>
        </span>
      </div>
      <div class="flex items-center gap-3">
        <a href="#contact-section" class="btn-primary text-sm py-2 px-4">Dit wil ik!</a>
      </div>
    </div>
  </div>

  <div class="h-[57px]"></div>

  <!-- HERO -->
  <section class={cn("relative min-h-[90vh] flex items-center justify-center overflow-hidden", style.heroLayout === 'fullbleed' ? 'p-0' : 'px-6')}>
    <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${lead.secondary_color} 0%, #1e293b 100%)`}></div>
    <div class="relative z-10 text-center transition-all duration-1000", style.containerMaxWidth)>
      {lead.logo_url && (
        <img src={lead.logo_url} alt={lead.company_name} class="h-16 w-auto mx-auto mb-8 object-contain" />
      )}
      <div class={cn("inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6", style.fontHeading)}
           style={`color: ${lead.primary_color}; background-color: ${lead.primary_color}20; border: 1px solid ${lead.primary_color}40`}>
        {lead.category || 'Vakmanschap'}
      </div>
      <h1 class={cn("font-black text-white leading-tight mb-6", style.h1Size, style.fontHeading)}>
        {lead.headline || lead.company_name}
      </h1>
      <p class={cn("text-slate-300 mx-auto leading-relaxed mb-10 max-w-2xl", style.fontBody, style.h2Size)}>
        {lead.subheadline || lead.style_instructions}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contact-section" class={cn("btn-primary", style.buttonStyle)}>Neem contact op</a>
      </div>
    </div>
  </section>

  <!-- DIENSTEN -->
  {services.length > 0 && (
    <section id="diensten" class={cn("py-28 bg-slate-900", style.sectionPadding)}>
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class={cn("font-black text-white mb-4", style.h2Size, style.fontHeading)}>Onze diensten</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((s: any) => (
            <div class={cn("rounded-2xl p-8 border border-slate-700", style.cardStyle)}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl mb-6 shadow-lg"
                   style={`background-color: ${lead.primary_color}15`}>
                <div class="w-6 h-6" style={`color: ${lead.primary_color}`} set:html={svgIcons[s.icon] || svgIcons.leaf} />
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{s.title}</h3>
              <p class="text-slate-400 leading-relaxed text-sm">{s.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- GALLERY -->
  {images.length > 0 && (
    <section class="py-24 bg-slate-950">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <h2 class={cn("font-black text-white mb-12", style.h2Size, style.fontHeading)}>Portefeuille</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {images.map((src) => (
            <div class={cn("aspect-video overflow-hidden bg-slate-800", style.borderRadius)}>
              <img src={src} alt="project" class={cn("w-full h-full object-cover transition-transform duration-700 hover:scale-110", style.imageStyle)} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <Tracker leadId={lead.id} />
</Layout>
