            <textarea placeholder="Vertel meer over uw evenement, locatie, verwacht publiek..."></textarea>
          </div>
          <button type="submit" class="lm-submit" data-track="form-submit">
            Verstuur boekingsaanvraag →
          </button>
        </form>

        <div class="lm-success" id="lmSuccess">
          <div class="lm-success-check">✓</div>
          <h3>Aanvraag ontvangen!</h3>
          <p>We nemen zo snel mogelijk contact op over de beschikbaarheid van Lara voor jouw evenement.</p>
        </div>
      </div>

    </div>
  </div>
</section>


