---
import Tracker from '../../../components/Tracker.astro';
import { supabaseAdmin } from '../../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'lara-millaa')
  .maybeSingle();
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Lara Millaa – Nederlandstalige zangeres. Warm stemgeluid, krachtige podiumpresentatie. Van feesttent tot Gelredome." />
  <title>Lara Millaa | Nederlandstalige Zangeres</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

  <style>
    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    /* ── Tokens ── */
    :root {
      --dark:    #0D0A08;
      --dark-2:  #181310;
      --dark-3:  #221A14;
      --gold:    #C9973C;
      --gold-hi: #E2B865;
      --cream:   #F5F0E8;
      --cream-2: #EDE7DA;
      --rose:    #BE6070;
      --text:    #1A1208;
      --muted:   rgba(26,18,8,0.50);
      --on-dark: rgba(245,240,232,0.85);
      --on-dark-muted: rgba(245,240,232,0.42);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--dark);
      color: var(--cream);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    h1,h2,h3,.serif { font-family: 'Cormorant Garamond', serif; }

    .lm-wrap { max-width: 1120px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }

    /* ── Reveal ── */
    .r { opacity: 0; transform: translateY(36px); transition: opacity 0.9s cubic-bezier(.2,.8,.2,1), transform 0.9s cubic-bezier(.2,.8,.2,1); }
    .r.on { opacity: 1; transform: none; }

    /* ── Tag label ── */
    .lm-tag {
      display: inline-block;
      font-size: 0.62rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.28em;
      color: var(--gold); margin-bottom: 1.25rem;
    }

    /* ════════════════════════════════════
       NAV
    ════════════════════════════════════ */
    .lm-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      padding: 1.75rem 0;
      transition: padding .4s, background .4s, box-shadow .4s;
    }
    .lm-nav.s {
      background: rgba(13,10,8,.93);
      backdrop-filter: blur(22px);
      padding: 1rem 0;
      box-shadow: 0 1px 0 rgba(201,151,60,.12);
    }
    .lm-nav-inner { display: flex; align-items: center; justify-content: space-between; }

    .lm-nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem; font-weight: 700; font-style: italic;
      color: var(--cream); text-decoration: none; letter-spacing: .02em;
    }
    .lm-nav-logo em { color: var(--gold); font-style: normal; }

    .lm-nav-links { display: flex; align-items: center; gap: 2.25rem; }
    .lm-nav-link {
      font-size: 0.75rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: .12em;
      color: var(--on-dark-muted); text-decoration: none; transition: color .3s;
    }
    .lm-nav-link:hover { color: var(--cream); }
    .lm-nav-cta {
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      background: var(--gold); color: var(--dark);
      padding: .6rem 1.4rem; border-radius: 99px;
      text-decoration: none; transition: all .3s;
    }
    .lm-nav-cta:hover { background: var(--gold-hi); transform: translateY(-1px); }

    /* ════════════════════════════════════
       HERO
    ════════════════════════════════════ */
    .lm-hero {
      min-height: 100vh; position: relative;
      display: flex; flex-direction: column;
      background: var(--dark); overflow: hidden;
    }

    /* warm glow blobs */
    .lm-glow {
      position: absolute; border-radius: 50%;
      filter: blur(130px); pointer-events: none;
    }
    .lm-glow-a {
      width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(201,151,60,.16) 0%, transparent 70%);
      top: -180px; right: -160px;
    }
    .lm-glow-b {
      width: 450px; height: 450px;
      background: radial-gradient(circle, rgba(190,96,112,.09) 0%, transparent 70%);
      bottom: 5%; left: -100px;
    }

    /* ghost monogram behind text */
    .lm-hero-mono {
      position: absolute; right: 2vw; top: 50%;
      transform: translateY(-50%);
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(12rem, 28vw, 26rem);
      font-weight: 700; font-style: italic;
      color: transparent;
      -webkit-text-stroke: 1.5px rgba(201,151,60,.07);
      line-height: 1; user-select: none; pointer-events: none;
    }

    .lm-hero-body {
      flex: 1; position: relative; z-index: 1;
      display: flex; align-items: flex-end;
      padding-top: 10rem; padding-bottom: 5rem;
    }

    .lm-hero-eyebrow {
      display: flex; align-items: center; gap: 1rem;
      font-size: .64rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .32em;
      color: var(--gold); margin-bottom: 1.5rem;
    }
    .lm-hero-eyebrow::before {
      content: ''; width: 36px; height: 1px; background: var(--gold); flex-shrink: 0;
    }

    .lm-hero-h1 {
      font-family: 'Cormorant Garamond', serif;
      line-height: .88; font-weight: 700;
      margin-bottom: 3.5rem;
    }
    .lm-h1-a {
      display: block;
      font-size: clamp(5.5rem, 16vw, 15rem);
      font-style: italic; color: var(--cream);
      letter-spacing: -.02em;
    }
    .lm-h1-b {
      display: block;
      font-size: clamp(5.5rem, 16vw, 15rem);
      font-style: normal; color: var(--gold);
      letter-spacing: .04em;
    }

    .lm-hero-foot {
      display: flex; align-items: center;
      justify-content: space-between; flex-wrap: wrap; gap: 2rem;
    }
    .lm-hero-sub {
      font-size: .88rem; color: var(--on-dark-muted);
      line-height: 1.65; max-width: 300px;
    }
    .lm-hero-btns { display: flex; gap: .9rem; flex-wrap: wrap; }

    /* generic buttons */
    .lm-btn {
      display: inline-flex; align-items: center; gap: .6rem;
      font-size: .72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      padding: .9rem 2rem; border-radius: 99px;
      text-decoration: none; transition: all .3s; cursor: pointer;
    }
    .lm-btn-gold {
      background: var(--gold); color: var(--dark);
      box-shadow: 0 4px 20px rgba(201,151,60,.3);
    }
    .lm-btn-gold:hover { background: var(--gold-hi); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,151,60,.42); }
    .lm-btn-outline {
      border: 1px solid rgba(245,240,232,.22); color: var(--cream);
    }
    .lm-btn-outline:hover { border-color: rgba(245,240,232,.55); background: rgba(245,240,232,.05); }
    .lm-btn-dark {
      background: var(--dark); color: var(--cream);
      border: none;
    }
    .lm-btn-dark:hover { background: var(--dark-3); transform: translateY(-2px); }

    /* scroll hint */
    .lm-scroll-hint {
      position: absolute; bottom: 2.5rem; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      opacity: .35; pointer-events: none;
    }
    .lm-scroll-hint span { font-size: .52rem; letter-spacing: .25em; text-transform: uppercase; }
    .lm-scroll-line {
      width: 1px; height: 44px;
      background: linear-gradient(to bottom, white, transparent);
      animation: spulse 2.2s ease-in-out infinite;
    }
    @keyframes spulse {
      0%,100% { opacity: .35; } 50% { opacity: .85; }
    }

    /* ════════════════════════════════════
       TICKER
    ════════════════════════════════════ */
    .lm-ticker-wrap { background: var(--gold); padding: .8rem 0; overflow: hidden; }
    .lm-ticker-track {
      display: flex;
      animation: tick 35s linear infinite;
      white-space: nowrap;
    }
    .lm-ticker-track:hover { animation-play-state: paused; }
    .lm-tick-item {
      display: inline-flex; align-items: center; gap: 2rem;
      padding-right: 2rem; flex-shrink: 0;
      font-size: .68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .14em;
      color: rgba(13,10,8,.65);
    }
    .lm-tick-item::after { content: '◆'; font-size: .4rem; opacity: .45; }
    @keyframes tick {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ════════════════════════════════════
       OVER LARA
    ════════════════════════════════════ */
    .lm-about { background: var(--cream); padding: 9rem 0; color: var(--text); }
    .lm-about-grid {
      display: grid; grid-template-columns: 5fr 6fr;
      gap: 6rem; align-items: center;
    }

    /* Styled artist card instead of raw photo placeholder */
    .lm-artist-card {
      position: relative; border-radius: 2.5rem; overflow: hidden;
      aspect-ratio: 3/4; background: var(--dark-2);
      display: flex; flex-direction: column;
      justify-content: flex-end; padding: 2.5rem;
    }
    .lm-artist-card-mono {
      position: absolute; top: -1rem; left: -0.5rem; right: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(8rem, 20vw, 18rem);
      font-weight: 700; font-style: italic;
      color: transparent;
      -webkit-text-stroke: 1px rgba(201,151,60,.13);
      line-height: 1; user-select: none;
      letter-spacing: -.04em;
    }
    .lm-artist-card-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      opacity: 0; /* shown when image loads */
      transition: opacity .6s;
    }
    .lm-artist-card-img.loaded { opacity: 1; }
    .lm-artist-card-stripe {
      position: absolute; top: 0; left: 0; right: 0;
      height: 3px; background: linear-gradient(to right, var(--gold), transparent);
    }
    .lm-artist-card-info {
      position: relative; z-index: 1;
    }
    .lm-artist-card-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.75rem; font-weight: 700; font-style: italic;
      color: var(--cream); line-height: 1;
    }
    .lm-artist-card-role {
      font-size: .65rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .22em;
      color: var(--gold); margin-top: .4rem;
    }

    /* Floating badge */
    .lm-card-badge {
      position: absolute; bottom: -1.5rem; right: -1.5rem;
      background: var(--gold);
      border-radius: 1.25rem; padding: 1.5rem 1.75rem;
      text-align: center; z-index: 5;
    }
    .lm-card-badge-num {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem; font-weight: 700;
      color: var(--dark); line-height: 1;
    }
    .lm-card-badge-lbl {
      display: block; font-size: .58rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .16em;
      color: rgba(13,10,8,.65); margin-top: .2rem;
    }

    .lm-about-h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 4vw, 3.75rem);
      font-weight: 700; font-style: italic;
      line-height: 1.1; color: var(--text); margin-bottom: 1.75rem;
    }
    .lm-about-p {
      font-size: 1rem; line-height: 1.85;
      color: var(--muted); margin-bottom: 1.2rem;
    }
    .lm-stats-row {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 2rem; margin-top: 3rem; padding-top: 3rem;
      border-top: 1px solid var(--cream-2);
    }
    .lm-stat-n {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.25rem; font-weight: 700;
      color: var(--gold); line-height: 1;
    }
    .lm-stat-l {
      font-size: .66rem; text-transform: uppercase; letter-spacing: .12em;
      color: var(--muted); margin-top: .3rem;
    }

    /* ════════════════════════════════════
       HOOGTEPUNTEN
    ════════════════════════════════════ */
    .lm-high { background: var(--dark-2); padding: 9rem 0; }
    .lm-high-header {
      display: flex; justify-content: space-between; align-items: flex-end;
      flex-wrap: wrap; gap: 2rem; margin-bottom: 4.5rem;
    }
    .lm-high-h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 4.5vw, 4.5rem);
      font-weight: 700; color: var(--cream); line-height: 1.05;
    }
    .lm-high-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem; }

    .lm-hcard {
      background: var(--dark-3);
      border: 1px solid rgba(201,151,60,.1);
      border-radius: 2rem; padding: 3rem;
      position: relative; overflow: hidden;
      transition: border-color .35s, transform .35s;
    }
    .lm-hcard:hover { border-color: rgba(201,151,60,.35); transform: translateY(-5px); }
    .lm-hcard::before {
      content: ''; position: absolute;
      top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(to right, var(--gold), transparent);
    }

    .lm-hcard-year {
      display: inline-block;
      font-size: .62rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .2em;
      color: var(--gold); border: 1px solid rgba(201,151,60,.3);
      padding: .3rem .85rem; border-radius: 99px; margin-bottom: 2rem;
    }
    .lm-hcard-venue {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.75rem; font-weight: 700;
      color: var(--cream); line-height: 1; margin-bottom: .4rem;
    }
    .lm-hcard-sub {
      font-size: .82rem; color: var(--on-dark-muted);
      margin-bottom: 1.5rem; line-height: 1.5;
    }
    .lm-hcard-desc {
      font-size: .9rem; color: var(--on-dark-muted); line-height: 1.75;
    }
    .lm-hcard-deco {
      position: absolute; bottom: -1.5rem; right: 1rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 9rem; font-weight: 700; font-style: italic;
      color: transparent; -webkit-text-stroke: 1px rgba(201,151,60,.06);
      line-height: 1; pointer-events: none; user-select: none;
    }

    /* ════════════════════════════════════
       REPERTOIRE
    ════════════════════════════════════ */
    .lm-rep { background: var(--cream); padding: 9rem 0; color: var(--text); }
    .lm-rep-head { text-align: center; margin-bottom: 5rem; }
    .lm-rep-h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.75rem, 5vw, 5rem);
      font-weight: 700; font-style: italic;
      color: var(--text); line-height: 1.05; margin-bottom: .75rem;
    }
    .lm-rep-sub {
      font-size: .95rem; color: var(--muted);
      max-width: 480px; margin: 0 auto; line-height: 1.75;
    }
    .lm-rep-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.75rem; }

    .lm-rcard {
      background: white; border-radius: 2rem; padding: 2.75rem 2.25rem;
      border: 1px solid var(--cream-2);
      transition: box-shadow .35s, transform .35s;
    }
    .lm-rcard:hover { box-shadow: 0 20px 60px rgba(26,18,8,.08); transform: translateY(-5px); }
    .lm-rcard-icon {
      width: 52px; height: 52px; border-radius: 1rem;
      background: rgba(201,151,60,.1);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem; margin-bottom: 1.5rem;
    }
    .lm-rcard-cat {
      font-size: .6rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .22em;
      color: var(--gold); margin-bottom: .5rem;
    }
    .lm-rcard-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.65rem; font-weight: 700;
      color: var(--text); margin-bottom: .75rem;
    }
    .lm-rcard-desc { font-size: .88rem; color: var(--muted); line-height: 1.75; }
    .lm-rcard-pills { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1.5rem; }
    .lm-pill {
      font-size: .62rem; font-weight: 600;
      color: var(--muted); background: var(--cream-2);
      padding: .28rem .7rem; border-radius: 99px;
    }

    /* ════════════════════════════════════
       QUOTE STRIP
    ════════════════════════════════════ */
    .lm-quote-strip {
      background: var(--gold); padding: 5rem 0;
      overflow: hidden; position: relative;
    }
    .lm-quote-strip::before, .lm-quote-strip::after {
      content: '"';
      position: absolute;
      font-family: 'Cormorant Garamond', serif;
      font-size: 30rem; font-weight: 700; color: rgba(13,10,8,.06);
      line-height: 1; top: -3rem;
    }
    .lm-quote-strip::before { left: 1rem; }
    .lm-quote-strip::after  { right: 1rem; }
    .lm-quote-inner { text-align: center; position: relative; z-index: 1; }
    .lm-quote-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4.5vw, 3.75rem);
      font-weight: 600; font-style: italic;
      color: var(--dark); line-height: 1.3;
      max-width: 900px; margin: 0 auto 1.5rem;
    }
    .lm-quote-attr {
      font-size: .7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .22em;
      color: rgba(13,10,8,.55);
    }

    /* ════════════════════════════════════
       CONTACT / BOOKING
    ════════════════════════════════════ */
    .lm-contact { background: var(--dark-2); padding: 9rem 0; }
    .lm-contact-grid {
      display: grid; grid-template-columns: 5fr 6fr;
      gap: 7rem; align-items: start;
    }
    .lm-contact-h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.75rem, 4.5vw, 4.25rem);
      font-weight: 700; font-style: italic;
      color: var(--cream); line-height: 1.1; margin-bottom: 1.5rem;
    }
    .lm-contact-p {
      font-size: .95rem; color: var(--on-dark-muted);
      line-height: 1.75; margin-bottom: 2.5rem;
    }
    .lm-contact-items { display: flex; flex-direction: column; gap: 1.1rem; }
    .lm-ci {
      display: flex; align-items: center; gap: 1rem;
      font-size: .9rem; color: var(--on-dark-muted);
    }
    .lm-ci-icon {
      width: 38px; height: 38px; flex-shrink: 0;
      border-radius: .75rem; background: rgba(201,151,60,.1);
      display: flex; align-items: center; justify-content: center; font-size: .9rem;
    }
    .lm-ci a { color: inherit; text-decoration: none; transition: color .3s; }
    .lm-ci a:hover { color: var(--gold); }

    /* Form */
    .lm-form { display: flex; flex-direction: column; gap: 1.1rem; }
    .lm-frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
    .lm-field { display: flex; flex-direction: column; gap: .35rem; }
    .lm-field label {
      font-size: .6rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .16em;
      color: var(--on-dark-muted);
    }
    .lm-field input, .lm-field select, .lm-field textarea {
      width: 100%; padding: .95rem 1.2rem;
      border-radius: .85rem;
      border: 1.5px solid rgba(245,240,232,.1);
      background: rgba(245,240,232,.06);
      font-family: 'DM Sans', sans-serif;
      font-size: .92rem; color: var(--cream);
      outline: none; transition: border-color .25s;
    }
    .lm-field input::placeholder, .lm-field textarea::placeholder { color: var(--on-dark-muted); }
    .lm-field select { appearance: none; cursor: pointer; }
    .lm-field select option { background: var(--dark-3); color: var(--cream); }
    .lm-field input:focus, .lm-field select:focus, .lm-field textarea:focus {
      border-color: var(--gold);
    }
    .lm-field textarea { resize: vertical; min-height: 120px; }

    .lm-submit {
      width: 100%; padding: 1.15rem;
      background: var(--gold); color: var(--dark);
      border: none; border-radius: 99px;
      font-family: 'DM Sans', sans-serif;
      font-size: .75rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      cursor: pointer; transition: all .3s; margin-top: .5rem;
    }
    .lm-submit:hover { background: var(--gold-hi); transform: translateY(-2px); }
    .lm-submit:disabled { opacity: .4; cursor: not-allowed; transform: none; }

    .lm-success {
      display: none;
      text-align: center; padding: 3.5rem 2rem;
      background: rgba(201,151,60,.08);
      border: 1px solid rgba(201,151,60,.2); border-radius: 1.75rem;
    }
    .lm-success.show { display: block; }
    .lm-success-check {
      width: 60px; height: 60px; border-radius: 50%;
      border: 2px solid rgba(201,151,60,.4); background: rgba(201,151,60,.1);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem; font-size: 1.25rem; color: var(--gold);
    }
    .lm-success h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem; color: var(--cream); margin-bottom: .75rem;
    }
    .lm-success p { font-size: .9rem; color: var(--on-dark-muted); line-height: 1.7; }

    /* ════════════════════════════════════
       FOOTER
    ════════════════════════════════════ */
    .lm-footer {
      background: var(--dark); padding: 3.5rem 0 2rem;
      border-top: 1px solid rgba(201,151,60,.08);
    }
    .lm-footer-row {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 2rem;
    }
    .lm-footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem; font-weight: 700; font-style: italic;
      color: var(--cream); text-decoration: none;
    }
    .lm-footer-logo em { color: var(--gold); font-style: normal; }
    .lm-footer-links { display: flex; gap: 2rem; flex-wrap: wrap; }
    .lm-footer-link {
      font-size: .72rem; color: var(--on-dark-muted);
      text-decoration: none; transition: color .3s;
    }
    .lm-footer-link:hover { color: var(--gold); }
    .lm-footer-copy {
      border-top: 1px solid rgba(255,255,255,.05);
      margin-top: 2.5rem; padding-top: 2rem;
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
      font-size: .68rem; color: var(--on-dark-muted);
    }

    /* ════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════ */
    @media (max-width: 960px) {
      .lm-about-grid  { grid-template-columns: 1fr; gap: 4rem; }
      .lm-high-grid   { grid-template-columns: 1fr; }
      .lm-rep-grid    { grid-template-columns: 1fr 1fr; }
      .lm-contact-grid { grid-template-columns: 1fr; gap: 4rem; }
      .lm-nav-links   { display: none; }
    }
    @media (max-width: 600px) {
      .lm-rep-grid    { grid-template-columns: 1fr; }
      .lm-stats-row   { grid-template-columns: 1fr 1fr; }
      .lm-frow        { grid-template-columns: 1fr; }
      .lm-hero-mono   { display: none; }
      .lm-card-badge  { right: 0; bottom: -1rem; }
    }
  </style>
</head>
<body>

