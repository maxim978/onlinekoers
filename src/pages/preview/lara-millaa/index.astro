<!-- ════ CONTACT / BOOKING ════ -->
<section class="contact" id="contact">
  <div class="wrap">
    <div class="contact-grid">
      <div class="r">
        <span class="stag">Boek Lara</span>
        <h2 class="contact-h2">Lara op jouw podium?</h2>
        <p class="contact-p">Of het nu gaat om een feesttent, bedrijfsfeest, bruiloft, theater of festival — Lara brengt altijd het beste van zichzelf mee. Vul het formulier in, we nemen snel contact op.</p>
        <div class="cinfo">
          <div class="cinfo-item"><div class="cinfo-dot"></div><span>Bovensmilde, Drenthe — door heel Nederland beschikbaar</span></div>
          <div class="cinfo-item"><div class="cinfo-dot"></div><a href="https://www.instagram.com/lara_millaa/" target="_blank" rel="noopener">@lara_millaa op Instagram</a></div>
          <div class="cinfo-item"><div class="cinfo-dot"></div><span>Levenslied · Feesthits · Eigen werk</span></div>
          <div class="cinfo-item"><div class="cinfo-dot"></div><span>Feesttent · Bruiloft · Bedrijfsfeest · Festival · Theater</span></div>
        </div>
      </div>
      <div class="r" style="transition-delay:.12s;">
        <form class="form" id="bookForm">
          <div class="frow">
            <div class="field"><label>Uw naam</label><input type="text" placeholder="Jan de Vries" required /></div>
            <div class="field"><label>Organisatie</label><input type="text" placeholder="Evenement / bedrijf" /></div>
          </div>
          <div class="frow">
            <div class="field"><label>E-mailadres</label><input type="email" placeholder="jan@voorbeeld.nl" required /></div>
            <div class="field"><label>Telefoonnummer</label><input type="tel" placeholder="06 12 34 56 78" /></div>
          </div>
          <div class="frow">
            <div class="field"><label>Datum evenement</label><input type="date" /></div>
            <div class="field">
              <label>Type optreden</label>
              <select>
                <option value="">Kies een type...</option>
                <option>Feesttent / Carnaval</option>
                <option>Bedrijfsfeest</option>
                <option>Bruiloft / Gala</option>
                <option>Festival / Open podium</option>
                <option>Theater / Cabaretshow</option>
                <option>Anders</option>
              </select>
            </div>
          </div>
          <div class="field"><label>Bericht</label><textarea placeholder="Vertel meer over uw evenement, locatie, publiek en eventuele wensen..."></textarea></div>
          <button type="submit" class="form-submit" data-track="form-submit">Verstuur boekingsaanvraag →</button>
        </form>
        <div class="form-success" id="bookSuccess">
          <div class="form-success-icon">✓</div>
          <h3>Aanvraag ontvangen!</h3>
          <p>We nemen zo snel mogelijk contact op over de beschikbaarheid van Lara voor jouw evenement.</p>
        </div>
      </div>
    </div>
  </div>
</section>


