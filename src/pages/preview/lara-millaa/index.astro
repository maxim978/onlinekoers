---
import Tracker from '../../../components/Tracker.astro';
import { supabaseAdmin } from '../../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'lara-millaa')
  .maybeSingle();
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Lara Millaa. Nederlandstalige zangeres. Warm stemgeluid, krachtige podiumpresentatie. Van feesttent tot Gelredome." />
  <title>Lara Millaa | Nederlandstalige Zangeres</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/lenis@1.1.13/dist/lenis.css">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --white:  #FFFFFF;
      --warm:   #F8F5F1;
      --warm-2: #F1EDE7;
      --dark:   #111010;
      --border: rgba(20,16,12,0.09);
      --text:   #141210;
      --muted:  rgba(20,18,16,0.48);
      --rose:   #C56B58;
      --rose-l: rgba(197,107,88,0.09);
      
      --font-display: 'Instrument Serif', serif;
      --font-body:    'Plus Jakarta Sans', sans-serif;
      --font-ui:      'Outfit', sans-serif;
    }

    body {
      font-family: var(--font-body);
      background: var(--white);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    h1, h2, h3 { font-family: var(--font-display); font-weight: 400; }
    .nav-logo, .btn, .stag, .nav-link, .about-stat-l, .hcard-year, .hcard-tag, .quote-attr, .field label, .footer-link, .footer-copy { font-family: var(--font-ui); }
    .wrap { max-width: 1140px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }

    .r { opacity: 0; transform: translateY(28px); transition: opacity .85s cubic-bezier(.2,.8,.2,1), transform .85s cubic-bezier(.2,.8,.2,1); }
    .r.on { opacity: 1; transform: none; }

    .stag {
      display: inline-flex; align-items: center; gap: .6rem;
      font-size: .62rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .28em; color: var(--rose);
      margin-bottom: 1.25rem;
    }
    .stag::before { content: ''; width: 24px; height: 1px; background: var(--rose); }
    .stag-light { color: rgba(248,245,241,.5); }
    .stag-light::before { background: rgba(248,245,241,.5); }

    /* ════ KEYFRAMES ════ */
    @keyframes heroIn {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: none; }
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50%     { transform: translateY(-12px); }
    }
    @keyframes spulse { 0%,100%{opacity:.3} 50%{opacity:.8} }

    /* ════ NAV ════ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      padding: 1.6rem 0;
      transition: padding .4s, background .4s, border-color .4s;
      border-bottom: 1px solid transparent;
    }
    .nav.s {
      background: rgba(255,255,255,.7);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      padding: 1rem 0;
      border-color: var(--border);
    }
    .nav-row { display: flex; align-items: center; justify-content: space-between; }
    .nav-logo {
      font-family: 'Oswald', sans-serif;
      font-size: 1.25rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      color: var(--text); text-decoration: none;
    }
    .nav-logo span { color: var(--rose); }
    .nav-links { display: flex; align-items: center; gap: 2.25rem; }
    .nav-link {
      font-size: .73rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: .12em;
      color: var(--muted); text-decoration: none; transition: color .25s;
      position: relative;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -.25rem; left: 0; right: 0;
      height: 1px; background: var(--rose);
      transform: scaleX(0); transform-origin: left;
      transition: transform .25s cubic-bezier(.2,.8,.2,1);
    }
    .nav-link:hover { color: var(--text); }
    .nav-link:hover::after { transform: scaleX(1); }
    .nav-cta {
      font-size: .7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      color: var(--white); background: var(--text);
      padding: .65rem 1.5rem; border-radius: 99px;
      text-decoration: none; transition: background .25s, transform .25s;
    }
    .nav-cta:hover { background: var(--rose); transform: translateY(-1px); }

    /* ════ HERO ════ */
    .hero {
      min-height: 100vh; background: var(--white);
      display: grid; grid-template-columns: 1fr 42vw;
      overflow: hidden;
    }

    .hero-left {
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 12rem clamp(2rem, 4vw, 4rem) 7rem clamp(1.5rem, max(3vw, calc((100vw - 1140px)/2 + 4rem)), 10rem);
    }
    .hero-eyebrow {
      display: flex; align-items: center; gap: .75rem;
      font-size: .65rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .3em; color: var(--rose);
      margin-bottom: 1.5rem;
      animation: heroIn .9s cubic-bezier(.2,.8,.2,1) .1s both;
    }
    .hero-eyebrow::before { content: ''; width: 30px; height: 1px; background: var(--rose); }

    .hero-h1 { line-height: 1; margin-bottom: 2.5rem; }
    .h1-first {
      display: block; font-weight: 400; color: var(--text);
      font-size: clamp(5rem, 10vw, 11rem); letter-spacing: -0.03em;
      text-transform: uppercase; line-height: 1;
      animation: heroIn .9s cubic-bezier(.2,.8,.2,1) .3s both;
    }
    .h1-last {
      display: block; font-weight: 400; color: var(--rose);
      font-size: clamp(5rem, 10vw, 11rem); letter-spacing: -0.03em;
      text-transform: uppercase; line-height: 1;
      animation: heroIn .9s cubic-bezier(.2,.8,.2,1) .5s both;
      font-style: italic; margin-top: -0.1em;
    }
    .hero-sub {
      font-size: .98rem; color: var(--muted); line-height: 1.7;
      max-width: 380px; margin-bottom: 2.5rem;
      animation: heroIn .9s cubic-bezier(.2,.8,.2,1) .65s both;
    }
    .hero-btns {
      display: flex; gap: .85rem; flex-wrap: wrap;
      animation: heroIn .9s cubic-bezier(.2,.8,.2,1) .8s both;
    }

    .hero-right {
      background: var(--white);
      position: relative; overflow: hidden;
      display: flex; align-items: flex-end; justify-content: center;
      padding-top: 6rem;
    }
    .hero-right img {
      width: 100%; height: 100%;
      object-fit: contain;
      object-position: center bottom;
      display: block;
      animation: float 6s ease-in-out 1.2s infinite;
    }
    .hero-right::before {
      content: ''; position: absolute;
      left: 0; top: 15%; bottom: 0;
      width: 3px; background: var(--rose); z-index: 2;
    }

    .hero-scroll {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      opacity: .3; pointer-events: none;
    }
    .hero-scroll span { font-size: .5rem; letter-spacing: .25em; text-transform: uppercase; }
    .hero-scroll-line { width: 1px; height: 38px; background: linear-gradient(to bottom, var(--text), transparent); animation: spulse 2s ease-in-out infinite; }

    /* buttons */
    .btn {
      display: inline-flex; align-items: center; gap: .55rem;
      font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
      padding: .9rem 2rem; border-radius: 99px;
      text-decoration: none; transition: all .25s; cursor: pointer; border: none;
    }
    .btn-dark { background: var(--text); color: var(--white); }
    .btn-dark:hover { background: var(--rose); transform: translateY(-2px); }
    .btn-ghost { border: 1.5px solid var(--border); color: var(--text); }
    .btn-ghost:hover { border-color: var(--text); }
    .btn-rose { background: var(--rose); color: var(--white); }
    .btn-rose:hover { background: #b55d4b; transform: translateY(-2px); }

    /* ════ FACTS STRIP ════ */
    .facts {
      background: var(--warm); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      padding: 1.75rem 0;
    }
    .facts-inner { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; }
    .fact {
      display: flex; align-items: center; padding: .5rem 2.25rem;
      font-size: .73rem; font-weight: 600; color: var(--muted); letter-spacing: .04em;
      border-right: 1px solid var(--border);
      transition: color .25s, background .25s; cursor: default;
    }
    .fact:last-child { border-right: none; }
    .fact:hover { background: var(--warm-2); color: var(--text); }
    .fact strong { color: var(--text); margin-right: .35rem; }

    /* ════ ABOUT ════ */
    .about { padding: 9rem 0; background: var(--white); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }

    .about-photo-wrap {
      position: relative;
      padding-right: 2rem; padding-bottom: 2rem;
    }
    .about-photo {
      aspect-ratio: 4/5; border-radius: .5rem; overflow: hidden;
      background: var(--warm-2); position: relative;
    }
    .about-photo img {
      width: 100%; height: 100%; object-fit: cover; object-position: center top;
    }
    .about-photo::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 40%;
      background: linear-gradient(to top, rgba(20,18,16,.4), transparent);
    }
    .about-photo-label {
      position: absolute; bottom: 1.75rem; left: 1.75rem; z-index: 1;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem; font-style: italic; color: var(--white);
    }
    .about-badge {
      position: absolute; bottom: 0; right: 0; z-index: 2;
      background: var(--rose); color: var(--white);
      padding: 1.25rem 1.5rem; border-radius: .5rem; text-align: center;
    }
    .about-badge-n { display: block; font-family: 'Oswald', sans-serif; font-size: 2rem; font-weight: 700; line-height: 1; }
    .about-badge-l { display: block; font-size: .58rem; font-weight: 700; text-transform: uppercase; letter-spacing: .14em; opacity: .75; margin-top: .2rem; }

    .about-h2 {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(2.25rem, 3.5vw, 3.5rem);
      font-weight: 700; line-height: 1.1; letter-spacing: .02em;
      color: var(--text); margin-bottom: 1.75rem;
      position: relative; padding-bottom: 1rem;
    }
    .about-h2::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 0; height: 2px; background: var(--rose);
      transition: width .7s cubic-bezier(.2,.8,.2,1) .4s;
    }
    .r.on .about-h2::after { width: 2.5rem; }

    .about-p { font-size: .98rem; line-height: 1.85; color: var(--muted); margin-bottom: 1.1rem; }
    .about-stats {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 1.5rem; margin-top: 3rem; padding-top: 3rem; border-top: 1px solid var(--border);
    }
    .about-stat-n { font-family: 'Oswald', sans-serif; font-size: 2.25rem; font-weight: 700; color: var(--rose); line-height: 1; }
    .about-stat-l { font-size: .65rem; text-transform: uppercase; letter-spacing: .12em; color: var(--muted); margin-top: .3rem; }

    /* ════ HOOGTEPUNTEN ════ */
    .high { padding: 9rem 0; background: var(--warm); }
    .high-header { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 2rem; margin-bottom: 4rem; }
    .high-h2 {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(2.25rem, 4vw, 4rem); font-weight: 700; line-height: 1.05;
      letter-spacing: .02em; color: var(--text);
      position: relative; padding-bottom: 1rem;
    }
    .high-h2::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 0; height: 2px; background: var(--rose);
      transition: width .7s cubic-bezier(.2,.8,.2,1) .4s;
    }
    .r.on .high-h2::after { width: 2.5rem; }

    .high-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .hcard {
      background: var(--white); border: 1px solid var(--border); border-radius: .5rem;
      padding: 3rem; position: relative; overflow: hidden;
      transition: box-shadow .35s, transform .35s;
    }
    .hcard::before {
      content: ''; position: absolute;
      left: 0; top: 0; bottom: 0; width: 3px;
      background: var(--rose);
      transform: scaleY(0); transform-origin: bottom;
      transition: transform .4s cubic-bezier(.2,.8,.2,1);
    }
    .hcard:hover { 
      box-shadow: 0 40px 80px rgba(20,18,16,.12); 
      transform: translateY(-8px); 
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(10px);
    }
    .hcard:hover::before { transform: scaleY(1); }
    .hcard-num {
      position: absolute; top: 2rem; right: 2.5rem;
      font-family: 'Oswald', sans-serif;
      font-size: 5rem; font-weight: 700;
      color: rgba(20,18,16,.05); line-height: 1; user-select: none;
    }
    .hcard-year { display: inline-block; font-size: .6rem; font-weight: 700; text-transform: uppercase; letter-spacing: .22em; color: var(--rose); margin-bottom: 1.75rem; }
    .hcard-venue { font-family: 'Oswald', sans-serif; font-size: 2.25rem; font-weight: 700; letter-spacing: .02em; color: var(--text); line-height: 1; margin-bottom: .4rem; }
    .hcard-with { font-size: .82rem; color: var(--muted); margin-bottom: 1.5rem; }
    .hcard-desc { font-size: .9rem; color: var(--muted); line-height: 1.75; }
    .hcard-tag { display: inline-flex; font-size: .6rem; font-weight: 700; text-transform: uppercase; letter-spacing: .16em; color: var(--rose); margin-top: 1.75rem; border-top: 1px solid var(--border); padding-top: 1.5rem; width: 100%; }

    /* ════ LIVE GALLERY ════ */
    .gallery { background: var(--dark); padding: 7rem 0; }
    .gallery-header { margin-bottom: 3rem; }
    .gallery-h2 {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(2rem, 3.5vw, 3.5rem);
      font-weight: 700; letter-spacing: .03em; color: var(--white); line-height: 1.05;
    }
    .gallery-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr;
      grid-template-rows: auto;
      gap: 1rem;
    }
    .gallery-img {
      border-radius: .4rem; overflow: hidden;
      position: relative; background: #1a1818;
    }
    .gallery-img img {
      width: 100%; height: 100%; object-fit: cover;
      display: block; transition: transform .6s cubic-bezier(.2,.8,.2,1);
    }
    .gallery-img::after {
      content: ''; position: absolute;
      bottom: 0; left: 0; right: 0; height: 3px;
      background: var(--rose);
      transform: scaleX(0); transform-origin: left;
      transition: transform .4s cubic-bezier(.2,.8,.2,1);
    }
    .gallery-img:hover img { transform: scale(1.04); }
    .gallery-img:hover::after { transform: scaleX(1); }

    .gallery-img-fire  { grid-column: 1; grid-row: 1 / 3; aspect-ratio: 4/5; }
    .gallery-img-stage { grid-column: 2; grid-row: 1;     aspect-ratio: 1 / 1; }
    .gallery-img-purple{ grid-column: 2; grid-row: 2;     aspect-ratio: 1 / 1; }

    /* ════ QUOTE ════ */
    .quote-sec { padding: 8rem 0; background: var(--warm); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .quote-inner { max-width: 860px; }
    .quote-mark { font-family: 'Oswald', sans-serif; font-size: 5rem; font-weight: 700; color: var(--rose); line-height: .8; margin-bottom: 1rem; display: block; }
    .quote-text { font-family: 'DM Sans', sans-serif; font-size: clamp(1.5rem, 3vw, 2.75rem); font-weight: 400; font-style: italic; color: var(--text); line-height: 1.4; margin-bottom: 2rem; }
    .quote-attr { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .25em; color: var(--muted); }

    /* ════ CONTACT ════ */
    .contact { padding: 9rem 0; background: var(--white); }
    .contact-grid { display: grid; grid-template-columns: 5fr 6fr; gap: 7rem; align-items: start; }
    .contact-h2 {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(2.25rem, 4vw, 3.75rem); font-weight: 700; line-height: 1.05;
      letter-spacing: .02em; color: var(--text); margin-bottom: 1.5rem;
      position: relative; padding-bottom: 1rem;
    }
    .contact-h2::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 0; height: 2px; background: var(--rose);
      transition: width .7s cubic-bezier(.2,.8,.2,1) .4s;
    }
    .r.on .contact-h2::after { width: 2.5rem; }

    .contact-p { font-size: .95rem; color: var(--muted); line-height: 1.75; margin-bottom: 2.5rem; }
    .cinfo { display: flex; flex-direction: column; gap: 1rem; }
    .cinfo-item { display: flex; align-items: center; gap: .9rem; font-size: .88rem; color: var(--muted); transition: color .25s; }
    .cinfo-item:hover { color: var(--text); }
    .cinfo-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rose); flex-shrink: 0; transition: transform .25s; }
    .cinfo-item:hover .cinfo-dot { transform: scale(1.6); }
    .cinfo-item a { color: inherit; text-decoration: none; }
    .cinfo-item a:hover { color: var(--rose); }

    .form { display: flex; flex-direction: column; gap: 1rem; }
    .frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: .35rem; }
    .field label { font-size: .6rem; font-weight: 700; text-transform: uppercase; letter-spacing: .16em; color: var(--muted); }
    .field input, .field select, .field textarea { width: 100%; padding: .9rem 1.15rem; border-radius: .4rem; border: 1.5px solid var(--border); background: var(--white); font-family: 'DM Sans', sans-serif; font-size: .92rem; color: var(--text); outline: none; transition: border-color .2s; }
    .field input:focus, .field select:focus, .field textarea:focus { border-color: var(--rose); }
    .field textarea { resize: vertical; min-height: 110px; }
    .field select { appearance: none; cursor: pointer; }
    .form-submit { width: 100%; padding: 1.1rem; background: var(--text); color: var(--white); border: none; border-radius: 99px; font-family: 'DM Sans', sans-serif; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; cursor: pointer; transition: all .25s; margin-top: .5rem; }
    .form-submit:hover { background: var(--rose); transform: translateY(-2px); }
    .form-submit:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .form-success { display: none; text-align: center; padding: 3rem 2rem; border-radius: .5rem; border: 1.5px solid var(--border); background: var(--warm); }
    .form-success.on { display: block; }
    .form-success-icon { width: 52px; height: 52px; border-radius: 50%; background: var(--rose-l); border: 1.5px solid rgba(197,107,88,.25); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 1.1rem; color: var(--rose); }
    .form-success h3 { font-family: 'Oswald', sans-serif; font-size: 1.75rem; font-weight: 700; color: var(--text); margin-bottom: .6rem; }
    .form-success p { font-size: .88rem; color: var(--muted); line-height: 1.7; }

    /* ════ FOOTER ════ */
    .footer { background: var(--dark); padding: 4rem 0 2.5rem; }
    .footer-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 2rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,.08); }
    .footer-logo { font-family: 'Oswald', sans-serif; font-size: 1.3rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--white); text-decoration: none; }
    .footer-logo span { color: var(--rose); }
    .footer-links { display: flex; gap: 2rem; flex-wrap: wrap; }
    .footer-link { font-size: .72rem; color: rgba(255,255,255,.4); text-decoration: none; transition: color .25s; }
    .footer-link:hover { color: rgba(255,255,255,.9); }
    .footer-copy { padding-top: 2rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; font-size: .68rem; color: rgba(255,255,255,.3); }

    /* ════ RESPONSIVE ════ */
    @media (max-width: 960px) {
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-right { height: 65vw; padding-top: 0; }
      .hero-right img { object-fit: cover; object-position: center top; animation: none; }
      .hero-right::before { display: none; }
      .hero-left { padding: 7rem 1.5rem 4rem; order: 2; }
      .hero-right { order: 1; }
      .about-grid { grid-template-columns: 1fr; gap: 4rem; }
      .high-grid { grid-template-columns: 1fr; }
      .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .gallery-img-fire { grid-column: 1 / 3; grid-row: 1; aspect-ratio: 16/9; }
      .gallery-img-stage { grid-column: 1; grid-row: 2; aspect-ratio: 1; }
      .gallery-img-purple { grid-column: 2; grid-row: 2; aspect-ratio: 1; }
      .contact-grid { grid-template-columns: 1fr; gap: 4rem; }
      .nav-links { display: none; }
    }
    @media (max-width: 600px) {
      .about-stats { grid-template-columns: 1fr 1fr; }
      .frow { grid-template-columns: 1fr; }
      .facts-inner { flex-direction: column; }
      .fact { border-right: none; border-bottom: 1px solid var(--border); width: 100%; justify-content: center; }
      .fact:last-child { border-bottom: none; }
      .gallery-grid { grid-template-columns: 1fr; }
      .gallery-img-fire, .gallery-img-stage, .gallery-img-purple { grid-column: 1; grid-row: auto; aspect-ratio: 4/3; }
    }
    /* ════ EFFECTS ════ */
    .grain {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 9999; pointer-events: none; opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }

    .cursor-dot {
      width: 8px; height: 8px; background: var(--rose);
      border-radius: 50%; position: fixed; top: 0; left: 0;
      pointer-events: none; z-index: 10000; transition: transform 0.1s ease-out;
      display: none;
    }
    @media (hover: hover) { .cursor-dot { display: block; } }

    .reveal-text { overflow: hidden; padding-bottom: 0.15em; margin-bottom: -0.15em; }
    .reveal-text span { display: inline-block; transform: translateY(110%); transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
    .reveal-text.on span { transform: translateY(0); }

    .hero-right img { transition: transform 0.1s ease-out; }
  </style>
</head>
