{lead?.id && <Tracker leadId={lead.id} />}


<script>
  // Nav scroll
  const nav = document.getElementById('lmNav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('s', window.scrollY > 60);
  }, { passive: true });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('on'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.r').forEach(el => obs.observe(el));

  // Artist card image fallback
  document.querySelectorAll<HTMLImageElement>('.lm-artist-card-img').forEach(img => {
    img.addEventListener('error', () => img.remove());
  });

  // Form submit
  document.getElementById('lmForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const btn = (e.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('.lm-submit')!;
    btn.textContent = 'Versturen...';
    btn.disabled = true;
    await new Promise(r => setTimeout(r, 700));
    (e.currentTarget as HTMLElement).style.display = 'none';
    document.getElementById('lmSuccess')!.classList.add('show');
  });
</script>

</body>
</html>
