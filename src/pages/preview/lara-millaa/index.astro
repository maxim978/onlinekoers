{lead?.id && <Tracker leadId={lead.id} />}


<script>
  const nav = document.getElementById('mainNav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('s', window.scrollY > 60);
  }, { passive: true });

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('on'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.r').forEach(el => obs.observe(el));

  // Lenis Smooth Scroll
  // @ts-ignore
  const lenis = new Lenis();
  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  // Parallax Hero
  const heroImg = document.querySelector('.hero-right img') as HTMLElement;
  window.addEventListener('scroll', () => {
    const s = window.scrollY;
    if (heroImg) heroImg.style.transform = `translateY(${s * 0.1}px)`;
  }, { passive: true });

  // Custom Cursor
  const dot = document.querySelector('.cursor-dot') as HTMLElement;
  window.addEventListener('mousemove', e => {
    if (dot) {
      dot.style.transform = `translate(${e.clientX - 4}px, ${e.clientY - 4}px)`;
    }
  });

  document.getElementById('bookForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const btn = (e.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('.form-submit')!;
    btn.textContent = 'Versturen...';
    btn.disabled = true;
    await new Promise(r => setTimeout(r, 700));
    (e.currentTarget as HTMLElement).style.display = 'none';
    document.getElementById('bookSuccess')!.classList.add('on');
  });
</script>

</body>
