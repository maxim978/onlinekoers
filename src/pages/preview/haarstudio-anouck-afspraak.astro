---
import Tracker from '../../components/Tracker.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'haarstudio-anouck')
  .maybeSingle();

const imgLogo = '/images/haarstudio-anouck/logo.jpg';
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Afspraak maken — Haarstudio Anouck</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --black:  #0E0C0C;
      --black2: #1A1617;
      --white:  #FAFAF8;
      --off:    #F3EEEB;
      --rose:   #C4827F;
      --rose-d: #A8605D;
      --rose-bg:#F2C5C3;
      --muted:  rgba(14,12,12,.48);
      --border: rgba(14,12,12,.1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--off);
      color: var(--black);
      -webkit-font-smoothing: antialiased;
      min-height: 100svh;
    }

    /* ── TOPBAR ─────────────────────────────── */
    .topbar {
      background: var(--black);
      padding: 0 clamp(1.25rem, 4vw, 3rem);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 100;
    }
    .topbar-logo {
      display: flex; align-items: center; gap: .6rem;
      text-decoration: none;
    }
    .topbar-logo img { height: 34px; width: 34px; border-radius: 50%; object-fit: cover; }
    .topbar-logo-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .95rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: rgba(250,250,248,.75);
    }
    .topbar-back {
      font-size: .68rem; font-weight: 600; letter-spacing: .08em;
      color: rgba(250,250,248,.4); text-decoration: none;
      display: flex; align-items: center; gap: .4rem;
      transition: color .2s;
    }
    .topbar-back:hover { color: rgba(250,250,248,.8); }

    /* ── PAGE LAYOUT ────────────────────────── */
    .page {
      max-width: 860px; margin: 0 auto;
      padding: 3rem clamp(1rem, 4vw, 2rem) 5rem;
    }

    .page-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900; text-transform: uppercase;
      color: var(--black); margin-bottom: .4rem; line-height: 1;
    }
    .page-sub { font-size: .9rem; color: var(--muted); margin-bottom: 2.5rem; }

    /* ── STEPPER ────────────────────────────── */
    .stepper {
      display: flex; align-items: center; margin-bottom: 3rem;
      gap: 0;
    }
    .step-item {
      display: flex; align-items: center; gap: .65rem;
      flex: 1;
    }
    .step-item:last-child { flex: none; }
    .step-circle {
      width: 36px; height: 36px; border-radius: 50%;
      border: 2px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .9rem; font-weight: 700;
      color: var(--muted); background: var(--white);
      flex-shrink: 0; transition: all .3s;
    }
    .step-circle.active { background: var(--rose); border-color: var(--rose); color: #fff; }
    .step-circle.done   { background: var(--black); border-color: var(--black); color: #fff; }
    .step-label {
      font-size: .7rem; font-weight: 700; letter-spacing: .08em;
      text-transform: uppercase; color: var(--muted);
      white-space: nowrap; transition: color .3s;
    }
    .step-label.active { color: var(--rose); }
    .step-label.done   { color: var(--black); }
    .step-line {
      flex: 1; height: 1.5px; background: var(--border);
      margin: 0 .75rem; transition: background .3s;
    }
    .step-line.done { background: var(--black); }

    /* ── CARDS / PANELS ─────────────────────── */
    .panel {
      background: var(--white);
      border-radius: 4px;
      border: 1.5px solid var(--border);
      overflow: hidden;
    }

    /* ── STEP 1: SERVICES ───────────────────── */
    .cat-header {
      padding: 1.1rem 1.5rem .5rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .78rem; font-weight: 700;
      letter-spacing: .22em; text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    .cat-header:not(:first-child) { border-top: 1px solid var(--border); }

    .service-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 1.5rem;
      border-bottom: 1px solid var(--border);
      cursor: pointer; transition: background .15s;
      gap: 1rem;
    }
    .service-row:last-child { border-bottom: none; }
    .service-row:hover { background: var(--off); }
    .service-row.selected { background: #fdf0ef; }

    .service-info { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 0; }
    .service-radio {
      width: 20px; height: 20px; border-radius: 50%;
      border: 2px solid var(--border); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: all .2s;
    }
    .service-row.selected .service-radio {
      border-color: var(--rose); background: var(--rose);
    }
    .service-radio::after {
      content: ''; width: 8px; height: 8px; border-radius: 50%;
      background: #fff; opacity: 0; transition: opacity .2s;
    }
    .service-row.selected .service-radio::after { opacity: 1; }

    .service-text { min-width: 0; }
    .service-name {
      font-size: .95rem; font-weight: 500; color: var(--black);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .service-dur {
      font-size: .72rem; color: var(--muted); margin-top: 1px;
    }

    .service-right { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
    .service-price {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.25rem; font-weight: 700; color: var(--rose);
    }

    /* ── STEP 2: CALENDAR ───────────────────── */
    .step2-layout {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    /* Calendar */
    .cal-panel { padding: 1.5rem; }
    .cal-nav {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1.25rem;
    }
    .cal-nav-btn {
      background: none; border: 1.5px solid var(--border);
      border-radius: 2px; width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--black); transition: all .2s;
    }
    .cal-nav-btn:hover { border-color: var(--rose); color: var(--rose); }
    .cal-nav-btn:disabled { opacity: .3; cursor: not-allowed; }
    .cal-month-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.05rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .08em;
    }

    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
    .cal-dow {
      text-align: center;
      font-size: .58rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      color: var(--muted); padding: .3rem 0; margin-bottom: .25rem;
    }
    .cal-day {
      aspect-ratio: 1; border-radius: 2px;
      display: flex; align-items: center; justify-content: center;
      font-size: .82rem; font-weight: 500; cursor: pointer;
      border: 1.5px solid transparent;
      transition: all .15s; user-select: none;
    }
    .cal-day.empty     { cursor: default; }
    .cal-day.past      { color: rgba(14,12,12,.2); cursor: not-allowed; }
    .cal-day.closed    { color: rgba(14,12,12,.2); cursor: not-allowed; }
    .cal-day.available { color: var(--black); }
    .cal-day.available:hover { border-color: var(--rose); color: var(--rose); background: #fdf0ef; }
    .cal-day.today     { font-weight: 700; }
    .cal-day.today.available { border-color: var(--border); }
    .cal-day.selected  { background: var(--rose); color: #fff !important; border-color: var(--rose) !important; font-weight: 700; }

    /* Time slots */
    .slots-panel { padding: 1.5rem; }
    .slots-placeholder {
      height: 100%; min-height: 200px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      color: var(--muted); font-size: .88rem; text-align: center;
      gap: .75rem;
    }
    .slots-placeholder svg { opacity: .3; }
    .slots-date-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .06em; margin-bottom: 1.25rem;
    }
    .slots-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: .5rem;
    }
    .slot-btn {
      padding: .65rem .5rem; border-radius: 2px;
      border: 1.5px solid var(--border);
      font-size: .82rem; font-weight: 600; text-align: center;
      cursor: pointer; transition: all .15s; background: var(--white);
      color: var(--black);
    }
    .slot-btn.taken {
      background: var(--off); color: rgba(14,12,12,.3);
      cursor: not-allowed; border-color: var(--border); text-decoration: line-through;
    }
    .slot-btn.available:hover { border-color: var(--rose); color: var(--rose); background: #fdf0ef; }
    .slot-btn.selected { background: var(--rose); border-color: var(--rose); color: #fff; }

    /* ── STEP 3: FORM ───────────────────────── */
    .summary-bar {
      display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;
      background: var(--black2); padding: 1.25rem 1.5rem;
      border-radius: 4px 4px 0 0;
    }
    .summary-chip {
      display: flex; align-items: center; gap: .5rem;
      font-size: .75rem; color: rgba(250,250,248,.65);
    }
    .summary-chip strong { color: rgba(250,250,248,.9); font-weight: 600; }
    .summary-chip + .summary-chip::before {
      content: '·'; color: rgba(250,250,248,.2); font-size: 1rem;
      margin-right: -.25rem;
    }
    .summary-price {
      margin-left: auto;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.4rem; font-weight: 800; color: var(--rose-bg);
    }

    .form-body { padding: 1.75rem 1.5rem; }
    .frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: .3rem; }
    .field label {
      font-size: .58rem; font-weight: 700; letter-spacing: .2em;
      text-transform: uppercase; color: var(--muted);
    }
    .field input, .field textarea {
      padding: .85rem 1rem; border-radius: 2px;
      border: 1.5px solid var(--border);
      background: var(--off); font-family: 'DM Sans', sans-serif;
      font-size: .92rem; color: var(--black); outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input:focus, .field textarea:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 3px rgba(196,130,127,.1);
    }
    .field textarea { resize: vertical; min-height: 90px; }

    /* ── NAV BUTTONS ────────────────────────── */
    .btn-row {
      display: flex; justify-content: space-between; align-items: center;
      margin-top: 1.75rem; gap: 1rem; flex-wrap: wrap;
    }
    .btn {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .82rem; font-weight: 700;
      letter-spacing: .16em; text-transform: uppercase;
      padding: .85rem 2rem; border-radius: 2px;
      border: none; cursor: pointer; transition: all .2s;
      display: inline-flex; align-items: center; gap: .5rem;
      text-decoration: none;
    }
    .btn-ghost {
      background: var(--white); color: var(--muted);
      border: 1.5px solid var(--border);
    }
    .btn-ghost:hover { border-color: var(--black); color: var(--black); }
    .btn-next {
      background: var(--rose); color: #fff; margin-left: auto;
    }
    .btn-next:hover { background: var(--rose-d); }
    .btn-next:disabled { opacity: .4; cursor: not-allowed; }
    .btn-confirm {
      background: var(--black); color: #fff; margin-left: auto;
    }
    .btn-confirm:hover { background: var(--rose); }
    .btn-confirm:disabled { opacity: .4; cursor: not-allowed; }

    /* ── SUCCESS SCREEN ─────────────────────── */
    .success-screen {
      display: none; text-align: center; padding: 4rem 2rem;
    }
    .success-screen.on { display: block; }
    .success-icon {
      width: 72px; height: 72px; border-radius: 50%;
      background: var(--rose); display: flex;
      align-items: center; justify-content: center;
      margin: 0 auto 2rem;
      box-shadow: 0 12px 40px rgba(196,130,127,.35);
    }
    .success-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 900; text-transform: uppercase;
      color: var(--black); margin-bottom: 1rem;
    }
    .success-sub { font-size: .95rem; color: var(--muted); line-height: 1.7; max-width: 480px; margin: 0 auto 2.5rem; }
    .success-summary {
      display: inline-flex; flex-direction: column; gap: .6rem;
      background: var(--white); border: 1.5px solid var(--border);
      border-radius: 4px; padding: 1.5rem 2.5rem;
      text-align: left; margin-bottom: 2.5rem;
    }
    .success-row {
      display: flex; gap: 1rem; align-items: baseline;
      font-size: .88rem;
    }
    .success-row-label { color: var(--muted); width: 80px; flex-shrink: 0; font-size: .75rem; text-transform: uppercase; letter-spacing: .1em; }
    .success-row-val { color: var(--black); font-weight: 500; }
    .success-back {
      display: inline-block;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .8rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase;
      color: var(--muted); text-decoration: none; transition: color .2s;
    }
    .success-back:hover { color: var(--black); }

    /* ── STEP VISIBILITY ────────────────────── */
    .step-content { display: none; }
    .step-content.active { display: block; }

    /* ── RESPONSIVE ─────────────────────────── */
    @media (max-width: 640px) {
      .step2-layout { grid-template-columns: 1fr; }
      .frow { grid-template-columns: 1fr; }
      .stepper .step-label { display: none; }
      .stepper .step-item { flex: none; }
      .stepper .step-line { flex: 1; }
      .slots-grid { grid-template-columns: repeat(4, 1fr); }
      .summary-bar { flex-direction: column; align-items: flex-start; }
      .summary-price { margin-left: 0; }
    }
  </style>
</head>
<body>

<!-- ── TOPBAR ──────────────────────────────────────────────────────── -->
<div class="topbar">
  <a href="/preview/haarstudio-anouck" class="topbar-logo">
    <img src={imgLogo} alt="Haarstudio Anouck" />
    <span class="topbar-logo-name">Haarstudio Anouck</span>
  </a>
  <a href="/preview/haarstudio-anouck" class="topbar-back">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
    </svg>
    Terug naar website
  </a>
</div>


<!-- ── PAGE ───────────────────────────────────────────────────────── -->
<div class="page">
  <h1 class="page-title">Afspraak maken</h1>
  <p class="page-sub">Kies een dienst, selecteer een datum en tijd, en vul jouw gegevens in.</p>

  <!-- STEPPER -->
  <div class="stepper" id="stepper">
    <div class="step-item">
      <div class="step-circle active" id="sc1">1</div>
      <span class="step-label active" id="sl1">Dienst</span>
    </div>
    <div class="step-line" id="line1"></div>
    <div class="step-item">
      <div class="step-circle" id="sc2">2</div>
      <span class="step-label" id="sl2">Datum &amp; tijd</span>
    </div>
    <div class="step-line" id="line2"></div>
    <div class="step-item">
      <div class="step-circle" id="sc3">3</div>
      <span class="step-label" id="sl3">Gegevens</span>
    </div>
  </div>


  <!-- ─── STEP 1: DIENST ────────────────────────────────────────── -->
  <div class="step-content active" id="step1">
    <div class="panel">

      <div class="cat-header">Knippen</div>

      <div class="service-row" data-id="dames-kort" data-name="Dames kort" data-dur="45" data-price="30.50">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Dames kort</div>
            <div class="service-dur">± 45 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 30,50</span>
        </div>
      </div>

      <div class="service-row" data-id="dames-half" data-name="Dames half lang" data-dur="60" data-price="36.50">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Dames half lang</div>
            <div class="service-dur">± 60 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 36,50</span>
        </div>
      </div>

      <div class="service-row" data-id="dames-lang" data-name="Dames lang" data-dur="75" data-price="39.50">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Dames lang</div>
            <div class="service-dur">± 75 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 39,50</span>
        </div>
      </div>

      <div class="service-row" data-id="heer" data-name="Heer" data-dur="30" data-price="26.00">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Heer</div>
            <div class="service-dur">± 30 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 26,00</span>
        </div>
      </div>

      <div class="service-row" data-id="kind" data-name="Kinderen t/m 12 jaar" data-dur="30" data-price="23.50">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Kinderen t/m 12 jaar</div>
            <div class="service-dur">± 30 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 23,50</span>
        </div>
      </div>

      <div class="cat-header">Kleuren</div>

      <div class="service-row" data-id="face-framing" data-name="Face framing folie" data-dur="90" data-price="72.50">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Face framing folie</div>
            <div class="service-dur">± 90 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 72,50</span>
        </div>
      </div>

      <div class="service-row" data-id="scalp" data-name="Scalp folie" data-dur="120" data-price="105.50">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Scalp folie</div>
            <div class="service-dur">± 2 uur</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 105,50</span>
        </div>
      </div>

      <div class="service-row" data-id="full-head" data-name="Full head folie" data-dur="150" data-price="120.00">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Full head folie</div>
            <div class="service-dur">± 2,5 uur</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 120,00</span>
        </div>
      </div>

      <div class="cat-header">Extra's</div>

      <div class="service-row" data-id="toner" data-name="Toner" data-dur="30" data-price="25.00">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">Toner</div>
            <div class="service-dur">± 30 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 25,00</span>
        </div>
      </div>

      <div class="service-row" data-id="olig" data-name="OliG toevoeging" data-dur="15" data-price="10.00">
        <div class="service-info">
          <div class="service-radio"></div>
          <div class="service-text">
            <div class="service-name">OliG toevoeging</div>
            <div class="service-dur">± 15 minuten</div>
          </div>
        </div>
        <div class="service-right">
          <span class="service-price">€ 10,00</span>
        </div>
      </div>

    </div><!-- /panel -->

    <p style="font-size:.72rem; color:var(--muted); margin-top:.75rem; font-style:italic;">
      * Alle genoemde prijzen zijn vanafprijzen. De definitieve prijs wordt bepaald na overleg.
    </p>

    <div class="btn-row">
      <button class="btn btn-next" id="btn1next" disabled>
        Volgende stap
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </button>
    </div>
  </div><!-- /step1 -->


  <!-- ─── STEP 2: DATUM & TIJD ──────────────────────────────────── -->
  <div class="step-content" id="step2">
    <div class="step2-layout">

      <!-- Calendar -->
      <div class="panel cal-panel">
        <div class="cal-nav">
          <button class="cal-nav-btn" id="calPrev" aria-label="Vorige maand">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
            </svg>
          </button>
          <span class="cal-month-label" id="calMonthLabel"></span>
          <button class="cal-nav-btn" id="calNext" aria-label="Volgende maand">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </button>
        </div>

        <div class="cal-grid" id="calGrid">
          <!-- filled by JS -->
        </div>
      </div>

      <!-- Time slots -->
      <div class="panel slots-panel" id="slotsPanel">
        <div class="slots-placeholder" id="slotsPlaceholder">
          <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
          </svg>
          Kies eerst een datum in de agenda
        </div>
        <div id="slotsContent" style="display:none;">
          <div class="slots-date-label" id="slotsDateLabel"></div>
          <div class="slots-grid" id="slotsGrid"></div>
        </div>
      </div>

    </div><!-- /step2-layout -->

    <div class="btn-row">
      <button class="btn btn-ghost" id="btn2prev">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Vorige
      </button>
      <button class="btn btn-next" id="btn2next" disabled>
        Volgende stap
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </button>
    </div>
  </div><!-- /step2 -->


  <!-- ─── STEP 3: GEGEVENS ──────────────────────────────────────── -->
  <div class="step-content" id="step3">
    <div class="panel">
      <div class="summary-bar" id="summaryBar"></div>
      <div class="form-body">
        <div style="display:flex; flex-direction:column; gap:1rem;">
          <div class="frow">
            <div class="field">
              <label>Voornaam *</label>
              <input type="text" id="f-naam" placeholder="Jouw naam" required />
            </div>
            <div class="field">
              <label>Achternaam</label>
              <input type="text" id="f-achternaam" placeholder="Achternaam" />
            </div>
          </div>
          <div class="frow">
            <div class="field">
              <label>E-mailadres *</label>
              <input type="email" id="f-email" placeholder="jou@email.nl" required />
            </div>
            <div class="field">
              <label>Telefoonnummer *</label>
              <input type="tel" id="f-tel" placeholder="06 12 34 56 78" required />
            </div>
          </div>
          <div class="field">
            <label>Opmerkingen (optioneel)</label>
            <textarea id="f-opmerking" placeholder="Bijzondere wensen, haartype, eerder gebruik van producten..."></textarea>
          </div>
        </div>
      </div>
    </div>

    <div class="btn-row">
      <button class="btn btn-ghost" id="btn3prev">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Vorige
      </button>
      <button class="btn btn-confirm" id="btnConfirm">
        Afspraak bevestigen
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
        </svg>
      </button>
    </div>
  </div><!-- /step3 -->


  <!-- ─── SUCCESS ───────────────────────────────────────────────── -->
  <div class="success-screen" id="successScreen">
    <div class="success-icon">
      <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
      </svg>
    </div>
    <h2 class="success-title">Aanvraag ontvangen!</h2>
    <p class="success-sub">
      Anouck heeft jouw aanvraag ontvangen en neemt zo snel mogelijk contact op ter bevestiging.
    </p>
    <div class="success-summary" id="successSummary"></div>
    <a href="/preview/haarstudio-anouck" class="success-back">← Terug naar de website</a>
  </div>

</div><!-- /page -->


{lead?.id && <Tracker leadId={lead.id} />}


<script>
(function () {
  // ── State ────────────────────────────────────────────────────────
  let currentStep = 1;
  let selectedService: { id: string; name: string; dur: number; price: string } | null = null;
  let calYear  = new Date().getFullYear();
  let calMonth = new Date().getMonth();
  let selectedDate: Date | null = null;
  let selectedTime: string | null = null;

  const NL_MONTHS = ['januari','februari','maart','april','mei','juni','juli','augustus','september','oktober','november','december'];
  const NL_DAYS   = ['Ma','Di','Wo','Do','Vr','Za','Zo'];
  const NL_DAYS_FULL = ['maandag','dinsdag','woensdag','donderdag','vrijdag','zaterdag','zondag'];

  // ── Step navigation ───────────────────────────────────────────────
  function goTo(step: number) {
    document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
    (document.getElementById(`step${step}`) as HTMLElement).classList.add('active');
    currentStep = step;
    updateStepper();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateStepper() {
    for (let i = 1; i <= 3; i++) {
      const circle = document.getElementById(`sc${i}`)!;
      const label  = document.getElementById(`sl${i}`)!;
      const line   = document.getElementById(`line${i}`);
      circle.className = 'step-circle' + (i < currentStep ? ' done' : i === currentStep ? ' active' : '');
      circle.textContent = i < currentStep ? '✓' : String(i);
      label.className  = 'step-label'  + (i < currentStep ? ' done' : i === currentStep ? ' active' : '');
      if (line) line.className = 'step-line' + (i < currentStep ? ' done' : '');
    }
  }

  // ── Step 1: Services ─────────────────────────────────────────────
  const serviceRows = document.querySelectorAll<HTMLElement>('.service-row');
  const btn1next    = document.getElementById('btn1next') as HTMLButtonElement;

  serviceRows.forEach(row => {
    row.addEventListener('click', () => {
      serviceRows.forEach(r => r.classList.remove('selected'));
      row.classList.add('selected');
      selectedService = {
        id:    row.dataset.id!,
        name:  row.dataset.name!,
        dur:   parseInt(row.dataset.dur!),
        price: row.dataset.price!,
      };
      btn1next.disabled = false;
    });
  });

  btn1next.addEventListener('click', () => {
    goTo(2);
    renderCalendar();
  });

  // ── Step 2: Calendar ─────────────────────────────────────────────
  function isWorkDay(d: Date) {
    const day = d.getDay(); // 0=Sun
    return day >= 2 && day <= 6; // Tue–Sat
  }

  function isPast(d: Date) {
    const today = new Date(); today.setHours(0,0,0,0);
    return d < today;
  }

  function isTooFarAhead(d: Date) {
    const limit = new Date();
    limit.setDate(limit.getDate() + 60);
    return d > limit;
  }

  function renderCalendar() {
    const label = document.getElementById('calMonthLabel')!;
    label.textContent = `${NL_MONTHS[calMonth]} ${calYear}`;

    const grid = document.getElementById('calGrid')!;
    grid.innerHTML = '';

    // Day-of-week headers (Mon first)
    NL_DAYS.forEach(d => {
      const el = document.createElement('div');
      el.className = 'cal-dow';
      el.textContent = d;
      grid.appendChild(el);
    });

    const today = new Date(); today.setHours(0,0,0,0);
    const firstOfMonth = new Date(calYear, calMonth, 1);
    // JS: 0=Sun, we want Mon=0
    let startOffset = (firstOfMonth.getDay() + 6) % 7;
    const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();

    for (let i = 0; i < startOffset; i++) {
      const el = document.createElement('div');
      el.className = 'cal-day empty';
      grid.appendChild(el);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(calYear, calMonth, day);
      const el   = document.createElement('div');
      const isT  = date.toDateString() === today.toDateString();

      let cls = 'cal-day';
      const past     = isPast(date) && !isT;
      const work     = isWorkDay(date);
      const tooFar   = isTooFarAhead(date);
      const avail    = work && !past && !tooFar;

      if (isT) cls += ' today';
      if (!avail) cls += past ? ' past' : tooFar ? ' closed' : ' closed';
      else cls += ' available';

      if (selectedDate && date.toDateString() === selectedDate.toDateString()) cls += ' selected';

      el.className = cls;
      el.textContent = String(day);

      if (avail) {
        el.addEventListener('click', () => selectDate(date));
      }
      grid.appendChild(el);
    }

    // Prev button: disable if showing current month
    const prevBtn = document.getElementById('calPrev') as HTMLButtonElement;
    const now = new Date();
    prevBtn.disabled = calYear === now.getFullYear() && calMonth === now.getMonth();
  }

  function selectDate(date: Date) {
    selectedDate = date;
    selectedTime = null;
    (document.getElementById('btn2next') as HTMLButtonElement).disabled = true;
    renderCalendar();
    renderSlots();
  }

  function renderSlots() {
    const placeholder = document.getElementById('slotsPlaceholder')!;
    const content     = document.getElementById('slotsContent')!;
    const dateLabel   = document.getElementById('slotsDateLabel')!;
    const grid        = document.getElementById('slotsGrid')!;

    if (!selectedDate) {
      placeholder.style.display = 'flex';
      content.style.display = 'none';
      return;
    }

    placeholder.style.display = 'none';
    content.style.display = 'block';

    const dow = (selectedDate.getDay() + 6) % 7; // Mon=0
    dateLabel.textContent = `${NL_DAYS_FULL[dow]} ${selectedDate.getDate()} ${NL_MONTHS[selectedDate.getMonth()]}`;

    const dur   = selectedService!.dur;
    const start = 9 * 60;
    const end   = 17 * 60 - dur;
    const now   = new Date();
    const isToday = selectedDate.toDateString() === now.toDateString();

    grid.innerHTML = '';

    for (let m = start; m <= end; m += 30) {
      const h   = Math.floor(m / 60);
      const min = m % 60;
      const timeStr = `${String(h).padStart(2,'0')}:${String(min).padStart(2,'0')}`;

      // Deterministic "taken" simulation
      const seed = selectedDate.getDate() * 3 + selectedDate.getMonth() * 7 + h * 11 + Math.floor(min / 30) * 5;
      const taken = seed % 9 < 3; // ~33% taken

      // Past time today?
      const pastTime = isToday && (h < now.getHours() || (h === now.getHours() && min <= now.getMinutes()));

      const btn = document.createElement('button');
      btn.className = 'slot-btn ' + (taken || pastTime ? 'taken' : 'available');
      btn.textContent = timeStr;
      btn.disabled = taken || pastTime;

      if (!taken && !pastTime) {
        btn.addEventListener('click', () => {
          document.querySelectorAll<HTMLElement>('.slot-btn.selected').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          selectedTime = timeStr;
          (document.getElementById('btn2next') as HTMLButtonElement).disabled = false;
        });
      }

      // Re-select if previously picked
      if (selectedTime === timeStr && !taken && !pastTime) {
        btn.classList.add('selected');
      }

      grid.appendChild(btn);
    }
  }

  document.getElementById('calPrev')!.addEventListener('click', () => {
    const now = new Date();
    if (calYear === now.getFullYear() && calMonth === now.getMonth()) return;
    calMonth--;
    if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendar();
  });

  document.getElementById('calNext')!.addEventListener('click', () => {
    calMonth++;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendar();
  });

  document.getElementById('btn2prev')!.addEventListener('click', () => goTo(1));
  document.getElementById('btn2next')!.addEventListener('click', () => {
    buildSummaryBar();
    goTo(3);
  });

  // ── Step 3: Summary + confirm ─────────────────────────────────────
  function fmtDate(d: Date) {
    const dow = (d.getDay() + 6) % 7;
    return `${NL_DAYS_FULL[dow]} ${d.getDate()} ${NL_MONTHS[d.getMonth()]} ${d.getFullYear()}`;
  }

  function buildSummaryBar() {
    const bar = document.getElementById('summaryBar')!;
    bar.innerHTML = `
      <div class="summary-chip"><strong>${selectedService!.name}</strong></div>
      <div class="summary-chip"><strong>${fmtDate(selectedDate!)}</strong></div>
      <div class="summary-chip"><strong>${selectedTime}</strong></div>
      <div class="summary-price">€ ${parseFloat(selectedService!.price).toFixed(2).replace('.',',')}</div>
    `;
  }

  document.getElementById('btn3prev')!.addEventListener('click', () => goTo(2));

  document.getElementById('btnConfirm')!.addEventListener('click', async () => {
    const naam  = (document.getElementById('f-naam')  as HTMLInputElement).value.trim();
    const email = (document.getElementById('f-email') as HTMLInputElement).value.trim();
    const tel   = (document.getElementById('f-tel')   as HTMLInputElement).value.trim();

    if (!naam || !email || !tel) {
      alert('Vul je naam, e-mailadres en telefoonnummer in.');
      return;
    }

    const btn = document.getElementById('btnConfirm') as HTMLButtonElement;
    btn.textContent = 'Versturen...';
    btn.disabled = true;

    await new Promise(r => setTimeout(r, 800));

    // Hide all steps
    document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
    document.getElementById('stepper')!.style.display = 'none';
    (document.querySelector('.page-title') as HTMLElement).style.display = 'none';
    (document.querySelector('.page-sub')  as HTMLElement).style.display = 'none';

    // Build success summary
    const achternaam = (document.getElementById('f-achternaam') as HTMLInputElement).value.trim();
    const fullName   = [naam, achternaam].filter(Boolean).join(' ');
    const successSummary = document.getElementById('successSummary')!;
    successSummary.innerHTML = `
      <div class="success-row"><span class="success-row-label">Naam</span><span class="success-row-val">${fullName}</span></div>
      <div class="success-row"><span class="success-row-label">Dienst</span><span class="success-row-val">${selectedService!.name}</span></div>
      <div class="success-row"><span class="success-row-label">Datum</span><span class="success-row-val">${fmtDate(selectedDate!)}</span></div>
      <div class="success-row"><span class="success-row-label">Tijd</span><span class="success-row-val">${selectedTime}</span></div>
      <div class="success-row"><span class="success-row-label">Prijs</span><span class="success-row-val">v.a. € ${parseFloat(selectedService!.price).toFixed(2).replace('.',',')}</span></div>
    `;

    document.getElementById('successScreen')!.classList.add('on');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

})();
</script>

</body>
</html>
