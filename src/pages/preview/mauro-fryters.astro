<!-- ── URGENCY BAR (bottom) ──────────────────────────────────────────── -->
<div id="urgency">
  <span class="urgency-text">
    <strong>Exclusief voorstel</strong> — Dit ontwerp is persoonlijk gemaakt voor Mauro Fryters
  </span>
  <button class="urgency-close" id="urgency-close" aria-label="Sluiten">×</button>
</div>

{lead?.id && <Tracker leadId={lead.id} />}

<script>
  (function () {
    const nav     = document.getElementById('nav') as HTMLElement;
    const urgency = document.getElementById('urgency') as HTMLElement;
    const closeBtn = document.getElementById('urgency-close');

    // Nav solid on scroll
    function onScroll() {
      nav?.classList.toggle('solid', window.scrollY > 60);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Urgency bar after 3s
    setTimeout(() => urgency?.classList.add('visible'), 3000);
    closeBtn?.addEventListener('click', () => urgency?.classList.remove('visible'));

    // Reveal on scroll
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.r').forEach(el => io.observe(el));
  })();
</script>

