          <input type="text" id="f-naam" name="naam" placeholder="Jouw naam" required />
        </div>
        <div class="form-field">
          <label for="f-email">E-mail</label>
          <input type="email" id="f-email" name="email" placeholder="jouw@email.nl" required />
        </div>
        <div class="form-field">
          <label for="f-tel">Telefoon</label>
          <input type="tel" id="f-tel" name="telefoon" placeholder="+31 6 ..." />
        </div>
        <div class="form-field">
          <label for="f-type">Type evenement</label>
          <select id="f-type" name="type">
            <option value="">Kies een type...</option>
            <option>Privéfeest</option>
            <option>Bruiloft</option>
            <option>Bedrijfsevenement</option>
            <option>Horeca-optreden</option>
            <option>Anders</option>
          </select>
        </div>
        <div class="form-field full">
          <label for="f-datum">Gewenste datum</label>
          <input type="text" id="f-datum" name="datum" placeholder="bijv. 14 juni 2026" />
        </div>
        <div class="form-field full">
          <label for="f-bericht">Bericht</label>
