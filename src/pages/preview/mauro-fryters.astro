<!-- ── SETLIST ───────────────────────────────────────────────────────── -->
<section id="setlist">
  <div class="setlist-inner">
    <div class="setlist-head r">
      <span class="lbl">Repertoire</span>
      <h2 class="setlist-title">Wat hij speelt</h2>
    </div>

    <div class="setlist-item r">
      <div class="s-num">01</div>
      <div>
        <div class="s-name">Nederlandstalig</div>
        <p class="s-desc">Eigentijdse Nederlandse hits en bekende nummers, herkenbaar, meezingbaar en vol sfeer. Er is veel vraag naar en Mauro weet precies waarom: het werkt direct.</p>
