---
import Layout from '../../layouts/Layout.astro';
import Tracker from '../../components/Tracker.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'mauro-fryters')
  .maybeSingle();

if (lead?.id) {
  try { await supabaseAdmin.rpc('increment_view_count', { lead_id_param: lead.id }); } catch (_) {}
}

// Tijdelijke stockfoto's — vervangen zodra Mauro eigen foto's aanlevert
const imgHero      = 'https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&w=1920&q=85';
const imgPortrait  = 'https://images.unsplash.com/photo-1516280440614-37939bbacd81?auto=format&fit=crop&w=900&q=85';
const imgStage     = 'https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?auto=format&fit=crop&w=1920&q=85';
---

<Layout
  title="Mauro Fryters | Zanger"
  description="Mauro Fryters — zanger uit Zandvoort. Nederlandstalige pop en tijdloze klassiekers."
  primaryColor="#D4A84B"
  secondaryColor="#0D0C09"
  ogImage={imgHero}
>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: #0D0C09;
    color: #F0E6CC;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  ::selection { background: #D4A84B; color: #0D0C09; }
</style>

<style>
  /* ── Tokens ────────────────────────────────────── */
  :root {
    --gold:    #D4A84B;
    --gold-20: rgba(212,168,75,.20);
    --gold-08: rgba(212,168,75,.08);
    --ink:     #0D0C09;
    --ink2:    #191710;
    --cream:   #F0E6CC;
    --muted:   rgba(240,230,204,.55);
    --faint:   rgba(240,230,204,.28);
  }

  /* ── Typography ────────────────────────────────── */
  .serif  { font-family: 'Playfair Display', Georgia, serif; }
  .label  {
    font-size: .65rem; font-weight: 600;
    letter-spacing: .28em; text-transform: uppercase;
    color: var(--gold);
  }

  /* ── Nav ───────────────────────────────────────── */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    padding: 1.5rem 3rem;
    display: flex; align-items: center; justify-content: space-between;
    transition: background .4s, backdrop-filter .4s, padding .4s;
  }
  #nav.solid {
    background: rgba(13,12,9,.95);
    backdrop-filter: blur(16px);
    padding-top: 1rem; padding-bottom: 1rem;
    border-bottom: 1px solid rgba(212,168,75,.12);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem; font-weight: 700;
    color: var(--cream); letter-spacing: .04em;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links { display: flex; gap: 2.5rem; }
  .nav-links a {
    font-size: .8rem; font-weight: 500; color: var(--muted);
    text-decoration: none; letter-spacing: .04em;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--cream); }
  .nav-cta {
    font-size: .75rem; font-weight: 600;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--gold); text-decoration: none;
    border: 1px solid rgba(212,168,75,.4);
    padding: .6rem 1.4rem; border-radius: 2px;
    transition: background .2s, color .2s;
  }
  .nav-cta:hover { background: var(--gold); color: var(--ink); }

  /* ── Hero ──────────────────────────────────────── */
  #hero {
    position: relative; min-height: 100svh;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 0 3rem 5rem;
    overflow: hidden;
  }
  #hero-bg {
    position: absolute; inset: 0;
    background: var(--ink);
    overflow: hidden;
  }
  #hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    opacity: .55;
    transform: scale(1.06);
    animation: slowZoom 24s ease-in-out infinite alternate;
  }
  #hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background:
      linear-gradient(to top,  rgba(13,12,9,1) 0%, rgba(13,12,9,.5) 40%, transparent 80%),
      linear-gradient(to right, rgba(13,12,9,.6) 0%, transparent 55%);
  }
  @keyframes slowZoom { from { transform:scale(1.06); } to { transform:scale(1.14); } }

  .hero-content { position: relative; z-index: 2; max-width: 1160px; width: 100%; }
  .hero-eyebrow { margin-bottom: 1.25rem; }

  .hero-name {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    line-height: .9;
    color: var(--cream);
    font-size: clamp(5.5rem, 14vw, 13rem);
    letter-spacing: -.02em;
  }
  .hero-name .thin {
    display: block;
    font-weight: 400;
    font-style: italic;
    color: var(--gold);
    font-size: clamp(3rem, 8vw, 7.5rem);
    margin-top: .1em;
  }

  .hero-meta {
    margin-top: 2.5rem;
    display: flex; align-items: center; gap: 2rem;
    flex-wrap: wrap;
  }
  .hero-tag {
    font-size: .8rem; color: var(--muted); letter-spacing: .08em;
  }
  .hero-sep { width: 40px; height: 1px; background: var(--gold); opacity: .45; }

  .hero-actions { margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    font-size: .8rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
    background: var(--gold); color: var(--ink); text-decoration: none;
    padding: 1rem 2.5rem; border-radius: 2px;
    transition: opacity .2s, transform .2s;
  }
  .btn-primary:hover { opacity: .88; transform: translateY(-2px); }
  .btn-ghost {
    font-size: .8rem; font-weight: 500; color: var(--muted); text-decoration: none;
    padding: 1rem 2rem; border: 1px solid var(--faint); border-radius: 2px;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--muted); color: var(--cream); }

  .hero-scroll {
    position: absolute; bottom: 2rem; right: 3rem; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: .5rem;
    color: var(--faint); font-size: .6rem; letter-spacing: .2em; text-transform: uppercase;
  }
  .scroll-line {
    width: 1px; height: 3rem;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%,100% { opacity: .4; transform: scaleY(1); }
    50%      { opacity: 1;  transform: scaleY(1.1); }
  }

  /* ── Intro strip ───────────────────────────────── */
  #intro {
    background: var(--gold);
    padding: 4rem 3rem;
    text-align: center;
  }
  .intro-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.8rem);
    font-style: italic;
    color: var(--ink);
    max-width: 900px;
    margin: 0 auto;
    line-height: 1.4;
  }

  /* ── Over ──────────────────────────────────────── */
  #over {
    background: var(--ink2);
    display: grid;
    grid-template-columns: 5fr 4fr;
    min-height: 90vh;
  }
  .over-photo {
    position: relative;
    overflow: hidden;
  }
  .over-photo img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    filter: sepia(.25) contrast(1.05);
    transition: transform .9s ease;
  }
  .over-photo:hover img { transform: scale(1.03); }
  .over-photo::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to right, transparent 60%, var(--ink2) 100%);
  }

  .over-text {
    padding: 6rem 4rem 6rem 3.5rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .over-quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-style: italic;
    color: var(--gold);
    line-height: 1.35;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--gold-20);
  }
  .over-bio p {
    font-size: .95rem; line-height: 1.85;
    color: var(--muted); margin-bottom: 1.25rem;
  }
  .over-bio p:last-child { margin-bottom: 0; }
  .over-link {
    margin-top: 2.5rem;
    display: inline-flex; align-items: center; gap: .6rem;
    font-size: .78rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
    color: var(--gold); text-decoration: none;
    transition: gap .2s;
  }
  .over-link:hover { gap: 1rem; }

  /* ── Setlist ───────────────────────────────────── */
  #setlist {
    background: var(--ink);
    padding: 7rem 3rem;
  }
  .setlist-head {
    max-width: 1160px; margin: 0 auto 4rem;
    display: flex; align-items: baseline; gap: 2rem;
  }
  .setlist-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700; color: var(--cream);
  }
  .setlist-items { max-width: 1160px; margin: 0 auto; }

  .setlist-item {
    border-top: 1px solid rgba(240,230,204,.08);
    padding: 2.5rem 0;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    align-items: start;
    transition: background .2s;
    cursor: default;
  }
  .setlist-item:last-child { border-bottom: 1px solid rgba(240,230,204,.08); }
  .setlist-item:hover { background: var(--gold-08); margin: 0 -3rem; padding-left: 3rem; padding-right: 3rem; }
  .setlist-num {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem; font-weight: 900;
    color: rgba(240,230,204,.07);
    line-height: 1; letter-spacing: -.02em;
    margin-top: -.4rem;
    transition: color .2s;
  }
  .setlist-item:hover .setlist-num { color: rgba(212,168,75,.2); }
  .setlist-body { padding-top: .4rem; }
  .setlist-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 700; color: var(--cream);
    margin-bottom: .6rem;
  }
  .setlist-desc { font-size: .88rem; color: var(--muted); line-height: 1.7; max-width: 560px; }
  .setlist-badge {
    display: inline-block;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold); border: 1px solid var(--gold-20);
    padding: .25rem .7rem; border-radius: 2px; margin-top: .8rem;
  }

  /* ── Optredens ─────────────────────────────────── */
  #optredens {
    background: var(--ink2);
    padding: 7rem 3rem;
  }
  .optredens-inner { max-width: 1160px; margin: 0 auto; }
  .optredens-head { margin-bottom: 4rem; }
  .optredens-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700; color: var(--cream);
  }

  .venue-row {
    border-top: 1px solid rgba(240,230,204,.08);
    padding: 2rem 0;
    display: flex; align-items: center; gap: 2rem;
    transition: padding .2s;
  }
  .venue-row:last-child { border-bottom: 1px solid rgba(240,230,204,.08); }
  .venue-row:hover { padding-left: 1.5rem; }
  .venue-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold); flex-shrink: 0;
    transition: box-shadow .2s;
  }
  .venue-row:hover .venue-dot { box-shadow: 0 0 10px var(--gold); }
  .venue-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-weight: 700; color: var(--cream);
    flex: 1;
  }
  .venue-city { font-size: .85rem; color: var(--muted); }
  .venue-tag {
    font-size: .6rem; font-weight: 700;
    letter-spacing: .15em; text-transform: uppercase;
    color: var(--gold); border: 1px solid var(--gold-20);
    padding: .3rem .8rem; border-radius: 2px;
    white-space: nowrap;
  }

  /* ── Quote ─────────────────────────────────────── */
  #quote {
    position: relative;
    min-height: 70vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    padding: 7rem 3rem;
  }
  #quote-bg {
    position: absolute; inset: 0;
  }
  #quote-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    filter: brightness(.35) sepia(.5);
  }
  #quote-bg::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(13,12,9,.72);
  }
  .quote-inner {
    position: relative; z-index: 2;
    max-width: 900px; text-align: center;
  }
  .quote-mark {
    font-family: 'Playfair Display', serif;
    font-size: 8rem; line-height: .6;
    color: var(--gold); opacity: .3;
    margin-bottom: 1.5rem;
  }
  .quote-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 3rem);
    font-style: italic;
    color: var(--cream);
    line-height: 1.45;
    margin-bottom: 2.5rem;
  }
  .quote-stats {
    display: flex; justify-content: center; gap: 4rem; flex-wrap: wrap;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(212,168,75,.2);
  }
  .stat-val {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem; font-weight: 700;
    color: var(--gold); display: block; margin-bottom: .25rem;
  }
  .stat-lbl {
    font-size: .65rem; color: var(--faint);
    letter-spacing: .2em; text-transform: uppercase;
  }

  /* ── Contact ───────────────────────────────────── */
  #contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }
  .contact-left {
    background: var(--gold);
    padding: 6rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .contact-left-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 900;
    color: var(--ink); line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .contact-left-sub {
    font-size: .95rem; color: rgba(13,12,9,.65);
    line-height: 1.7; max-width: 360px;
    margin-bottom: 2.5rem;
  }
  .contact-left-link {
    display: inline-flex; align-items: center; gap: .6rem;
    font-size: .8rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--ink); text-decoration: none;
    transition: gap .2s;
  }
  .contact-left-link:hover { gap: 1rem; }

  .contact-right {
    background: var(--ink2);
    padding: 6rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .contact-right-label { margin-bottom: 2.5rem; }
  .contact-items { display: flex; flex-direction: column; gap: 1.75rem; margin-bottom: 3rem; }
  .contact-item { display: flex; align-items: flex-start; gap: 1.25rem; }
  .contact-icon {
    width: 40px; height: 40px; border-radius: 6px;
    background: var(--gold-08); border: 1px solid var(--gold-20);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    color: var(--gold);
  }
  .contact-item-text .sub { font-size: .7rem; color: var(--faint); margin-bottom: .2rem; }
  .contact-item-text .val { font-size: .95rem; font-weight: 600; color: var(--cream); }
  .contact-item-text a { text-decoration: none; color: inherit; transition: color .2s; }
  .contact-item-text a:hover { color: var(--gold); }

  .contact-checklist { list-style: none; display: flex; flex-direction: column; gap: .85rem; margin-bottom: 2.5rem; }
  .contact-checklist li {
    display: flex; align-items: center; gap: .75rem;
    font-size: .88rem; color: var(--muted);
  }
  .check { color: var(--gold); flex-shrink: 0; }

  .btn-book {
    font-size: .78rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    background: var(--gold); color: var(--ink); text-decoration: none;
    padding: 1.1rem 2rem; border-radius: 2px;
    text-align: center;
    transition: opacity .2s, transform .2s;
    display: block;
  }
  .btn-book:hover { opacity: .88; transform: translateY(-2px); }

  /* ── Footer ────────────────────────────────────── */
  footer {
    background: var(--ink);
    border-top: 1px solid rgba(212,168,75,.1);
    padding: 2rem 3rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1rem; font-weight: 700;
    color: var(--cream); letter-spacing: .04em;
  }
  .footer-logo span { color: var(--gold); }
  .footer-copy { font-size: .7rem; color: var(--faint); letter-spacing: .06em; }

  /* ── Urgency bar ───────────────────────────────── */
  #urgency {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 60;
    background: rgba(13,12,9,.95);
    border-top: 1px solid rgba(212,168,75,.18);
    backdrop-filter: blur(12px);
    padding: .75rem 3rem;
    display: flex; align-items: center; justify-content: space-between;
    transform: translateY(100%);
    transition: transform .4s ease;
  }
  #urgency.visible { transform: translateY(0); }
  .urgency-text { font-size: .7rem; color: var(--muted); }
  .urgency-text strong { color: var(--gold); }
  .urgency-close {
    background: none; border: none; cursor: pointer;
    color: var(--faint); font-size: 1.2rem; padding: 0 .5rem;
    transition: color .2s;
  }
  .urgency-close:hover { color: var(--cream); }

  /* ── Reveal ────────────────────────────────────── */
  .r { opacity: 0; transform: translateY(28px); transition: opacity .9s ease, transform .9s ease; }
  .r.in { opacity: 1; transform: none; }
  .r2 { transition-delay: .15s; }
  .r3 { transition-delay: .28s; }
  .r4 { transition-delay: .42s; }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 768px) {
    #nav { padding: 1.2rem 1.5rem; }
    #nav .nav-links { display: none; }
    #hero { padding: 0 1.5rem 4rem; }
    .hero-scroll { right: 1.5rem; }
    #intro { padding: 3rem 1.5rem; }
    #over { grid-template-columns: 1fr; }
    .over-photo { height: 60vw; }
    .over-text { padding: 3rem 1.5rem; }
    #setlist { padding: 5rem 1.5rem; }
    .setlist-item:hover { margin: 0 -1.5rem; padding-left: 1.5rem; padding-right: 1.5rem; }
    #optredens { padding: 5rem 1.5rem; }
    #quote { padding: 5rem 1.5rem; }
    #contact { grid-template-columns: 1fr; }
    .contact-left, .contact-right { padding: 4rem 1.5rem; }
    footer { padding: 1.5rem; flex-direction: column; gap: 1rem; text-align: center; }
    #urgency { padding: .75rem 1.5rem; }
  }
</style>

<!-- ── NAV ──────────────────────────────────────────────────────────── -->
<nav id="nav">
  <a href="#" class="nav-logo">Mauro <span>Fryters</span></a>
  <div class="nav-links">
    <a href="#over">Over Mauro</a>
    <a href="#setlist">Repertoire</a>
    <a href="#optredens">Optredens</a>
    <a href="#contact">Contact</a>
  </div>
  <a href="#contact" class="nav-cta" data-track="nav_cta">Boek Mauro</a>
</nav>

<!-- ── HERO ─────────────────────────────────────────────────────────── -->
<section id="hero">
  <div id="hero-bg">
    <img src={imgHero} alt="Mauro Fryters live" loading="eager" />
  </div>

  <div class="hero-content r">
    <div class="hero-eyebrow">
      <span class="label">Zanger · Zandvoort · Noord-Holland</span>
    </div>

    <h1 class="hero-name">
      Mauro
      <em class="thin">Fryters</em>
    </h1>

    <div class="hero-meta">
      <span class="hero-tag">Nederlandstalige pop</span>
      <span class="hero-sep"></span>
      <span class="hero-tag">Engelstalige klassiekers</span>
      <span class="hero-sep"></span>
      <span class="hero-tag">Live · 2 uur repertoire</span>
    </div>

    <div class="hero-actions">
      <a href="#contact" class="btn-primary" data-track="hero_cta">Boek Mauro</a>
      <a href="#over" class="btn-ghost">Meer over hem</a>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ── INTRO STRIP ───────────────────────────────────────────────────── -->
<section id="intro">
  <p class="intro-text r">
    "Van een spontane microfoongreep op een voetbaltoernooi tot vaste podia door de regio — Mauro Fryters brengt altijd de juiste sfeer."
  </p>
</section>

<!-- ── OVER MAURO ────────────────────────────────────────────────────── -->
<section id="over">
  <div class="over-photo">
    <img src={imgPortrait} alt="Mauro Fryters" loading="lazy" />
  </div>

  <div class="over-text">
    <span class="label r" style="margin-bottom:2rem; display:block;">Over Mauro</span>

    <p class="over-quote r r2">
      "Ik deed het in het begin voor de lol — en ineens stond ik op een podium."
    </p>

    <div class="over-bio r r3">
      <p>
        Mauro Fryters (28) groeide op in Zandvoort en werd zanger op de meest Zandvoortse manier die denkbaar is: door spontaan een microfoon te grijpen op een voetbaltoernooi bij SV Zandvoort. Wat begon als een spontaan moment groeide uit tot serieuze ambitie.
      </p>
      <p>
        Inmiddels werkt hij aan zijn stem met vocal coach Marcel Swerissen en staat hij regelmatig op podia in de regio — van intieme brasseries tot open festivals. In 2026 schrijft hij zijn eerste eigen nummers.
      </p>
    </div>

