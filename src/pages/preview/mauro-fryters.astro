        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
      </svg>
      <p><strong>Aanvraag ontvangen!</strong><br/>Mauro neemt zo snel mogelijk contact met je op.</p>
    </div>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────────────────────────── -->
<footer>
  <a href="#" class="logo-wrap" style="text-decoration:none;">
    <svg class="logo-badge" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" style="color:#C8922A; width:32px; height:32px;">
      <circle cx="24" cy="24" r="22.5" stroke="currentColor" stroke-width="1.5"/>
      <text x="24" y="30" text-anchor="middle" font-family="'Playfair Display', Georgia, serif" font-size="17" font-weight="700" fill="currentColor" letter-spacing="-.5">MF</text>
    </svg>
    <div class="logo-text-wrap">
      <span class="logo-first" style="font-size:1rem; color:rgba(245,239,230,.7);">Mauro Fryters</span>
    </div>
  </a>
  <span class="f-copy">Exclusief voorstel · Niet publiekelijk vindbaar</span>
</footer>

{lead?.id && <Tracker leadId={lead.id} />}

<script>
  (function () {
    // Nav sticky + leesbaar bij scrollen
    const nav = document.getElementById('nav') as HTMLElement;
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('scrolled', window.scrollY > 70);
    }, { passive: true });

    // Reveal on scroll
    const io = new IntersectionObserver(
      es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.r').forEach(el => io.observe(el));

    // Booking form submit
    const bookForm = document.getElementById('book-form') as HTMLFormElement | null;
    const formSuccess = document.getElementById('form-success') as HTMLElement | null;
    bookForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = bookForm.querySelector('.btn-submit') as HTMLButtonElement | null;
      if (btn) { btn.textContent = 'Versturen...'; btn.disabled = true; }
      await new Promise(r => setTimeout(r, 700));
      bookForm.style.display = 'none';
      if (formSuccess) formSuccess.style.display = 'block';
    });

    // Zwevende gouden deeltjes genereren
    const container = document.getElementById('particles');
    if (container) {
      const count = 18;
      for (let i = 0; i < count; i++) {
        const p = document.createElement('div');
        p.className = 'p';
        const size = Math.random() * 5 + 2;
        p.style.cssText = `
          width: ${size}px;
          height: ${size}px;
          left: ${Math.random() * 55}%;
          bottom: ${Math.random() * 20}%;
          animation-duration: ${Math.random() * 8 + 6}s;
          animation-delay: ${Math.random() * 8}s;
          opacity: 0;
        `;
        container.appendChild(p);
      }
    }
  })();
</script>

</Layout>
