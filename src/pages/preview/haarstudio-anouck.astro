---
import Tracker from '../../components/Tracker.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'haarstudio-anouck')
  .maybeSingle();

if (lead?.id) {
  try { await supabaseAdmin.rpc('increment_view_count', { lead_id_param: lead.id }); } catch (_) {}
}

const imgPortrait = '/images/haarstudio-anouck/anouck.jpg';
const imgSalon    = '/images/haarstudio-anouck/salon.jpg';
const imgLogo     = '/images/haarstudio-anouck/logo.jpg';
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Haarstudio Anouck — persoonlijke haarstudio voor knippen, kleuren en styling op maat." />
  <meta name="robots" content="noindex, nofollow" />
  <title>Haarstudio Anouck | OnlineKoers voorstel</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,300;0,500;0,700;0,800;0,900;1,300;1,700;1,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: hidden; }
    body { overflow-x: hidden; }

    :root {
      --black:   #0E0C0C;
      --black2:  #1A1617;
      --white:   #FAFAF8;
      --off:     #F3EEEB;
      --rose:    #C4827F;
      --rose-d:  #A8605D;
      --rose-bg: #F2C5C3;
      --muted-l: rgba(250,250,248,.5);
      --muted-d: rgba(14,12,12,.5);
      --border-l: rgba(250,250,248,.1);
      --border-d: rgba(14,12,12,.1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--white);
      color: var(--black);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .display { font-family: 'Barlow Condensed', sans-serif; }
    .wrap    { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem); }

    /* ── Reveal ───────────────────────────────── */
    .r { opacity: 0; transform: translateY(28px); transition: opacity .75s cubic-bezier(.2,.8,.2,1), transform .75s cubic-bezier(.2,.8,.2,1); }
    .r.on { opacity: 1; transform: none; }
    .d1{transition-delay:.1s} .d2{transition-delay:.2s} .d3{transition-delay:.32s}

    /* ── Label ────────────────────────────────── */
    .lbl {
      display: inline-block;
      font-size: .58rem; font-weight: 700;
      letter-spacing: .3em; text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 1.25rem;
    }
    .lbl-light { color: var(--rose-bg); }

    /* ══════════════════════════════════════════
       NAV
    ══════════════════════════════════════════ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 400;
      padding: 0;
      transition: background .35s, box-shadow .35s;
    }
    .nav.s {
      background: rgba(14,12,12,.97);
      box-shadow: 0 1px 0 rgba(255,255,255,.06);
    }
    .nav-inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      height: 72px;
      border-bottom: 1px solid rgba(255,255,255,.08);
      transition: border-color .35s;
    }
    .nav.s .nav-inner { border-color: transparent; }

    .nav-logo {
      display: flex; align-items: center; gap: .65rem;
      text-decoration: none;
    }
    .nav-logo img {
      height: 38px; width: 38px;
      border-radius: 50%; object-fit: cover;
      border: 1px solid rgba(255,255,255,.15);
    }
    .nav-logo-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--white); line-height: 1;
    }
    .nav-logo-sub {
      display: block; font-family: 'DM Sans', sans-serif;
      font-size: .5rem; font-weight: 500;
      letter-spacing: .22em; text-transform: uppercase;
      color: var(--rose-bg); margin-top: 2px;
    }

    .nav-links {
      display: flex; align-items: center; gap: 2.5rem;
      justify-content: center;
    }
    .nav-link {
      font-size: .68rem; font-weight: 500;
      letter-spacing: .1em; text-transform: uppercase;
      color: rgba(250,250,248,.55); text-decoration: none;
      transition: color .2s;
    }
    .nav-link:hover { color: var(--white); }

    .nav-right {
      display: flex; align-items: center; gap: 1.25rem; justify-content: flex-end;
    }
    .nav-phone {
      font-size: .7rem; color: rgba(250,250,248,.4);
      text-decoration: none; transition: color .2s;
      display: flex; align-items: center; gap: .4rem;
    }
    .nav-phone:hover { color: var(--white); }
    .nav-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .8rem; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase;
      background: var(--rose); color: var(--white);
      padding: .6rem 1.5rem; border-radius: 2px;
      text-decoration: none; transition: background .2s;
      white-space: nowrap;
    }
    .nav-cta:hover { background: var(--rose-d); }

    .nav-toggle {
      display: none; background: none; border: none;
      cursor: pointer; color: var(--white); padding: .25rem;
    }

    /* Mobile overlay */
    .nav-overlay {
      position: fixed; inset: 0;
      background: var(--black2); z-index: 450;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 2.5rem;
      transform: translateX(100%);
      transition: transform .45s cubic-bezier(.2,.8,.2,1);
    }
    .nav-overlay.on { transform: none; }
    .nav-overlay .nav-link {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2.2rem; font-weight: 700; letter-spacing: .1em;
      color: rgba(250,250,248,.6);
    }
    .nav-overlay .nav-link:hover { color: var(--white); }
    .nav-overlay .nav-cta { font-size: 1rem; padding: .9rem 2.5rem; }
    .nav-overlay-close {
      position: absolute; top: 1.1rem; right: 1.1rem;
      background: none; border: 1px solid rgba(255,255,255,.12);
      border-radius: 2px; width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--white); transition: all .2s;
    }
    .nav-overlay-close:hover { background: var(--rose); border-color: var(--rose); }

    /* ══════════════════════════════════════════
       HERO
    ══════════════════════════════════════════ */
    .hero {
      height: 100svh; min-height: 640px;
      display: grid; grid-template-columns: 1fr 1fr;
      background: var(--black);
      position: relative; overflow: hidden;
    }

    .hero-left {
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 10rem clamp(2rem, 4vw, 5rem) 5rem clamp(1.5rem, max(3vw, calc((100vw - 1200px)/2 + 4rem)), 10rem);
      position: relative; z-index: 2;
    }

    .hero-h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(4rem, 8vw, 7.5rem);
      font-weight: 900; line-height: .92;
      letter-spacing: -.01em;
      color: var(--white);
      text-transform: uppercase;
    }
    .hero-h1 em {
      display: block; font-style: italic;
      color: var(--rose-bg); font-weight: 300;
      font-size: .62em; letter-spacing: .03em;
      text-transform: none;
    }

    .hero-sub {
      font-size: .95rem; line-height: 1.7;
      color: var(--muted-l); max-width: 360px;
      margin-top: 2rem; margin-bottom: 2.5rem;
    }
    .hero-btns { display: flex; gap: .85rem; flex-wrap: wrap; }

    .btn {
      display: inline-flex; align-items: center; gap: .5rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .85rem; font-weight: 700;
      letter-spacing: .16em; text-transform: uppercase;
      padding: .85rem 2.2rem; border-radius: 2px;
      text-decoration: none; transition: all .2s; border: none; cursor: pointer;
    }
    .btn-rose  { background: var(--rose); color: var(--white); }
    .btn-rose:hover  { background: var(--rose-d); }
    .btn-outline { border: 1.5px solid rgba(255,255,255,.25); color: var(--white); background: transparent; }
    .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,.05); }
    .btn-dark  { background: var(--black); color: var(--white); }
    .btn-dark:hover  { background: var(--black2); }
    .btn-rose-solid { background: var(--rose); color: var(--white); }
    .btn-rose-solid:hover { background: var(--rose-d); transform: translateY(-1px); }

    /* Scroll indicator */
    .hero-scroll {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .45rem;
      color: rgba(250,250,248,.25); pointer-events: none; z-index: 2;
    }
    .hero-scroll span { font-size: .5rem; letter-spacing: .3em; text-transform: uppercase; }
    .hero-scroll-bar { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--rose), transparent); animation: scpulse 2s ease-in-out infinite; }
    @keyframes scpulse { 0%,100%{opacity:.25} 50%{opacity:.8} }

    /* Photo right */
    .hero-right {
      position: relative; overflow: hidden;
    }
    .hero-right::before {
      content: ''; position: absolute;
      left: 0; top: 0; bottom: 0; width: 100px;
      background: linear-gradient(to right, var(--black), transparent);
      z-index: 1;
    }
    .hero-right img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      display: block; filter: grayscale(15%);
    }
    /* Rose tint overlay */
    .hero-right::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(160deg, rgba(196,130,127,.15), transparent 50%);
      z-index: 2; pointer-events: none;
    }

    /* ══════════════════════════════════════════
       TAGLINE STRIP (zwart, vette quote)
    ══════════════════════════════════════════ */
    .strip {
      background: var(--rose);
      padding: 1rem 0;
      overflow: hidden;
      position: relative;
    }
    .strip-track {
      display: flex; gap: 2rem; white-space: nowrap;
      animation: marquee 18s linear infinite;
    }
    @keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
    .strip-item {
      display: inline-flex; align-items: center; gap: 2rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem; font-weight: 700;
      letter-spacing: .15em; text-transform: uppercase;
      color: var(--white); flex-shrink: 0;
    }
    .strip-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: rgba(255,255,255,.5); flex-shrink: 0;
    }

    /* ══════════════════════════════════════════
       OVER ANOUCK (wit)
    ══════════════════════════════════════════ */
    .about { background: var(--white); padding: 8rem 0; }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; align-items: center; }

    .about-img-wrap { position: relative; }
    .about-img {
      aspect-ratio: 4/5; overflow: hidden; border-radius: 2px;
      background: var(--rose-bg);
    }
    .about-img img {
      width: 100%; height: 100%; object-fit: cover;
      object-position: center top; display: block;
      transition: transform .6s cubic-bezier(.2,.8,.2,1);
    }
    .about-img:hover img { transform: scale(1.03); }
    /* Decoratief hoekje */
    .about-img-wrap::before {
      content: '';
      position: absolute; top: -1.25rem; left: -1.25rem;
      width: 60px; height: 60px;
      border-top: 3px solid var(--rose);
      border-left: 3px solid var(--rose);
    }
    .about-img-wrap::after {
      content: '';
      position: absolute; bottom: -1.25rem; right: -1.25rem;
      width: 60px; height: 60px;
      border-bottom: 3px solid var(--rose);
      border-right: 3px solid var(--rose);
    }

    .about-h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.8rem, 5vw, 4.5rem);
      font-weight: 800; line-height: .95;
      text-transform: uppercase; color: var(--black);
      margin-bottom: 1.75rem; margin-top: .5rem;
    }
    .about-h2 em { font-style: italic; color: var(--rose); font-weight: 300; text-transform: none; }
    .about-p { font-size: .98rem; line-height: 1.82; color: var(--muted-d); margin-bottom: 1rem; }

    .about-socials { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 2rem; }
    .social-pill {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .65rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
      padding: .6rem 1.1rem; border-radius: 2px;
      border: 1.5px solid var(--border-d); color: var(--black);
      text-decoration: none; transition: all .2s;
    }
    .social-pill:hover { border-color: var(--rose); color: var(--rose); }
    .social-pill svg { flex-shrink: 0; }

    /* ══════════════════════════════════════════
       DIENSTEN — KNIPPEN (donker links, foto rechts)
    ══════════════════════════════════════════ */
    .dienst {
      display: grid; grid-template-columns: 1fr 1fr;
      min-height: 600px;
    }
    .dienst-content {
      display: flex; flex-direction: column; justify-content: center;
      padding: 6rem clamp(2rem,4vw,5rem);
    }
    .dienst-content.dark { background: var(--black2); }
    .dienst-content.light { background: var(--off); }

    .dienst-h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(3rem, 5vw, 5rem);
      font-weight: 900; line-height: .92;
      text-transform: uppercase;
      margin-bottom: 2.5rem; margin-top: .5rem;
    }
    .dienst-content.dark .dienst-h2 { color: var(--white); }
    .dienst-content.light .dienst-h2 { color: var(--black); }
    .dienst-h2 em { display:block; font-style:italic; color:var(--rose-bg); font-weight:300; text-transform:none; font-size:.65em; }
    .dienst-content.light .dienst-h2 em { color: var(--rose); }

    /* Prijslijst items */
    .price-list { list-style: none; margin-bottom: 2.5rem; }
    .price-list li {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: .9rem 0; gap: 1rem;
      border-bottom: 1px solid;
    }
    .dienst-content.dark .price-list li { border-color: rgba(255,255,255,.07); }
    .dienst-content.light .price-list li { border-color: rgba(14,12,12,.08); }
    .price-list li:first-child { border-top: 1px solid; }
    .dienst-content.dark .price-list li:first-child { border-color: rgba(255,255,255,.07); }
    .dienst-content.light .price-list li:first-child { border-color: rgba(14,12,12,.08); }

    .price-name {
      font-size: .9rem;
    }
    .dienst-content.dark .price-name { color: rgba(250,250,248,.6); }
    .dienst-content.light .price-name { color: var(--muted-d); }

    .price-amt {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.15rem; font-weight: 700;
      white-space: nowrap; flex-shrink: 0;
    }
    .dienst-content.dark .price-amt { color: var(--rose-bg); }
    .dienst-content.light .price-amt { color: var(--rose); }

    .dienst-note {
      font-size: .72rem; font-style: italic;
    }
    .dienst-content.dark .dienst-note { color: rgba(250,250,248,.25); }
    .dienst-content.light .dienst-note { color: var(--muted-d); }

    /* Dienst foto */
    .dienst-photo {
      position: relative; overflow: hidden;
      background: var(--rose-bg);
    }
    .dienst-photo img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      transition: transform .6s cubic-bezier(.2,.8,.2,1);
    }
    .dienst-photo:hover img { transform: scale(1.04); }

    /* ══════════════════════════════════════════
       SALON — full-bleed foto
    ══════════════════════════════════════════ */
    .salon-section {
      height: 70vh; min-height: 450px;
      position: relative; overflow: hidden;
    }
    .salon-section img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
    }
    .salon-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(14,12,12,.75) 0%, rgba(14,12,12,.1) 50%, transparent 100%);
      display: flex; flex-direction: column;
      justify-content: flex-end;
      padding: 4rem clamp(1.5rem,5vw,5rem);
    }
    .salon-overlay h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.5rem, 5vw, 5rem);
      font-weight: 900; text-transform: uppercase;
      color: var(--white); line-height: .92;
      max-width: 700px;
    }
    .salon-overlay h2 em { font-style:italic; font-weight:300; color:var(--rose-bg); text-transform:none; display:block; }

    /* ══════════════════════════════════════════
       INSTAGRAM CTA STRIP
    ══════════════════════════════════════════ */
    .ig-strip {
      background: var(--off);
      padding: 5rem 0;
      text-align: center;
    }
    .ig-strip-inner { max-width: 680px; margin: 0 auto; }
    .ig-icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 56px; height: 56px; border-radius: 14px;
      background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
      margin-bottom: 1.5rem;
    }
    .ig-h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 800; text-transform: uppercase;
      color: var(--black); margin-bottom: 1rem;
    }
    .ig-p { font-size: .92rem; color: var(--muted-d); line-height: 1.7; margin-bottom: 2rem; }

    /* ══════════════════════════════════════════
       CONTACT (zwart links + form rechts)
    ══════════════════════════════════════════ */
    .contact { display: grid; grid-template-columns: 1fr 1fr; }

    .contact-left {
      background: var(--black2);
      padding: 7rem clamp(2rem,4vw,5rem);
      display: flex; flex-direction: column; justify-content: center;
      position: relative; overflow: hidden;
    }
    .contact-left::before {
      content: '';
      position: absolute; top: -100px; right: -100px;
      width: 350px; height: 350px; border-radius: 50%;
      background: radial-gradient(circle, rgba(196,130,127,.15), transparent 70%);
      pointer-events: none;
    }

    .contact-h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.8rem, 4vw, 4.2rem);
      font-weight: 900; text-transform: uppercase;
      color: var(--white); line-height: .92;
      margin-bottom: 1.5rem; margin-top: .5rem;
    }
    .contact-h2 em { font-style:italic; font-weight:300; color:var(--rose-bg); text-transform:none; display:block; font-size:.7em; }

    .contact-p { font-size: .9rem; color: var(--muted-l); line-height: 1.75; margin-bottom: 2.5rem; }

    .cinfo { display: flex; flex-direction: column; gap: 1rem; }
    .cinfo-item {
      display: flex; align-items: center; gap: .85rem;
      font-size: .88rem; color: var(--muted-l);
    }
    .cinfo-item svg { color: var(--rose-bg); flex-shrink: 0; }
    .cinfo-item a { color: inherit; text-decoration: none; transition: color .2s; }
    .cinfo-item a:hover { color: var(--white); }

    /* Form */
    .contact-right {
      background: var(--white);
      padding: 7rem clamp(2rem,4vw,5rem);
      display: flex; flex-direction: column; justify-content: center;
    }
    .form-h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2rem; font-weight: 800; text-transform: uppercase;
      color: var(--black); margin-bottom: .4rem;
    }
    .form-sub { font-size: .85rem; color: var(--muted-d); margin-bottom: 2rem; line-height: 1.6; }

    .form { display: flex; flex-direction: column; gap: 1rem; }
    .frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: .3rem; }
    .field label { font-size: .58rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--muted-d); }
    .field input, .field select, .field textarea {
      padding: .9rem 1rem; border-radius: 2px;
      border: 1.5px solid var(--border-d);
      background: var(--off); font-family: 'DM Sans', sans-serif;
      font-size: .92rem; color: var(--black); outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 3px rgba(196,130,127,.12);
    }
    .field textarea { resize: vertical; min-height: 100px; }
    .field select { appearance: none; cursor: pointer; }

    .form-btn {
      width: 100%; padding: 1.1rem;
      background: var(--black); color: var(--white);
      border: none; border-radius: 2px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .88rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase;
      cursor: pointer; transition: all .2s; margin-top: .25rem;
    }
    .form-btn:hover { background: var(--rose); }
    .form-btn:disabled { opacity: .4; cursor: not-allowed; }

    .form-success {
      display: none; padding: 3rem 2rem; text-align: center;
      border: 1.5px solid var(--border-d); border-radius: 2px;
      background: var(--off);
    }
    .form-success.on { display: block; }
    .form-success-check {
      width: 52px; height: 52px; border-radius: 50%;
      background: rgba(196,130,127,.12); border: 1.5px solid rgba(196,130,127,.3);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.25rem; color: var(--rose); font-size: 1.2rem;
    }
    .form-success h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2rem; font-weight: 800; text-transform: uppercase; color: var(--black);
    }
    .form-success p { font-size: .88rem; color: var(--muted-d); line-height: 1.7; margin-top: .5rem; }

    /* ══════════════════════════════════════════
       FOOTER
    ══════════════════════════════════════════ */
    .footer {
      background: var(--black);
      border-top: 1px solid rgba(255,255,255,.06);
      padding: 3rem 0 2rem;
    }
    .footer-row {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 1.5rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .footer-logo {
      display: flex; align-items: center; gap: .65rem; text-decoration: none;
    }
    .footer-logo img { height: 34px; width: 34px; border-radius: 50%; object-fit: cover; }
    .footer-logo-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .95rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      color: rgba(250,250,248,.6);
    }
    .footer-links { display: flex; gap: 2rem; flex-wrap: wrap; }
    .footer-link {
      font-size: .65rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
      color: rgba(250,250,248,.3); text-decoration: none; transition: color .2s;
    }
    .footer-link:hover { color: rgba(250,250,248,.8); }
    .footer-copy {
      padding-top: 1.75rem; display: flex; justify-content: space-between;
      flex-wrap: wrap; gap: 1rem;
      font-size: .62rem; color: rgba(250,250,248,.2); letter-spacing: .05em;
    }

    /* ══════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════ */

    /* ── Tablet (≤960px) ──────────────────── */
    @media (max-width: 960px) {
      /* Nav */
      .nav-inner { grid-template-columns: 1fr auto; }
      .nav-links  { display: none; }
      .nav-phone  { display: none; }
      .nav-toggle { display: block; }

      /* Hero */
      .hero { grid-template-columns: 1fr; height: auto; min-height: 100svh; }
      .hero-left  { padding: 8rem 1.75rem 3rem; order: 2; }
      .hero-right { order: 1; height: 52vw; min-height: 260px; }
      .hero-right::before { width: 0; }
      .hero-right::after  { display: none; }
      .hero-scroll { display: none; }

      /* About */
      .about { padding: 5rem 0; }
      .about-grid { grid-template-columns: 1fr; gap: 3rem; }
      .about-img-wrap { max-width: 300px; margin: 0 auto; }

      /* Diensten */
      .dienst { grid-template-columns: 1fr; }
      .dienst-content { padding: 3.5rem 1.75rem; }
      .dienst-photo { aspect-ratio: 16/9; min-height: 220px; }
      .dienst-photo.order-first { order: -1; }

      /* Salon */
      .salon-section { height: 55vw; }
      .salon-overlay { padding: 2.5rem 1.75rem; }

      /* Instagram strip */
      .ig-strip { padding: 4rem 0; }

      /* Contact */
      .contact { grid-template-columns: 1fr; }
      .contact-left  { padding: 4rem 1.75rem; }
      .contact-right { padding: 4rem 1.75rem; }
      .frow { grid-template-columns: 1fr; }

      /* Gallery */
      .gallery { padding: 5rem 0; }

      /* Footer */
      .footer-row { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
      .footer-links { gap: 1.25rem; }
    }

    /* ── Mobile (≤600px) ──────────────────── */
    @media (max-width: 600px) {
      /* Nav */
      .nav-inner { padding: 0 1rem; }
      .nav-logo-sub { display: none; }

      /* Hero */
      .hero-right { height: 62vw; }
      .hero-left  { padding: 7rem 1.25rem 2.5rem; }
      .hero-sub   { font-size: .88rem; }

      /* Strip */
      .strip-item { font-size: .82rem; gap: 1.5rem; }
      .strip-track { gap: 1.5rem; }

      /* About */
      .about { padding: 3.5rem 0; }
      .about-grid { gap: 2rem; }
      .about-img-wrap { max-width: 100%; }
      .about-img-wrap::before,
      .about-img-wrap::after { display: none; }
      .about-p { font-size: .92rem; }
      .about-socials { gap: .5rem; }
      .social-pill { font-size: .6rem; padding: .55rem .9rem; }

      /* Diensten */
      .dienst-content { padding: 2.5rem 1.25rem; }
      .dienst-h2 { font-size: clamp(2.2rem,8vw,3.5rem); }
      .price-list li { padding: .65rem 0; }
      .price-name { font-size: .85rem; }

      /* Salon */
      .salon-section { height: 65vw; }
      .salon-overlay h2 { font-size: clamp(1.8rem, 7vw, 3rem); }

      /* Instagram */
      .ig-strip { padding: 3rem 0; }
      .ig-h2 { font-size: clamp(1.6rem, 7vw, 2.8rem); }

      /* Contact */
      .contact-left, .contact-right { padding: 3rem 1.25rem; }
      .contact-h2 { font-size: clamp(2.2rem, 8vw, 3.2rem); }
      .cinfo-item { font-size: .82rem; }

      /* Gallery */
      .gallery { padding: 3.5rem 0; }
      .gallery-h2 { font-size: clamp(1.8rem, 7vw, 3rem); }
      .gallery-img { aspect-ratio: 3/2; }

      /* Footer */
      .footer { padding: 2.5rem 0 1.5rem; }
      .footer-links { flex-wrap: wrap; gap: 1rem; }
      .footer-copy { flex-direction: column; gap: .4rem; }
    }
  </style>
</head>
