---
import Tracker from '../../components/Tracker.astro';
import { supabaseAdmin } from '../../lib/supabase';

const { data: lead } = await supabaseAdmin
  .from('leads')
  .select('id')
  .eq('slug', 'haarstudio-anouck')
  .maybeSingle();

if (lead?.id) {
  try { await supabaseAdmin.rpc('increment_view_count', { lead_id_param: lead.id }); } catch (_) {}
}

const imgPortrait = '/images/haarstudio-anouck/anouck.jpg';
const imgSalon    = '/images/haarstudio-anouck/salon.jpg';
const imgLogo     = '/images/haarstudio-anouck/logo.png';
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Haarstudio Anouck — jouw persoonlijke haarstudio voor knippen, kleuren en styling." />
  <meta name="robots" content="noindex, nofollow" />
  <title>Haarstudio Anouck | OnlineKoers voorstel</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --rose:     #C4827F;
      --rose-d:   #A86360;
      --rose-bg:  #F2C5C3;
      --rose-10:  rgba(196,130,127,0.1);
      --rose-20:  rgba(196,130,127,0.2);
      --cream:    #FAF8F6;
      --cream2:   #F3EDE9;
      --dark:     #1A1315;
      --dark2:    #221619;
      --text:     #2A1A1C;
      --muted:    rgba(42,26,28,0.52);
      --border:   rgba(42,26,28,0.1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .serif { font-family: 'Cormorant Garant', Georgia, serif; }
    .wrap  { max-width: 1140px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }

    /* ── Reveal ───────────────────────────────── */
    .r { opacity: 0; transform: translateY(24px); transition: opacity .8s cubic-bezier(.2,.8,.2,1), transform .8s cubic-bezier(.2,.8,.2,1); }
    .r.on { opacity: 1; transform: none; }
    .d1 { transition-delay: .12s; } .d2 { transition-delay: .22s; }
    .d3 { transition-delay: .34s; } .d4 { transition-delay: .46s; }

    /* ── Eyebrow label ────────────────────────── */
    .eyebrow {
      display: inline-flex; align-items: center; gap: .65rem;
      font-size: .6rem; font-weight: 700;
      letter-spacing: .3em; text-transform: uppercase;
      color: var(--rose);
    }
    .eyebrow::before { content: ''; width: 22px; height: 1px; background: var(--rose); }

    /* ── NAV ──────────────────────────────────── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      padding: 1.4rem 0;
      transition: padding .4s, background .4s, border-color .4s;
      border-bottom: 1px solid transparent;
    }
    .nav.s {
      background: rgba(250,248,246,.88);
      backdrop-filter: blur(20px) saturate(160%);
      padding: 1rem 0;
      border-color: var(--border);
    }
    .nav-row { display: flex; align-items: center; justify-content: space-between; }

    .nav-logo {
      display: flex; align-items: center; gap: .75rem;
      text-decoration: none;
    }
    .nav-logo img { height: 42px; width: 42px; object-fit: contain; border-radius: 50%; }
    .nav-logo-text {
      font-family: 'Cormorant Garant', serif;
      font-size: 1.1rem; font-weight: 600;
      color: var(--text); letter-spacing: .04em; line-height: 1.1;
    }
    .nav-logo-sub {
      font-family: 'DM Sans', sans-serif;
      font-size: .5rem; font-weight: 700;
      letter-spacing: .3em; text-transform: uppercase;
      color: var(--rose); display: block; margin-top: 1px;
    }

    .nav-links { display: flex; align-items: center; gap: 2.25rem; }
    .nav-link {
      font-size: .72rem; font-weight: 500;
      letter-spacing: .08em; color: var(--muted);
      text-decoration: none; transition: color .2s;
      position: relative;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -.25rem; left: 0; right: 0;
      height: 1px; background: var(--rose);
      transform: scaleX(0); transform-origin: left;
      transition: transform .25s;
    }
    .nav-link:hover { color: var(--text); }
    .nav-link:hover::after { transform: scaleX(1); }

    .nav-cta {
      font-size: .68rem; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      color: #fff; background: var(--rose);
      padding: .65rem 1.5rem; border-radius: 99px;
      text-decoration: none; transition: background .2s, transform .2s;
    }
    .nav-cta:hover { background: var(--rose-d); transform: translateY(-1px); }

    .nav-toggle {
      display: none; background: none; border: none; cursor: pointer;
      color: var(--text); padding: .3rem;
    }

    .nav-overlay {
      position: fixed; inset: 0; background: var(--cream); z-index: 350;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2.5rem;
      transform: translateY(-100%); transition: transform .5s cubic-bezier(.2,.8,.2,1);
    }
    .nav-overlay.on { transform: none; }
    .nav-overlay .nav-link { font-size: 1.4rem; letter-spacing: .04em; }
    .nav-overlay .nav-link::after { display: none; }
    .nav-overlay .nav-cta { font-size: .9rem; padding: 1rem 2.5rem; }
    .nav-overlay-close {
      position: absolute; top: 1.25rem; right: 1.25rem;
      background: none; border: 1.5px solid var(--border);
      cursor: pointer; border-radius: .4rem; width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text); transition: all .2s;
    }
    .nav-overlay-close:hover { background: var(--dark); border-color: var(--dark); color: #fff; }

    /* ── HERO ─────────────────────────────────── */
    .hero {
      min-height: 100svh;
      display: grid; grid-template-columns: 1fr 42vw;
      overflow: hidden; background: var(--cream);
    }
    .hero-left {
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 11rem clamp(2rem, 4vw, 4rem) 7rem clamp(1.5rem, max(3vw, calc((100vw - 1140px)/2 + 4rem)), 10rem);
    }
    .hero-eyebrow {
      margin-bottom: 1.25rem;
      animation: fadeUp .9s cubic-bezier(.2,.8,.2,1) .1s both;
    }
    .hero-h1 {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(3.2rem, 7vw, 6rem);
      font-weight: 600; line-height: .96; letter-spacing: .01em;
      color: var(--text);
      animation: fadeUp .9s cubic-bezier(.2,.8,.2,1) .3s both;
    }
    .hero-h1 em {
      display: block; font-style: italic;
      font-weight: 300; color: var(--rose);
      font-size: .8em;
    }
    .hero-sub {
      font-size: 1rem; color: var(--muted); line-height: 1.72;
      max-width: 380px; margin-top: 1.5rem; margin-bottom: 2.5rem;
      animation: fadeUp .9s cubic-bezier(.2,.8,.2,1) .5s both;
    }
    .hero-btns {
      display: flex; gap: .85rem; flex-wrap: wrap;
      animation: fadeUp .9s cubic-bezier(.2,.8,.2,1) .65s both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: none; }
    }

    .hero-right {
      position: relative; overflow: hidden;
      background: var(--rose-bg);
    }
    .hero-right::before {
      content: ''; position: absolute;
      left: 0; top: 0; bottom: 0; width: 60px;
      background: linear-gradient(to right, var(--cream), transparent);
      z-index: 2;
    }
    .hero-right img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      display: block;
    }

    .hero-scroll {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      color: var(--muted); pointer-events: none;
    }
    .hero-scroll span { font-size: .5rem; letter-spacing: .25em; text-transform: uppercase; }
    .hero-scroll-line {
      width: 1px; height: 38px;
      background: linear-gradient(to bottom, var(--rose), transparent);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:.3} 50%{opacity:1} }

    /* ── Buttons ──────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .72rem; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      padding: .9rem 2rem; border-radius: 99px;
      text-decoration: none; transition: all .25s; cursor: pointer; border: none;
    }
    .btn-rose { background: var(--rose); color: #fff; }
    .btn-rose:hover { background: var(--rose-d); transform: translateY(-2px); }
    .btn-ghost { border: 1.5px solid var(--border); color: var(--text); background: transparent; }
    .btn-ghost:hover { border-color: var(--rose); color: var(--rose); }

    /* ── STRIP ────────────────────────────────── */
    .strip {
      background: var(--dark2);
      padding: 4rem 0;
      text-align: center;
      position: relative; overflow: hidden;
    }
    .strip::before {
      content: '';
      position: absolute; inset: 0;
      background: repeating-linear-gradient(-45deg, rgba(255,255,255,.02) 0, rgba(255,255,255,.02) 1px, transparent 1px, transparent 8px);
    }
    .strip-text {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(1.4rem, 3vw, 2.1rem);
      font-style: italic; font-weight: 300;
      color: rgba(250,248,246,.85);
      max-width: 780px; margin: 0 auto;
      line-height: 1.5; position: relative; z-index: 1;
    }
    .strip-text strong { font-weight: 600; color: var(--rose-bg); font-style: normal; }

    /* ── OVER ANOUCK ──────────────────────────── */
    .about { padding: 9rem 0; background: var(--cream); }
    .about-grid { display: grid; grid-template-columns: 5fr 6fr; gap: 7rem; align-items: center; }

    .about-photo-wrap { position: relative; }
    .about-photo {
      aspect-ratio: 3/4; border-radius: .75rem; overflow: hidden;
      background: var(--rose-bg);
      box-shadow: 0 30px 80px rgba(42,26,28,.12);
    }
    .about-photo img {
      width: 100%; height: 100%; object-fit: cover; object-position: top center;
      display: block;
    }
    .about-photo-accent {
      position: absolute; bottom: -1.5rem; right: -1.5rem;
      background: var(--rose);
      border-radius: .5rem;
      padding: 1.5rem 2rem; text-align: center;
      color: #fff; box-shadow: 0 12px 40px rgba(196,130,127,.35);
    }
    .about-photo-accent-n {
      font-family: 'Cormorant Garant', serif;
      font-size: 2.5rem; font-weight: 700; line-height: 1; display: block;
    }
    .about-photo-accent-l {
      font-size: .55rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase;
      opacity: .8; margin-top: .2rem; display: block;
    }

    .about-h2 {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(2rem, 3.2vw, 3rem);
      font-weight: 600; line-height: 1.15; color: var(--text);
      margin-bottom: 1.75rem; margin-top: 1rem;
      position: relative; padding-bottom: 1rem;
    }
    .about-h2::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 0; height: 1.5px; background: var(--rose);
      transition: width .7s cubic-bezier(.2,.8,.2,1) .4s;
    }
    .r.on .about-h2::after { width: 2.5rem; }
    .about-h2 em { font-style: italic; font-weight: 300; color: var(--rose); }

    .about-p { font-size: .98rem; line-height: 1.82; color: var(--muted); margin-bottom: 1.1rem; }
    .about-social { display: flex; gap: .75rem; margin-top: 2rem; flex-wrap: wrap; }
    .social-btn {
      display: inline-flex; align-items: center; gap: .55rem;
      font-size: .68rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
      color: var(--text); border: 1.5px solid var(--border);
      padding: .65rem 1.2rem; border-radius: 99px;
      text-decoration: none; transition: all .2s;
    }
    .social-btn:hover { border-color: var(--rose); color: var(--rose); }
    .social-btn svg { flex-shrink: 0; }

    /* ── PRIJZEN ──────────────────────────────── */
    .prices {
      padding: 9rem 0;
      background: var(--dark2);
      position: relative; overflow: hidden;
    }
    .prices::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 70% 60% at 80% 30%, rgba(196,130,127,.07), transparent 70%);
      pointer-events: none;
    }
    .prices-header { margin-bottom: 4rem; }
    .prices-h2 {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(2.5rem, 4vw, 3.8rem);
      font-weight: 600; line-height: 1.05; color: #FAF8F6;
      margin-top: .75rem;
    }
    .prices-h2 em { font-style: italic; font-weight: 300; color: var(--rose-bg); }
    .prices-sub { font-size: .88rem; color: rgba(250,248,246,.38); margin-top: .75rem; }

    .prices-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .price-cat {
      background: rgba(250,248,246,.03);
      border: 1px solid rgba(250,248,246,.07);
      border-radius: .6rem; padding: 2.5rem;
      transition: border-color .3s, background .3s;
    }
    .price-cat:hover { background: rgba(196,130,127,.06); border-color: rgba(196,130,127,.3); }
    .price-cat-title {
      font-family: 'Cormorant Garant', serif;
      font-size: 1.4rem; font-weight: 600; color: #FAF8F6;
      margin-bottom: 1.75rem; padding-bottom: 1rem;
      border-bottom: 1px solid rgba(250,248,246,.07);
      letter-spacing: .02em;
    }
    .price-item {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: .7rem 0;
      border-bottom: 1px solid rgba(250,248,246,.04);
      gap: 1rem;
    }
    .price-item:last-child { border-bottom: none; }
    .price-name { font-size: .9rem; color: rgba(250,248,246,.6); }
    .price-val {
      font-family: 'Cormorant Garant', serif;
      font-size: 1.1rem; font-weight: 600;
      color: var(--rose-bg); white-space: nowrap; flex-shrink: 0;
    }
    .price-note {
      grid-column: 1 / -1;
      font-size: .72rem; color: rgba(250,248,246,.25);
      letter-spacing: .04em; margin-top: .5rem;
    }
    .price-note em { font-style: italic; }

    /* ── SALON FOTO ───────────────────────────── */
    .gallery { padding: 9rem 0; background: var(--cream2); }
    .gallery-h2 {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(2.5rem, 4vw, 3.8rem);
      font-weight: 600; color: var(--text);
      margin-top: .75rem; margin-bottom: 3rem;
    }
    .gallery-h2 em { font-style: italic; font-weight: 300; color: var(--rose); }

    .gallery-img {
      border-radius: .75rem; overflow: hidden;
      background: var(--rose-bg);
      box-shadow: 0 20px 60px rgba(42,26,28,.1);
      aspect-ratio: 16/9;
    }
    .gallery-img img {
      width: 100%; height: 100%; object-fit: cover;
      display: block; transition: transform .6s cubic-bezier(.2,.8,.2,1);
    }
    .gallery-img:hover img { transform: scale(1.03); }

    /* ── CONTACT ──────────────────────────────── */
    .contact { padding: 9rem 0; background: var(--cream); }
    .contact-grid { display: grid; grid-template-columns: 5fr 6fr; gap: 7rem; align-items: start; }

    .contact-h2 {
      font-family: 'Cormorant Garant', serif;
      font-size: clamp(2rem, 3.2vw, 3rem);
      font-weight: 600; line-height: 1.15; color: var(--text);
      margin-top: .75rem; margin-bottom: 1.5rem;
    }
    .contact-h2 em { font-style: italic; font-weight: 300; color: var(--rose); }
    .contact-p { font-size: .95rem; color: var(--muted); line-height: 1.75; margin-bottom: 2.5rem; }

    .cinfo { display: flex; flex-direction: column; gap: 1rem; }
    .cinfo-item {
      display: flex; align-items: flex-start; gap: .85rem;
      font-size: .88rem; color: var(--muted); line-height: 1.5;
    }
    .cinfo-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--rose); flex-shrink: 0; margin-top: .45rem;
      transition: transform .2s;
    }
    .cinfo-item:hover .cinfo-dot { transform: scale(1.6); }
    .cinfo-item a { color: inherit; text-decoration: none; transition: color .2s; }
    .cinfo-item a:hover { color: var(--rose); }

    /* Form */
    .form { display: flex; flex-direction: column; gap: 1rem; }
    .frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: .35rem; }
    .field label {
      font-size: .58rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase; color: var(--muted);
    }
    .field input, .field select, .field textarea {
      width: 100%; padding: .9rem 1.15rem;
      border-radius: .4rem; border: 1.5px solid var(--border);
      background: var(--cream2); font-family: 'DM Sans', sans-serif;
      font-size: .92rem; color: var(--text); outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 3px rgba(196,130,127,.12);
    }
    .field textarea { resize: vertical; min-height: 110px; }
    .field select { appearance: none; cursor: pointer; }

    .form-submit {
      width: 100%; padding: 1.1rem;
      background: var(--rose); color: #fff;
      border: none; border-radius: 99px;
      font-family: 'DM Sans', sans-serif;
      font-size: .72rem; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      cursor: pointer; transition: all .25s; margin-top: .5rem;
    }
    .form-submit:hover { background: var(--rose-d); transform: translateY(-2px); }
    .form-submit:disabled { opacity: .4; cursor: not-allowed; transform: none; }

    .form-success {
      display: none; text-align: center; padding: 3rem 2rem;
      border-radius: .5rem; border: 1.5px solid var(--border);
      background: var(--cream2);
    }
    .form-success.on { display: block; }
    .form-success-icon {
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--rose-10); border: 1.5px solid var(--rose-20);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem; color: var(--rose); font-size: 1.2rem;
    }
    .form-success h3 {
      font-family: 'Cormorant Garant', serif;
      font-size: 1.8rem; font-weight: 600; color: var(--text); margin-bottom: .6rem;
    }
    .form-success p { font-size: .88rem; color: var(--muted); line-height: 1.7; }

    /* ── FOOTER ───────────────────────────────── */
    .footer { background: var(--dark2); padding: 4rem 0 2.5rem; }
    .footer-row {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 2rem;
      padding-bottom: 3rem; border-bottom: 1px solid rgba(250,248,246,.07);
    }
    .footer-logo {
      display: flex; align-items: center; gap: .75rem; text-decoration: none;
    }
    .footer-logo img { height: 38px; width: 38px; object-fit: contain; border-radius: 50%; }
    .footer-logo-name {
      font-family: 'Cormorant Garant', serif;
      font-size: 1.1rem; font-weight: 600; color: rgba(250,248,246,.8);
      letter-spacing: .04em;
    }
    .footer-links { display: flex; gap: 2rem; flex-wrap: wrap; }
    .footer-link {
      font-size: .72rem; color: rgba(250,248,246,.35);
      text-decoration: none; transition: color .2s;
    }
    .footer-link:hover { color: rgba(250,248,246,.8); }
    .footer-copy {
      padding-top: 2rem; display: flex; justify-content: space-between;
      flex-wrap: wrap; gap: 1rem;
      font-size: .68rem; color: rgba(250,248,246,.22);
    }

    /* ── RESPONSIVE ───────────────────────────── */
    @media (max-width: 960px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { height: 60vw; }
      .hero-right::before { left: 0; width: 40px; }
      .hero-left { padding: 8rem 1.5rem 3.5rem; justify-content: flex-start; }
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .about-grid { grid-template-columns: 1fr; gap: 4rem; }
      .about-photo-wrap { max-width: min(75vw, 300px); margin: 0 auto; }
      .about-photo-accent { display: none; }
      .prices-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; gap: 4rem; }
      .frow { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
      .hero-right { height: 70vw; }
      .gallery-img { aspect-ratio: 4/3; }
    }
  </style>
</head>
<body>

<!-- ── NAV ──────────────────────────────────────────────────────────── -->
<nav class="nav" id="mainNav">
  <div class="wrap nav-row">
    <a href="#" class="nav-logo">
      <img src={imgLogo} alt="Haarstudio Anouck logo" />
      <div>
        <span class="nav-logo-text">Haarstudio Anouck</span>
        <span class="nav-logo-sub">Officieel voorstel</span>
      </div>
    </a>

    <div class="nav-links">
      <a href="#over"      class="nav-link">Over Anouck</a>
      <a href="#diensten"  class="nav-link">Diensten</a>
      <a href="#salon"     class="nav-link">De salon</a>
