<script>
  const nav          = document.getElementById('mainNav')!;
  const navToggle    = document.getElementById('navToggle')!;
  const navOverlay   = document.getElementById('navOverlay')!;
  const overlayClose = document.getElementById('navOverlayClose')!;

  function openMenu() {
    navOverlay.classList.add('on');
    document.body.style.overflow = 'hidden';
    navToggle.setAttribute('aria-label', 'Menu sluiten');
  }
  function closeMenu() {
    navOverlay.classList.remove('on');
    document.body.style.overflow = '';
    navToggle.setAttribute('aria-label', 'Menu openen');
  }

  navToggle.addEventListener('click', () => {
    navOverlay.classList.contains('on') ? closeMenu() : openMenu();
  });
  overlayClose.addEventListener('click', closeMenu);
  navOverlay.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));

  window.addEventListener('scroll', () => {
    nav.classList.toggle('s', window.scrollY > 60);
  }, { passive: true });

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('on'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.r').forEach(el => obs.observe(el));

  document.getElementById('bookForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const btn = (e.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('.form-submit')!;
    btn.textContent = 'Versturen...';
    btn.disabled = true;
    await new Promise(r => setTimeout(r, 700));
    (e.currentTarget as HTMLElement).style.display = 'none';
    document.getElementById('bookSuccess')!.classList.add('on');
  });
</script>

</body>
